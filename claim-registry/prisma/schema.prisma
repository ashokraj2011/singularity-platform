// claim-registry — Prisma schema. M-CR1: claims, versions, evidence, maturity, receipts
// + the M11.e event-bus trio. M-CR2: knowledge capture + lowering. M-CR4: the ambiguity
// ledger + claim relations (sweeps open ledger rows; projections read them). ClaimMerge
// is the one model still deferred.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL_CLAIM_REGISTRY")
  extensions = [vector, pgcrypto]
}

enum ClaimKind {
  HYPOTHESIS
  ASSUMPTION
  OBSERVATION
  CONSTRAINT
  DECISION
  REQUIREMENT
}

enum MaturityState {
  FRAGMENT
  HYPOTHESIS
  VALIDATED
  REQUIREMENT
  SPEC_BOUND
  FALSIFIED
}

enum ClaimStatus {
  ACTIVE
  MERGED
  RETIRED
  FALSIFIED
}

enum EvidenceTier {
  T0
  T1
  T2
  T3
}

enum EvidenceKind {
  DATA_PULL
  PROD_TELEMETRY
  EXPERIMENT
  SPIKE
  USABILITY_SESSION
  INTERVIEW
  EXPERT_OPINION
  DOCUMENT
  MARKET_SIGNAL
}

enum EvidenceDirection {
  SUPPORTS
  CONTRADICTS
}

model Claim {
  id                String        @id @default(uuid())
  tenantId          String        @default("default")
  capabilityId      String? // platform org-scoping join key; null = org-level
  kind              ClaimKind
  maturity          MaturityState @default(FRAGMENT)
  status            ClaimStatus   @default(ACTIVE)
  statement         String
  canonicalKey      String // sha256 of normalized statement — the hard dedup guard
  embedding         Unsupported("vector(1536)")?
  embeddingDegraded Boolean       @default(false) // set when canonicalization couldn't embed (fail-loud, never silent-fork)
  subjectRefs       Json          @default("[]")
  tags              String[]      @default([])
  // Bayesian state — DERIVED, never set by an API (invariant 3)
  priorLogOdds      Float         @default(0)
  posteriorLogOdds  Float         @default(0)
  posteriorProb     Float         @default(0.5)
  effectiveEvidence Float         @default(0)
  halfLifeDays      Int           @default(180)
  thresholdHeldSince DateTime?    // when posterior first crossed the current maturity threshold
  lastComputedAt    DateTime      @default(now())
  provenance        Json          @default("{}")
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  currentVersion    Int           @default(1)

  versions      ClaimVersion[]
  evidenceLinks EvidenceLink[]
  transitions   MaturityTransition[]
  relationsFrom ClaimRelation[]      @relation("RelationFrom")
  relationsTo   ClaimRelation[]      @relation("RelationTo")
  ambiguities   Ambiguity[]

  @@unique([tenantId, canonicalKey])
  @@index([tenantId, capabilityId, maturity, status])
  @@index([kind, status])
  @@map("claims")
}

model ClaimVersion {
  id         String   @id @default(uuid())
  tenantId   String   @default("default")
  claimId    String
  claim      Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  version    Int
  statement  String
  changeNote String?
  editedBy   String
  createdAt  DateTime @default(now())

  @@unique([claimId, version])
  @@map("claim_versions")
}

model EvidenceObject {
  id          String       @id @default(uuid())
  tenantId    String       @default("default")
  tier        EvidenceTier
  kind        EvidenceKind
  contentHash String       // sha256 of raw payload — immutable at intake (invariant 2)
  excerpt     String
  payloadRef  String? // MinIO ref (bounded, fail-closed fetch)
  sourceMeta  Json         @default("{}")
  observedAt  DateTime
  signature   String?
  createdBy   String
  createdAt   DateTime     @default(now())

  links EvidenceLink[]

  @@unique([tenantId, contentHash])
  @@map("evidence_objects")
}

model EvidenceLink {
  id                 String            @id @default(uuid())
  tenantId           String            @default("default")
  claimId            String
  claim              Claim             @relation(fields: [claimId], references: [id], onDelete: Cascade)
  evidenceId         String
  evidence           EvidenceObject    @relation(fields: [evidenceId], references: [id])
  direction          EvidenceDirection
  logLikelihoodRatio Float // raw; capped by tier at compute time
  sourceKey          String // same-source diminishing dedup key
  decayExempt        Boolean           @default(false)
  attachedBy         String
  attachedAt         DateTime          @default(now())

  @@unique([claimId, evidenceId])
  @@index([claimId, attachedAt])
  @@map("evidence_links")
}

model MaturityTransition {
  id             String        @id @default(uuid())
  tenantId       String        @default("default")
  claimId        String
  claim          Claim         @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fromState      MaturityState
  toState        MaturityState
  thresholdProb  Float
  actualProb     Float
  evidenceHash   String // canonical-JSON sha256 of the evidence set (M11.c)
  approvedBy     String?
  receiptTraceId String
  occurredAt     DateTime      @default(now())

  @@index([claimId, occurredAt])
  @@map("maturity_transitions")
}

// M11.d unified receipt envelope, persisted (joinable by traceId).
model Receipt {
  id            String   @id @default(uuid())
  tenantId      String   @default("default")
  traceId       String
  kind          String
  sourceService String   @default("claim-registry")
  subjectKind   String
  subjectId     String
  actorKind     String
  actorId       String
  status        String
  payload       Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([traceId])
  @@map("receipts")
}

// M11.e event bus — outbox + subscriber registry + per-delivery state.
model EventOutbox {
  id          String   @id @default(uuid())
  tenantId    String   @default("default")
  eventType   String
  aggregateId String
  payload     Json
  traceId     String?
  status      String   @default("PENDING") // PENDING | PROCESSED
  createdAt   DateTime @default(now())

  deliveries EventDelivery[]

  @@index([status, createdAt])
  @@map("event_outbox")
}

model EventSubscription {
  id         String   @id @default(uuid())
  tenantId   String   @default("default")
  name       String
  eventTypes String[]
  targetUrl  String
  secret     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  deliveries EventDelivery[]

  @@unique([tenantId, name])
  @@map("event_subscriptions")
}

model EventDelivery {
  id             String            @id @default(uuid())
  tenantId       String            @default("default")
  outboxId       String
  outbox         EventOutbox       @relation(fields: [outboxId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   EventSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  status         String            @default("PENDING") // PENDING | DELIVERED | FAILED
  attempts       Int               @default(0)
  lastError      String?
  updatedAt      DateTime          @updatedAt

  @@unique([outboxId, subscriptionId])
  @@map("event_deliveries")
}

// ── Capture: knowledge events + lowering (M-CR2) ──────────────────────────────
enum CaptureSource {
  TRANSCRIPT
  SLACK
  CONFLUENCE
  BOARD_EXPORT
  WORKBENCH
  MANUAL
}

enum LoweringStatus {
  PENDING
  LOWERED
  NO_CLAIMS
  FAILED
}

enum CandidateStatus {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
  MERGED_TO_EXISTING
}

model KnowledgeEvent {
  id             String         @id @default(uuid())
  tenantId       String         @default("default")
  source         CaptureSource
  externalRef    String?
  contentHash    String         // hash-dedup: same capture links, not re-ingests
  payloadRef     String // MinIO ref to raw capture
  capabilityId   String?
  capturedBy     String
  capturedAt     DateTime       @default(now())
  loweringStatus LoweringStatus @default(PENDING)

  candidates LoweringCandidate[]

  @@unique([tenantId, contentHash])
  @@map("knowledge_events")
}

model LoweringCandidate {
  id                String          @id @default(uuid())
  tenantId          String          @default("default")
  eventId           String
  event             KnowledgeEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposedStatement String
  proposedKind      ClaimKind
  modelConfidence   Float // lowering-pass self-estimate; advisory only
  matchedClaimId    String? // canonicalization hit, if any (the dedup guard)
  status            CandidateStatus @default(PENDING_REVIEW)
  reviewedBy        String?
  resultingClaimId  String?
  createdAt         DateTime        @default(now())

  @@index([status, createdAt])
  @@map("lowering_candidates")
}

// ── Ambiguity ledger + relations (M-CR4) ──────────────────────────────────────
enum AmbiguityType {
  CONTRADICTION // two still-believed claims asserted to contradict
  MISSING_EVIDENCE // a matured claim decayed below its gate threshold
  STARVATION // a young claim with no evidence, aging out
}

enum AmbiguityStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum RelationType {
  CONTRADICTS
  DEPENDS_ON
  REFINES
  DUPLICATES
}

// A typed claim-to-claim edge, asserted (never inferred — no embeddings). CONTRADICTS is
// the input the contradiction sweep reads.
model ClaimRelation {
  id          String       @id @default(uuid())
  tenantId    String       @default("default")
  fromClaimId String
  fromClaim   Claim        @relation("RelationFrom", fields: [fromClaimId], references: [id], onDelete: Cascade)
  toClaimId   String
  toClaim     Claim        @relation("RelationTo", fields: [toClaimId], references: [id], onDelete: Cascade)
  type        RelationType
  note        String?
  createdBy   String
  createdAt   DateTime     @default(now())

  @@unique([fromClaimId, toClaimId, type])
  @@index([type])
  @@index([toClaimId])
  @@map("claim_relations")
}

// A surfaced-but-unresolved epistemic tension. The sweeps open these; humans close them.
// dedupeKey (type + sorted claim ids) is the idempotency guard — NOT a DB unique, so a
// resolved row and a later-reopened one coexist; "one OPEN per key" is code-enforced.
model Ambiguity {
  id             String          @id @default(uuid())
  tenantId       String          @default("default")
  type           AmbiguityType
  status         AmbiguityStatus @default(OPEN)
  claimId        String
  claim          Claim           @relation(fields: [claimId], references: [id], onDelete: Cascade)
  relatedClaimId String? // the other side of a CONTRADICTION (soft ref, no FK)
  dedupeKey      String
  severity       String          @default("MEDIUM") // LOW | MEDIUM | HIGH
  detail         Json            @default("{}")
  openedBy       String // sweep name or actor
  openedAt       DateTime        @default(now())
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionNote String?

  @@index([status, type])
  @@index([claimId, status])
  @@index([dedupeKey, status])
  @@map("ambiguities")
}
