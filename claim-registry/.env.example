# claim-registry — service env (M-CR1)
PORT=8600
DATABASE_URL_CLAIM_REGISTRY=postgresql://claim_registry:claim_registry@localhost:5437/claim_registry

# Authentication and tenant boundary. IAM is the default and the service no
# longer trusts x-user-id/x-service-name headers. Set CLAIM_REGISTRY_AUTH_PROVIDER=local
# only for isolated development with a compatible HS256 JWT_SECRET.
CLAIM_REGISTRY_AUTH_PROVIDER=iam
# PLATFORM_REGISTRY_URL=http://localhost:8090
# IAM_BASE_URL=http://localhost:8100/api/v1
# IAM_SERVICE_TOKEN=
# JWT_SECRET=change-me-min-32-chars
# TENANT_ISOLATION_MODE=strict
# CLAIM_REGISTRY_DEFAULT_TENANT_ID=default
# LLM_GATEWAY_URL=http://localhost:8000        # M33: model_alias only, no provider creds here
# EMBEDDING_MODEL_ALIAS=openai-text-embedding-3-small  # canonicalization needs a REAL embedding alias (not the anthropic default, which 400s)
# MINIO_ENDPOINT=http://localhost:9000
