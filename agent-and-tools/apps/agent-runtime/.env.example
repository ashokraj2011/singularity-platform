NODE_ENV=development
PORT=3003
DATABASE_URL=postgresql://postgres:singularity@localhost:5432/singularity
JWT_SECRET=dev-secret-change-in-prod
LOG_LEVEL=info
DEFAULT_MODEL_PROVIDER=stub
DEFAULT_MODEL_NAME=stub-model

# Bootstrap agent catalog (role-agents + team presets used when onboarding a capability).
# Optional: point AGENT_CATALOG_PATH at a JSON file to customize the roles, locked gates,
# and presets without a code change (AGENT_CATALOG_JSON accepts inline JSON and wins if set).
# Unset (the default) uses the built-in catalog. Start from .singularity/agent-catalog.json.default.
# AGENT_CATALOG_PATH=.singularity/agent-catalog.json
# AGENT_CATALOG_JSON=

# Permission key that grants platform-admin (default "platform:all"). Lets admin gating
# bind to the IAM permission model, not just role-name strings. See lib/authz/platform-admin.ts.
# PLATFORM_ADMIN_PERMISSION=platform:all
