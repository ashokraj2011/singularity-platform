// M29 — per-service Prisma client output. agent-runtime and prompt-composer
// each generate to their own path so the workspace's shared node_modules
// can't cause "last-generate-wins" model loss after their schemas diverged.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

// M31 — auto-generated ERD. Emits a Markdown file with an embedded Mermaid
// diagram; GitHub renders it natively. Regenerated on every `prisma generate`,
// so a schema PR that forgets to re-run will fail the CI drift gate.
generator erd_md {
  provider = "prisma-erd-generator"
  output   = "../../../../docs/data-model/02-agent-runtime.md"
  theme    = "default"
}

// Static PNG for offline use (slide decks, the docs/index.html landing page).
generator erd_png {
  provider = "prisma-erd-generator"
  output   = "../../../../docs/data-model/02-agent-runtime.png"
  theme    = "default"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AgentRoleType {
  ARCHITECT
  DEVELOPER
  QA
  GOVERNANCE
  BUSINESS_ANALYST
  PRODUCT_OWNER
  DEVOPS
  SECURITY
}

// M30 — composer-owned models moved to `singularity_composer` DB.
// Their enums (PromptScopeType, PromptLayerType) moved to composer too.
// No mirrors needed: each schema pushes to its own DB.

enum ToolRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ToolGrantScopeType {
  AGENT_TEMPLATE
  AGENT_BINDING
  CAPABILITY
  ROLE
  WORKFLOW_PHASE
  TEAM
  USER
}

enum ExecutionStatus {
  CREATED
  PROMPT_ASSEMBLED
  RUNNING
  WAITING_FOR_TOOL
  WAITING_FOR_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum MemoryPromotionStatus {
  NOT_REVIEWED
  CANDIDATE
  APPROVED
  REJECTED
  PROMOTED
}

model AgentTemplate {
  id                  String       @id @default(uuid())
  name                String
  roleType            AgentRoleType
  description         String?
  basePromptProfileId String?
  defaultToolPolicyId String?
  version             Int          @default(1)
  status              EntityStatus @default(DRAFT)
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // M23 — Agent Studio governance fields.
  // capabilityId NULL  ⟹  common library template (cross-capability baseline)
  // capabilityId set   ⟹  capability-scoped template (derived OR created from scratch)
  // baseTemplateId set ⟹  derived from another template (preserves lineage)
  // lockedReason       ⟹  human-readable reason this template rejects edits
  capabilityId        String?
  baseTemplateId      String?
  lockedReason        String?

  baseTemplate        AgentTemplate?  @relation("AgentTemplateDerivation", fields: [baseTemplateId], references: [id])
  derivedTemplates    AgentTemplate[] @relation("AgentTemplateDerivation")

  skills     AgentTemplateSkill[]
  bindings   AgentCapabilityBinding[]
  executions AgentExecution[]
  versions   AgentTemplateVersion[]

  @@index([capabilityId])
  @@index([baseTemplateId])
}

model AgentTemplateVersion {
  id              String   @id @default(uuid())
  agentTemplateId String
  version         Int
  changeSummary   String?
  snapshot        Json
  createdBy       String?
  createdAt       DateTime @default(now())

  agentTemplate AgentTemplate @relation(fields: [agentTemplateId], references: [id])

  @@unique([agentTemplateId, version])
  @@index([agentTemplateId, createdAt])
}

model AgentSkill {
  id            String       @id @default(uuid())
  name          String
  skillType     String
  description   String?
  promptLayerId String?
  version       Int          @default(1)
  status        EntityStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  agentTemplates AgentTemplateSkill[]
}

model AgentTemplateSkill {
  id              String   @id @default(uuid())
  agentTemplateId String
  skillId         String
  isDefault       Boolean  @default(true)
  createdAt       DateTime @default(now())

  agentTemplate AgentTemplate @relation(fields: [agentTemplateId], references: [id])
  skill         AgentSkill    @relation(fields: [skillId], references: [id])

  @@unique([agentTemplateId, skillId])
}

model Capability {
  id                 String       @id @default(uuid())
  name               String
  parentCapabilityId String?
  capabilityType     String?
  businessUnitId     String?
  ownerTeamId        String?
  criticality        String?
  description        String?
  status             EntityStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  parent             Capability?  @relation("CapabilityHierarchy", fields: [parentCapabilityId], references: [id])
  children           Capability[] @relation("CapabilityHierarchy")
  bindings           AgentCapabilityBinding[]
  repositories       CapabilityRepository[]
  knowledgeArtifacts CapabilityKnowledgeArtifact[]
  knowledgeSources   CapabilityKnowledgeSource[]
  bootstrapRuns      CapabilityBootstrapRun[]
  learningCandidates CapabilityLearningCandidate[]
  executions         AgentExecution[]
}

model AgentCapabilityBinding {
  id                  String       @id @default(uuid())
  agentTemplateId     String
  capabilityId        String
  bindingName         String
  roleInCapability    String?
  promptProfileId     String?
  toolPolicyId        String?
  memoryScopePolicyId String?
  status              EntityStatus @default(ACTIVE)
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  agentTemplate AgentTemplate    @relation(fields: [agentTemplateId], references: [id])
  capability    Capability       @relation(fields: [capabilityId], references: [id])
  executions    AgentExecution[]
}

// M30 — PromptProfile, PromptLayer, PromptProfileLayer, PromptAssembly,
// PromptAssemblyLayer, CapabilityCompiledContext, and their enums
// (PromptScopeType, PromptLayerType) moved to prompt-composer's own DB
// (`singularity_composer`). Composer's prisma/schema.prisma is the
// authoritative declaration. Composer reads agent-runtime models via a
// second client (`runtimeReader`) connected to THIS db.

model ToolDefinition {
  id          String       @id @default(uuid())
  name        String
  namespace   String
  description String?
  toolType    String?
  version     Int          @default(1)
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contracts ToolContract[]
  grants    ToolGrant[]
  receipts  ToolExecutionReceipt[]

  @@unique([namespace, name, version])
}

model ToolContract {
  id               String        @id @default(uuid())
  toolId           String
  inputSchema      Json
  outputSchema     Json?
  allowedUsage     String?
  deniedUsage      String?
  riskLevel        ToolRiskLevel @default(LOW)
  requiresApproval Boolean       @default(false)
  auditRequired    Boolean       @default(true)
  timeoutMs        Int           @default(30000)
  version          Int           @default(1)
  status           EntityStatus  @default(ACTIVE)
  createdAt        DateTime      @default(now())

  tool ToolDefinition @relation(fields: [toolId], references: [id])
}

model ToolPolicy {
  id          String       @id @default(uuid())
  name        String
  description String?
  scopeType   String?
  scopeId     String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  grants ToolGrant[]
}

model ToolGrant {
  id                       String             @id @default(uuid())
  toolPolicyId             String
  toolId                   String
  grantScopeType           ToolGrantScopeType
  grantScopeId             String
  allowedActions           Json?
  deniedActions            Json?
  environment              String?
  workflowPhase            String?
  requiresApprovalOverride Boolean?
  status                   EntityStatus       @default(ACTIVE)
  createdAt                DateTime           @default(now())

  toolPolicy ToolPolicy     @relation(fields: [toolPolicyId], references: [id])
  tool       ToolDefinition @relation(fields: [toolId], references: [id])
}

model CapabilityRepository {
  id             String       @id @default(uuid())
  capabilityId   String
  repoName       String
  repoUrl        String
  defaultBranch  String?
  repositoryType String?
  status         EntityStatus @default(ACTIVE)
  // M17 — polling config. NULL pollIntervalSec disables auto-poll. The
  // worker stores the last seen HEAD SHA so it only re-extracts on change.
  pollIntervalSec Int?
  lastPolledAt    DateTime?
  lastPolledSha   String?
  lastPollError   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  capability Capability             @relation(fields: [capabilityId], references: [id])
  symbols    CapabilityCodeSymbol[]
}

// M17 — polled knowledge sources. Each row points at a remote markdown
// (or plain text) URL; the worker fetches periodically and upserts the
// content into a CapabilityKnowledgeArtifact row keyed by
// (capabilityId, sourceRef=url). Distinct from CapabilityKnowledgeArtifact
// because the artifact is the *materialised* content; this model is the
// *source* config (URL + cadence).
model CapabilityKnowledgeSource {
  id              String       @id @default(uuid())
  capabilityId   String
  url             String       // Public HTTPS URL of a markdown / plain text file
  artifactType   String       @default("DOC") // applied to the upserted artifact
  title           String?     // Display name; falls back to URL
  pollIntervalSec Int?
  lastPolledAt    DateTime?
  lastContentHash String?
  lastPollError   String?
  status          EntityStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id])
}

model CapabilityKnowledgeArtifact {
  id           String       @id @default(uuid())
  capabilityId String
  artifactType String
  title        String
  content      String
  sourceType   String?
  sourceRef    String?
  confidence   Decimal?     @db.Decimal(5, 2)
  version      Int          @default(1)
  status       EntityStatus @default(ACTIVE)
  contentHash  String?
  // M15 — pgvector column for semantic retrieval. Embedded on write.
  embedding    Unsupported("vector(1536)")?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id])
}

model CapabilityBootstrapRun {
  id                String    @id @default(uuid())
  capabilityId      String
  status            String    @default("RUNNING")
  sourceSummary     Json      @default("{}")
  generatedAgentIds Json      @default("[]")
  warnings          Json      @default("[]")
  errors            Json      @default("[]")
  createdBy         String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  capability Capability                    @relation(fields: [capabilityId], references: [id])
  candidates CapabilityLearningCandidate[]

  @@index([capabilityId, createdAt])
  @@index([status, createdAt])
}

model CapabilityLearningCandidate {
  id                     String   @id @default(uuid())
  capabilityId           String
  bootstrapRunId         String?
  groupKey               String
  groupTitle             String
  artifactType           String
  title                  String
  content                String
  sourceType             String?
  sourceRef              String?
  confidence             Decimal? @db.Decimal(5, 2)
  status                 String   @default("PENDING")
  materializedArtifactId String?
  reviewedBy             String?
  reviewedAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  capability   Capability              @relation(fields: [capabilityId], references: [id])
  bootstrapRun CapabilityBootstrapRun? @relation(fields: [bootstrapRunId], references: [id])

  @@index([capabilityId, status])
  @@index([bootstrapRunId, groupKey])
  @@index([sourceType, sourceRef])
}

model CapabilityCodeSymbol {
  id             String   @id @default(uuid())
  capabilityId   String
  repositoryId   String
  filePath       String
  language       String?
  symbolName     String?
  symbolType     String?
  parentSymbolId String?
  startLine      Int?
  endLine        Int?
  summary        String?
  symbolHash     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  repository CapabilityRepository      @relation(fields: [repositoryId], references: [id])
  embeddings CapabilityCodeEmbedding[]
}

model CapabilityCodeEmbedding {
  id             String   @id @default(uuid())
  symbolId       String
  embeddingModel String?
  vectorId       String?
  summary        String?
  // M15 — pgvector column. Prisma can't bind unsupported types, so writes go
  // through raw SQL UPDATE. Reads use prisma + raw SELECT for cosine.
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime @default(now())

  symbol CapabilityCodeSymbol @relation(fields: [symbolId], references: [id])
}

model AgentExecution {
  id                  String          @id @default(uuid())
  workflowExecutionId String?
  capabilityId        String?
  agentTemplateId     String
  agentBindingId      String?
  userRequest         String?
  executionStatus     ExecutionStatus @default(CREATED)
  modelProvider       String?
  modelName           String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdBy           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  capability        Capability?             @relation(fields: [capabilityId], references: [id])
  agentTemplate     AgentTemplate           @relation(fields: [agentTemplateId], references: [id])
  agentBinding      AgentCapabilityBinding? @relation(fields: [agentBindingId], references: [id])
  toolReceipts      ToolExecutionReceipt[]
  executionReceipts AgentExecutionReceipt[]
}

model ToolExecutionReceipt {
  id               String    @id @default(uuid())
  agentExecutionId String
  toolId           String
  toolName         String
  inputHash        String?
  outputHash       String?
  approvalId       String?
  status           String
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id])
  tool           ToolDefinition @relation(fields: [toolId], references: [id])
}

model AgentExecutionReceipt {
  id               String   @id @default(uuid())
  agentExecutionId String
  promptAssemblyId String?
  promptHash       String?
  outputHash       String?
  toolReceiptRefs  Json?
  evidenceRefs     Json?
  memoryRefs       Json?
  approvalRefs     Json?
  finalStatus      String?
  createdAt        DateTime @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id])
}

model WorkflowExecutionMemory {
  id                  String                @id @default(uuid())
  workflowExecutionId String
  capabilityId        String?
  agentBindingId      String?
  memoryType          String
  title               String?
  content             String
  evidenceRefs        Json?
  confidence          Decimal?              @db.Decimal(5, 2)
  promotionStatus     MemoryPromotionStatus @default(NOT_REVIEWED)
  createdAt           DateTime              @default(now())
}

model DistilledMemory {
  id                 String       @id @default(uuid())
  scopeType          String
  scopeId            String
  memoryType         String
  title              String
  content            String
  sourceExecutionIds Json?
  evidenceRefs       Json?
  approvedBy         String?
  confidence         Decimal?     @db.Decimal(5, 2)
  version            Int          @default(1)
  status             EntityStatus @default(ACTIVE)
  // M15 — pgvector column for semantic retrieval. Embedded on distill.
  embedding          Unsupported("vector(1536)")?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// ─── M11.e — Event Bus (publisher side; subscribers can register via routes) ─

model EventOutbox {
  id            String   @id @default(uuid())
  eventName     String
  sourceService String
  traceId       String?
  subjectKind   String
  subjectId     String
  envelope      Json
  status        String   @default("pending")  // pending | dispatched | failed
  attempts      Int      @default(0)
  emittedAt     DateTime @default(now())
  lastAttemptAt DateTime?
  lastError     String?
  deliveries    EventDelivery[]

  @@index([status, emittedAt])
  @@index([eventName])
  @@index([traceId])
  @@map("event_outbox")
}

model EventSubscription {
  id            String   @id @default(uuid())
  subscriberId  String
  eventPattern  String
  targetUrl     String
  secret        String?
  isActive      Boolean  @default(true)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deliveries    EventDelivery[]

  @@index([isActive, eventPattern])
  @@map("event_subscriptions")
}

model EventDelivery {
  id              String   @id @default(uuid())
  outboxId        String
  subscriptionId  String
  status          String   @default("queued")
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  lastError       String?
  deliveredAt     DateTime?
  responseStatus  Int?
  outbox          EventOutbox       @relation(fields: [outboxId],       references: [id], onDelete: Cascade)
  subscription    EventSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([outboxId, subscriptionId])
  @@index([status, createdAt])
  @@map("event_deliveries")
}
