generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AgentRoleType {
  ARCHITECT
  DEVELOPER
  QA
  GOVERNANCE
  BUSINESS_ANALYST
  PRODUCT_OWNER
  DEVOPS
  SECURITY
}

enum PromptScopeType {
  PLATFORM
  TENANT
  BUSINESS_UNIT
  CAPABILITY
  AGENT_TEMPLATE
  AGENT_BINDING
  WORKFLOW
  WORKFLOW_PHASE
  EXECUTION
}

enum PromptLayerType {
  PLATFORM_CONSTITUTION
  TENANT_CONTEXT
  BUSINESS_UNIT_CONTEXT
  AGENT_ROLE
  SKILL_CONTRACT
  TOOL_CONTRACT
  CAPABILITY_CONTEXT
  REPOSITORY_CONTEXT
  WORKFLOW_CONTEXT
  PHASE_CONTEXT
  TASK_CONTEXT
  RUNTIME_EVIDENCE
  MEMORY_CONTEXT
  OUTPUT_CONTRACT
  APPROVAL_POLICY
  DATA_ACCESS_POLICY
}

enum ToolRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ToolGrantScopeType {
  AGENT_TEMPLATE
  AGENT_BINDING
  CAPABILITY
  ROLE
  WORKFLOW_PHASE
  TEAM
  USER
}

enum ExecutionStatus {
  CREATED
  PROMPT_ASSEMBLED
  RUNNING
  WAITING_FOR_TOOL
  WAITING_FOR_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum MemoryPromotionStatus {
  NOT_REVIEWED
  CANDIDATE
  APPROVED
  REJECTED
  PROMOTED
}

model AgentTemplate {
  id                  String       @id @default(uuid())
  name                String
  roleType            AgentRoleType
  description         String?
  basePromptProfileId String?
  defaultToolPolicyId String?
  version             Int          @default(1)
  status              EntityStatus @default(DRAFT)
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  skills     AgentTemplateSkill[]
  bindings   AgentCapabilityBinding[]
  executions AgentExecution[]
}

model AgentSkill {
  id            String       @id @default(uuid())
  name          String
  skillType     String
  description   String?
  promptLayerId String?
  version       Int          @default(1)
  status        EntityStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  agentTemplates AgentTemplateSkill[]
}

model AgentTemplateSkill {
  id              String   @id @default(uuid())
  agentTemplateId String
  skillId         String
  isDefault       Boolean  @default(true)
  createdAt       DateTime @default(now())

  agentTemplate AgentTemplate @relation(fields: [agentTemplateId], references: [id])
  skill         AgentSkill    @relation(fields: [skillId], references: [id])

  @@unique([agentTemplateId, skillId])
}

model Capability {
  id                 String       @id @default(uuid())
  name               String
  parentCapabilityId String?
  capabilityType     String?
  businessUnitId     String?
  ownerTeamId        String?
  criticality        String?
  description        String?
  status             EntityStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  parent             Capability?  @relation("CapabilityHierarchy", fields: [parentCapabilityId], references: [id])
  children           Capability[] @relation("CapabilityHierarchy")
  bindings           AgentCapabilityBinding[]
  repositories       CapabilityRepository[]
  knowledgeArtifacts CapabilityKnowledgeArtifact[]
  executions         AgentExecution[]
}

model AgentCapabilityBinding {
  id                  String       @id @default(uuid())
  agentTemplateId     String
  capabilityId        String
  bindingName         String
  roleInCapability    String?
  promptProfileId     String?
  toolPolicyId        String?
  memoryScopePolicyId String?
  status              EntityStatus @default(ACTIVE)
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  agentTemplate AgentTemplate    @relation(fields: [agentTemplateId], references: [id])
  capability    Capability       @relation(fields: [capabilityId], references: [id])
  executions    AgentExecution[]
}

model PromptProfile {
  id             String          @id @default(uuid())
  name           String
  description    String?
  ownerScopeType PromptScopeType?
  ownerScopeId   String?
  version        Int             @default(1)
  status         EntityStatus    @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  layers PromptProfileLayer[]
}

model PromptLayer {
  id          String          @id @default(uuid())
  name        String
  layerType   PromptLayerType
  scopeType   PromptScopeType
  scopeId     String?
  content     String
  priority    Int             @default(100)
  isRequired  Boolean         @default(false)
  version     Int             @default(1)
  status      EntityStatus    @default(ACTIVE)
  contentHash String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  profiles PromptProfileLayer[]
}

model PromptProfileLayer {
  id              String   @id @default(uuid())
  promptProfileId String
  promptLayerId   String
  priority        Int      @default(100)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())

  promptProfile PromptProfile @relation(fields: [promptProfileId], references: [id])
  promptLayer   PromptLayer   @relation(fields: [promptLayerId], references: [id])

  @@unique([promptProfileId, promptLayerId])
}

model PromptAssembly {
  id                   String   @id @default(uuid())
  executionId          String?
  agentTemplateId      String
  agentBindingId       String?
  capabilityId         String?
  workflowExecutionId  String?
  promptProfileId      String?
  modelProvider        String?
  modelName            String?
  finalPromptHash      String?
  finalPromptPreview   String?
  estimatedInputTokens Int?
  createdAt            DateTime @default(now())

  layers PromptAssemblyLayer[]
}

model PromptAssemblyLayer {
  id               String  @id @default(uuid())
  promptAssemblyId String
  promptLayerId    String?
  layerType        String?
  layerHash        String?
  priority         Int?
  included         Boolean @default(true)
  inclusionReason  String?
  contentSnapshot  String?

  promptAssembly PromptAssembly @relation(fields: [promptAssemblyId], references: [id])
}

model ToolDefinition {
  id          String       @id @default(uuid())
  name        String
  namespace   String
  description String?
  toolType    String?
  version     Int          @default(1)
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contracts ToolContract[]
  grants    ToolGrant[]
  receipts  ToolExecutionReceipt[]

  @@unique([namespace, name, version])
}

model ToolContract {
  id               String        @id @default(uuid())
  toolId           String
  inputSchema      Json
  outputSchema     Json?
  allowedUsage     String?
  deniedUsage      String?
  riskLevel        ToolRiskLevel @default(LOW)
  requiresApproval Boolean       @default(false)
  auditRequired    Boolean       @default(true)
  timeoutMs        Int           @default(30000)
  version          Int           @default(1)
  status           EntityStatus  @default(ACTIVE)
  createdAt        DateTime      @default(now())

  tool ToolDefinition @relation(fields: [toolId], references: [id])
}

model ToolPolicy {
  id          String       @id @default(uuid())
  name        String
  description String?
  scopeType   String?
  scopeId     String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  grants ToolGrant[]
}

model ToolGrant {
  id                       String             @id @default(uuid())
  toolPolicyId             String
  toolId                   String
  grantScopeType           ToolGrantScopeType
  grantScopeId             String
  allowedActions           Json?
  deniedActions            Json?
  environment              String?
  workflowPhase            String?
  requiresApprovalOverride Boolean?
  status                   EntityStatus       @default(ACTIVE)
  createdAt                DateTime           @default(now())

  toolPolicy ToolPolicy     @relation(fields: [toolPolicyId], references: [id])
  tool       ToolDefinition @relation(fields: [toolId], references: [id])
}

model CapabilityRepository {
  id             String       @id @default(uuid())
  capabilityId   String
  repoName       String
  repoUrl        String
  defaultBranch  String?
  repositoryType String?
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  capability Capability             @relation(fields: [capabilityId], references: [id])
  symbols    CapabilityCodeSymbol[]
}

model CapabilityKnowledgeArtifact {
  id           String       @id @default(uuid())
  capabilityId String
  artifactType String
  title        String
  content      String
  sourceType   String?
  sourceRef    String?
  confidence   Decimal?     @db.Decimal(5, 2)
  version      Int          @default(1)
  status       EntityStatus @default(ACTIVE)
  contentHash  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id])
}

model CapabilityCodeSymbol {
  id             String   @id @default(uuid())
  capabilityId   String
  repositoryId   String
  filePath       String
  language       String?
  symbolName     String?
  symbolType     String?
  parentSymbolId String?
  startLine      Int?
  endLine        Int?
  summary        String?
  symbolHash     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  repository CapabilityRepository      @relation(fields: [repositoryId], references: [id])
  embeddings CapabilityCodeEmbedding[]
}

model CapabilityCodeEmbedding {
  id             String   @id @default(uuid())
  symbolId       String
  embeddingModel String?
  vectorId       String?
  summary        String?
  createdAt      DateTime @default(now())

  symbol CapabilityCodeSymbol @relation(fields: [symbolId], references: [id])
}

model AgentExecution {
  id                  String          @id @default(uuid())
  workflowExecutionId String?
  capabilityId        String?
  agentTemplateId     String
  agentBindingId      String?
  userRequest         String?
  executionStatus     ExecutionStatus @default(CREATED)
  modelProvider       String?
  modelName           String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdBy           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  capability        Capability?             @relation(fields: [capabilityId], references: [id])
  agentTemplate     AgentTemplate           @relation(fields: [agentTemplateId], references: [id])
  agentBinding      AgentCapabilityBinding? @relation(fields: [agentBindingId], references: [id])
  toolReceipts      ToolExecutionReceipt[]
  executionReceipts AgentExecutionReceipt[]
}

model ToolExecutionReceipt {
  id               String    @id @default(uuid())
  agentExecutionId String
  toolId           String
  toolName         String
  inputHash        String?
  outputHash       String?
  approvalId       String?
  status           String
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id])
  tool           ToolDefinition @relation(fields: [toolId], references: [id])
}

model AgentExecutionReceipt {
  id               String   @id @default(uuid())
  agentExecutionId String
  promptAssemblyId String?
  promptHash       String?
  outputHash       String?
  toolReceiptRefs  Json?
  evidenceRefs     Json?
  memoryRefs       Json?
  approvalRefs     Json?
  finalStatus      String?
  createdAt        DateTime @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id])
}

model WorkflowExecutionMemory {
  id                  String                @id @default(uuid())
  workflowExecutionId String
  capabilityId        String?
  agentBindingId      String?
  memoryType          String
  title               String?
  content             String
  evidenceRefs        Json?
  confidence          Decimal?              @db.Decimal(5, 2)
  promotionStatus     MemoryPromotionStatus @default(NOT_REVIEWED)
  createdAt           DateTime              @default(now())
}

model DistilledMemory {
  id                 String       @id @default(uuid())
  scopeType          String
  scopeId            String
  memoryType         String
  title              String
  content            String
  sourceExecutionIds Json?
  evidenceRefs       Json?
  approvedBy         String?
  confidence         Decimal?     @db.Decimal(5, 2)
  version            Int          @default(1)
  status             EntityStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}
