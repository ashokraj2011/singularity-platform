NODE_ENV=development
PORT=3004
DATABASE_URL=postgresql://postgres:singularity@localhost:5432/singularity
JWT_SECRET=dev-secret-change-in-prod
LOG_LEVEL=info

# Upstream services consumed by /compose-and-respond (M4)
TOOL_SERVICE_URL=http://localhost:3002
AGENT_RUNTIME_URL=http://localhost:3003
CONTEXT_FABRIC_URL=http://localhost:8000

# D3 — prompt-text retention. Days before PromptAssemblyLayer.contentSnapshot
# is nulled; layerHash and every other column are kept, and no rows are
# deleted. Clamped to 1..3650; anything unparseable falls back to 30.
PROMPT_SNAPSHOT_TTL_DAYS=30
