// Prompt Composer — owns prompt assembly tables on its OWN Postgres DB.
//
// M30 — physical DB split:
//   • This schema's models live on `singularity_composer` (composer-owned).
//   • Agent-runtime read-models live in prisma/runtime-read.prisma, served
//     by a second client (`runtimeReader`) against `singularity`.
//   • Composer never runs `prisma db push` against agent-runtime's DB.
//
// Per-service Prisma client output path ensures the workspace's shared
// node_modules can't cause "last-generate-wins" client clobber. Composer
// imports the client from "../generated/prisma-client" instead of
// "@prisma/client".
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

// M31 — auto-generated ERD for composer-OWNED tables (singularity_composer DB).
generator erd_md {
  provider = "prisma-erd-generator"
  output   = "../../../../docs/data-model/03-prompt-composer-owned.md"
  theme    = "default"
}

generator erd_png {
  provider = "prisma-erd-generator"
  output   = "../../../../docs/data-model/03-prompt-composer-owned.png"
  theme    = "default"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums used by composer-OWNED models
// (PromptScopeType + PromptLayerType are composer-only after M30)
// ─────────────────────────────────────────────────────────────

enum EntityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PromptScopeType {
  PLATFORM
  TENANT
  BUSINESS_UNIT
  CAPABILITY
  AGENT_TEMPLATE
  AGENT_BINDING
  WORKFLOW
  WORKFLOW_PHASE
  EXECUTION
}

enum PromptLayerType {
  PLATFORM_CONSTITUTION
  TENANT_CONTEXT
  BUSINESS_UNIT_CONTEXT
  AGENT_ROLE
  SKILL_CONTRACT
  TOOL_CONTRACT
  CAPABILITY_CONTEXT
  REPOSITORY_CONTEXT
  WORKFLOW_CONTEXT
  PHASE_CONTEXT
  TASK_CONTEXT
  RUNTIME_EVIDENCE
  MEMORY_CONTEXT
  CODE_CONTEXT
  // M52 — Code Context Budgeter layers. Replace the monolithic
  // CODE_CONTEXT for runs that supply a structured codeContextPackage
  // (built upstream by mcp-server's /mcp/code-context/build endpoint).
  // Priority slots 310–316 in compose.service.ts, just above CODE_CONTEXT.
  CODE_TASK_INTENT
  CODE_TARGET_SYMBOLS
  CODE_EDITABLE_SLICES
  CODE_DEPENDENCY_SLICES
  CODE_TYPE_CONTRACTS
  CODE_TEST_SLICES
  CODE_CONTEXT_RECEIPT
  // M61 Slice F — CapabilityWorldModel layers.
  //
  // Rendered ABOVE the M52 CODE_* layers so ambient capability-wide
  // knowledge (agent rules, test commands, README summary, top-level
  // package map) is the first thing the agent sees about this repo.
  // These layers are scoped to the capability, not the specific task,
  // and stay byte-stable across workflows targeting the same repo —
  // they're cacheable.
  CODE_AGENT_RULES
  CODE_WORLD_MODEL
  OUTPUT_CONTRACT
  APPROVAL_POLICY
  DATA_ACCESS_POLICY
  // M38 — Cross-workflow lessons learned. EngineLessons are surfaced as
  // assembly-time layers when an active rule semantically matches the task.
  GLOBAL_LESSON
}

// ─────────────────────────────────────────────────────────────
// OWNED — Prompt assembly tables
// ─────────────────────────────────────────────────────────────

model PromptProfile {
  id             String           @id @default(uuid())
  name           String
  description    String?
  ownerScopeType PromptScopeType?
  ownerScopeId   String?
  version        Int              @default(1)
  status         EntityStatus     @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // M36.1 — optional Mustache-style task template (`{{varName}}` substitution).
  // When set, callers can resolve a stage prompt through StagePromptBinding and
  // receive a rendered task body without composing the string themselves.
  taskTemplate         String?
  // M36.6 — optional Mustache-style extraContext template, rendered with the
  // same vars as taskTemplate. Used by the workbench loop runner so the
  // per-execution "execution policy" block (which mixes static guidance with
  // dynamic session.sourceUri etc.) is also DB-owned.
  extraContextTemplate String?
  // M36.1 — optional canonical stage key bound to this profile (informational;
  // the real binding lives in StagePromptBinding for the (stage, role) tuple).
  stageKey             String?
  // M36.1 — optional role narrowing for this profile when selected by stage.
  roleGate             String?

  layers   PromptProfileLayer[]
  bindings StagePromptBinding[]
}

model PromptLayer {
  id          String          @id @default(uuid())
  name        String
  layerType   PromptLayerType
  scopeType   PromptScopeType
  scopeId     String?
  content     String
  priority    Int             @default(100)
  isRequired  Boolean         @default(false)
  version     Int             @default(1)
  status      EntityStatus    @default(ACTIVE)
  contentHash String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  profiles PromptProfileLayer[]
}

model PromptProfileLayer {
  id              String   @id @default(uuid())
  promptProfileId String
  promptLayerId   String
  priority        Int      @default(100)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())

  promptProfile PromptProfile @relation(fields: [promptProfileId], references: [id])
  promptLayer   PromptLayer   @relation(fields: [promptLayerId], references: [id])

  @@unique([promptProfileId, promptLayerId])
}

model PromptAssembly {
  id                   String   @id @default(uuid())
  executionId          String?
  agentTemplateId      String
  agentBindingId       String?
  capabilityId         String?
  workflowExecutionId  String?
  promptProfileId      String?
  modelProvider        String?
  modelName            String?
  finalPromptHash      String?
  finalPromptPreview   String?
  estimatedInputTokens Int?
  createdAt            DateTime @default(now())

  // M28 spine-2 — TraceId is the run evidence spine.
  traceId              String?

  // M25 — typed RetrievedChunk[] used to assemble this prompt.
  evidenceRefs         Json?
  // M25.5 — capsule id when this assembly was served from a precompiled
  // task context cache.
  compiledContextId    String?
  // M40 — when present, this assembly ran under an ImmutableContract.
  // For replay, the assembly used the contract's frozen layer snapshots
  // rather than the live PromptLayer rows. Recorded for audit + replay
  // join queries.
  immutableContractId  String?

  layers PromptAssemblyLayer[]

  @@index([traceId])
  @@index([immutableContractId])
}

// M25.5 — Context Compiler: precompiled task contexts (capsules).
model CapabilityCompiledContext {
  id                String   @id @default(uuid())
  capabilityId      String
  agentTemplateId   String
  taskSignature     String   @unique
  intent            String
  compiledContent   String
  compileMode       String   @default("RAW")
  citations         Json
  estimatedTokens   Int      @default(0)
  hitCount          Int      @default(0)
  status            String   @default("READY")
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([capabilityId, agentTemplateId])
  @@index([taskSignature])
  @@index([expiresAt])
}

// M36.5 — EventHorizonAction is the catalog of "quick actions" shown by the
// in-app assistant chip in every Singularity SPA (workgraph-web, agent-and-
// tools/web, UAC, portal). Each row is one button on the floating UI: when
// clicked, the SPA fires `prompt` as the user message + tags the call with
// `intent`. Surface filters scope which actions appear on which app.
//
// Was duplicated across 3 SPA components (workgraph-web/EventHorizonChat.tsx,
// agent-and-tools/web/EventHorizonChat.tsx, UAC). Edit a row here + re-seed
// instead of editing 3 React files.
model EventHorizonAction {
  id           String   @id @default(uuid())
  // App scope — e.g. "workflow-manager" (workgraph-web), "capability-admin"
  // (agent-and-tools/web), "portal", "uac".
  surface      String
  // Semantic intent name — matches the SPA's local ActionIntent union.
  // The composing service uses this to tag audit events ("user clicked X").
  intent       String
  // Button label shown in the SPA (e.g. "Summarize run").
  label        String
  // The literal LLM user message fired when the button is clicked.
  prompt       String
  // UI sort order (ascending). Defaults to 100.
  displayOrder Int      @default(100)
  isActive     Boolean  @default(true)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([surface, intent])
  @@index([surface, isActive, displayOrder])
}

// M40 — ImmutableContract: a cryptographic snapshot of an agent's full
// runtime configuration (every prompt layer + version, every tool + version,
// the resolved model alias→provider, every binding) taken at publish time.
// The bundle is hashed (bundleHash); the hash is recorded on the published
// AgentTemplateVersion and on every PromptAssembly that runs with this
// contract. On replay, the system hydrates the prompt assembly from the
// snapshot's layer contents — bypassing the live PromptLayer rows — so a
// 6-month-old workflow execution sees the December prompts and December
// model resolution, not today's.
//
// This is the regulatory compliance lever: a bank can prove to an auditor
// exactly which prompts + tools + model approved a loan, even years later.
model ImmutableContract {
  id                      String   @id @default(uuid())
  bundleHash              String   @unique
  agentTemplateId         String
  agentTemplateVersion    Int
  capabilityId            String?
  // Bundle contents — each Json field stores a stable canonical snapshot of
  // the referenced rows. Replay reads these directly instead of joining to
  // current PromptLayer/PromptProfile/etc. rows.
  promptProfileVersions   Json     // [{profileId, version, name}]
  promptLayerVersions     Json     // [{layerId, version, layerHash, contentSnapshot, layerType, priority}]
  systemPromptVersions    Json     // [{key, version, content}]
  stageBindingVersions    Json     // [{stageKey, agentRole, profileId, taskTemplate, extraContextTemplate}]
  toolPins                Json     // [{toolNamespace, toolName, version, riskLevel, requires_approval}]
  modelResolution         Json     // {alias, provider, model, version, resolvedAt}
  // Provenance — who minted the contract and from what surface.
  capturedAt              DateTime @default(now())
  capturedBy              String?
  capturedFrom            String?  // e.g. "workbench:finalize", "agent-service:publish"
  consumableId            String?  // when minted from workbench, links to the published consumable

  @@index([agentTemplateId, agentTemplateVersion])
  @@index([capturedAt])
}

// M38 — Cross-workflow lessons learned. When audit-gov's Singularity Engine
// confirms a failure cluster as resolved (no new failures in a 1h window after
// last-seen), an LLM extracts a 2-sentence rule from the failure pattern + the
// successful retry trace. The rule is embedded and stored here scoped to the
// failing (capability, optional tool). At assembly time, compose.service.ts
// pulls the top-K semantically-similar active lessons in as a GLOBAL_LESSON
// prompt layer so future agents on that capability inherit the platform's
// learnings without anyone manually authoring them.
//
// supersededBy lets a higher-confidence newer lesson on the same scope replace
// an older one without losing history (audit trail intact).
model EngineLesson {
  id              String   @id @default(uuid())
  capabilityId    String
  toolName        String?
  ruleText        String
  // pgvector — written via raw SQL UPDATE (Prisma can't bind unsupported types).
  // Read via raw SELECT with cosine `<=>` operator.
  embedding       Unsupported("vector(1536)")?
  sourceIssueId   String?
  sourceTraceIds  Json     @default("[]")
  confidence      Float    @default(0.5)
  isActive        Boolean  @default(true)
  supersededBy    String?
  extractedBy     String?  // e.g. "audit-gov:engine:sweep" or operator user id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([capabilityId, isActive])
  @@index([capabilityId, toolName, isActive])
  @@index([sourceIssueId])
}

// M36.4 — SystemPrompt is a flat key/value store for single-shot LLM prompts
// used by services that aren't running the full stage/agent assembly path
// (e.g. event-horizon, distillation, summarisation, capsule compiler,
// audit-gov diagnose). Each row is one named prompt; callers fetch by `key`.
//
// Unlike PromptProfile / PromptLayer, this is NOT layered or assembled —
// it's a literal string with optional Mustache substitution. Use when the
// prompt is a one-shot system message, not a multi-layer agent contract.
//
// Versioning: monotonic int; the active version is the one with isActive=true.
// Re-seed bumps the version when content changes.
model SystemPrompt {
  id          String   @id @default(uuid())
  // Stable key — e.g. "event-horizon.system", "agent-service.distillation",
  // "tool-service.summarise-text", "audit-gov.diagnose".
  key         String
  version     Int      @default(1)
  // The prompt text (may contain {{var}} Mustache tokens).
  content     String
  // Optional JSON schema the caller can reference for response validation.
  jsonSchema  Json?
  // Optional default model alias hint for this prompt (informational).
  modelHint   String?
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, version])
  @@index([key, isActive])
}

// M36.1 — StagePromptBinding maps a `(stageKey, agentRole)` tuple to a
// PromptProfile + task template. Callers (workgraph-api blueprint runner,
// loop runner, etc.) resolve a stage to its prompt at call time instead of
// hardcoding role-branched strings in TS source.
//
// Lookup precedence (most specific wins):
//   1. Exact (stageKey, agentRole) match
//   2. (stageKey, NULL) — stage-only default
// Inactive bindings are skipped.
model StagePromptBinding {
  id              String   @id @default(uuid())
  // Canonical stage key. Convention: <surface>.<key> e.g.
  // "blueprint.architect", "blueprint.developer", "blueprint.qa",
  // "loop.develop", "loop.qa", "loop.review", etc.
  stageKey        String
  // Optional role narrowing (e.g. "DEVELOPER", "QA", "ARCHITECT").
  // NULL means "any role at this stage".
  agentRole       String?
  // M71 — Optional phase narrowing for per-phase prompts. NULL = stage-level
  // binding, used by the resolver as a fallback when no phase-specific
  // binding exists. Phase values match StagePhasePolicy.phase
  // (PLAN, EXPLORE, ACT, VERIFY, REPAIR, SELF_REVIEW, FINALIZE).
  phase           String?
  promptProfileId String
  isActive        Boolean  @default(true)
  // Notes for the prompt engineer.
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  promptProfile   PromptProfile @relation(fields: [promptProfileId], references: [id])

  // M71 — (stageKey, agentRole, phase) is the natural key. NULLS NOT
  // DISTINCT semantics (PG 15+) so two stage-level bindings with phase=NULL
  // on the same (stageKey, agentRole) collide, which is the desired
  // integrity behaviour. Set manually in the migration since Prisma
  // doesn't yet emit the NULLS NOT DISTINCT clause.
  @@unique([stageKey, agentRole, phase], map: "StagePromptBinding_stageKey_agentRole_phase_key")
  @@index([stageKey])
  @@index([stageKey, agentRole])
}

// ─────────────────────────────────────────────────────────────
// M71 — StagePolicy: governance contract for a stage in the governed
// coding loop. Owns per-phase tool allowlists, required-receipt schemas,
// retry limits, risk policy. context-fabric loads these at runtime via
// POST /api/v1/stage-policies/resolve and enforces them as HARD refuses
// (PHASE_TOOL_FORBIDDEN). Replaces today's prompt-side phase nudges
// (M68/M70.x) with a single chokepoint that any agent runtime hits.
//
// Spec: singularity_governed_coding_loop_spec.md §8 StagePolicy
//       singularity_governed_coding_loop_spec.md §7 Phase Contracts
// ─────────────────────────────────────────────────────────────

model StagePolicy {
  id            String   @id @default(uuid())
  // Matches StagePromptBinding.stageKey ("loop.stage", "loop.stage.intake", etc.)
  stageKey      String
  // Role narrowing — same shape as StagePromptBinding.agentRole.
  // NULL means "any role at this stageKey".
  agentRole     String?
  version       Int      @default(1)
  status        String   @default("ACTIVE") // ACTIVE | DRAFT | RETIRED
  description   String?

  // §8 approval_model — which actions need human approval at which level.
  // Shape: { local_sandbox_edits: "auto", stage_completion: "requires_evidence_approval", ... }
  approvalModel      Json @default("{}")

  // §8 limits — hard caps applied across all phases. Shape:
  // { max_repair_attempts: 3, max_full_file_reads: 5, max_context_tokens: 24000,
  //   max_tool_calls: 80, max_changed_files_without_escalation: 10,
  //   max_diff_lines_without_escalation: 800 }
  limits             Json @default("{}")

  // §8 context_policy — AST-first, full-file justification rules. Shape:
  // { ast_first: true, full_file_read_requires_justification: true,
  //   large_file_threshold_lines: 500, require_context_receipt: true }
  contextPolicy      Json @default("{}")

  // §8 edit_policy — patch-first, anchor-hash, generated-file rules. Shape:
  // { patch_first: true, write_file_existing_file: "forbidden",
  //   require_anchor_hash: true, generated_file_requires_marker: true }
  editPolicy         Json @default("{}")

  // §8 verification_policy — mandatory test/lint/typecheck rules. Shape:
  // { verification_required: true, allow_unavailable_with_reason: true,
  //   require_test_discovery: true, require_fallback_if_no_tests: true }
  verificationPolicy Json @default("{}")

  // §8 risk_policy — escalation thresholds. Shape:
  // { high_risk_requires_architect_review: true,
  //   security_sensitive_requires_security_review: true,
  //   external_side_effects_blocked_by_default: true }
  riskPolicy         Json @default("{}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  phases        StagePhasePolicy[]

  @@unique([stageKey, agentRole, version])
  @@index([stageKey, status])
}

// Per-phase tool allowlist + required receipt schema. One row per
// (StagePolicy, phase). Phases come from §6.1: PLAN, EXPLORE, ACT,
// VERIFY, REPAIR, SELF_REVIEW, FINALIZE. context-fabric refuses any
// tool call not in allowedTools (or explicitly in forbiddenTools) with
// a PHASE_TOOL_FORBIDDEN error code listing the allowlist.

model StagePhasePolicy {
  id                   String   @id @default(uuid())
  stagePolicyId        String
  // Canonical phase name — see §6.1 for the full enum.
  phase                String

  // §7 allowed_tools — exact tool names the agent may call this phase.
  // Empty array = no tools at all (e.g. PRODUCT_OWNER intake stage).
  allowedTools         String[] @default([])
  // §7 forbidden_tools — explicit deny list. Overrides allowedTools on conflict.
  // Useful for "everything except X" patterns.
  forbiddenTools       String[] @default([])

  // §7 required_output schema — JSON-Schema-ish shape that the agent's
  // phase output must satisfy. Used by context-fabric's receipt validator.
  // Shape: { required: ["target_files", "test_strategy"],
  //          properties: { target_files: {type:"array"}, ... } }
  requiredOutputSchema Json     @default("{}")

  // Optional per-phase token budget overrides. Fall back to StagePolicy.limits
  // when null. Set when a phase needs tighter or looser caps than the stage default.
  maxInputTokens       Int?
  maxOutputTokens      Int?
  maxToolCalls         Int?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  stagePolicy          StagePolicy @relation(fields: [stagePolicyId], references: [id], onDelete: Cascade)

  @@unique([stagePolicyId, phase])
  @@index([phase])
}

model PromptAssemblyLayer {
  id               String  @id @default(uuid())
  promptAssemblyId String
  promptLayerId    String?
  layerType        String?
  layerHash        String?
  priority         Int?
  included         Boolean @default(true)
  inclusionReason  String?
  contentSnapshot  String?

  promptAssembly PromptAssembly @relation(fields: [promptAssemblyId], references: [id])
}
