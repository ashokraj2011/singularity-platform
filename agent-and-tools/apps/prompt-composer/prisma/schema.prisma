// Prompt Composer — owns prompt assembly tables.
//
// Models marked OWNED are written here (CRUD).
// Models marked READ are also declared in agent-runtime/prisma/schema.prisma —
// composer reads them directly during assembly. Same Postgres DB; both
// services' `prisma db push` converge on identical shapes. M3 cuts over
// agent-runtime by removing OWNED tables from its schema.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Shared enums (must match agent-runtime declarations exactly)
// ─────────────────────────────────────────────────────────────

enum EntityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AgentRoleType {
  ARCHITECT
  DEVELOPER
  QA
  GOVERNANCE
  BUSINESS_ANALYST
  PRODUCT_OWNER
  DEVOPS
  SECURITY
}

enum PromptScopeType {
  PLATFORM
  TENANT
  BUSINESS_UNIT
  CAPABILITY
  AGENT_TEMPLATE
  AGENT_BINDING
  WORKFLOW
  WORKFLOW_PHASE
  EXECUTION
}

enum PromptLayerType {
  PLATFORM_CONSTITUTION
  TENANT_CONTEXT
  BUSINESS_UNIT_CONTEXT
  AGENT_ROLE
  SKILL_CONTRACT
  TOOL_CONTRACT
  CAPABILITY_CONTEXT
  REPOSITORY_CONTEXT
  WORKFLOW_CONTEXT
  PHASE_CONTEXT
  TASK_CONTEXT
  RUNTIME_EVIDENCE
  MEMORY_CONTEXT
  CODE_CONTEXT
  OUTPUT_CONTRACT
  APPROVAL_POLICY
  DATA_ACCESS_POLICY
}

enum ToolRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ToolGrantScopeType {
  AGENT_TEMPLATE
  AGENT_BINDING
  CAPABILITY
  ROLE
  WORKFLOW_PHASE
  TEAM
  USER
}

enum MemoryPromotionStatus {
  NOT_REVIEWED
  CANDIDATE
  APPROVED
  REJECTED
  PROMOTED
}

// ─────────────────────────────────────────────────────────────
// OWNED — Prompt assembly tables
// ─────────────────────────────────────────────────────────────

model PromptProfile {
  id             String           @id @default(uuid())
  name           String
  description    String?
  ownerScopeType PromptScopeType?
  ownerScopeId   String?
  version        Int              @default(1)
  status         EntityStatus     @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  layers PromptProfileLayer[]
}

model PromptLayer {
  id          String          @id @default(uuid())
  name        String
  layerType   PromptLayerType
  scopeType   PromptScopeType
  scopeId     String?
  content     String
  priority    Int             @default(100)
  isRequired  Boolean         @default(false)
  version     Int             @default(1)
  status      EntityStatus    @default(ACTIVE)
  contentHash String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  profiles PromptProfileLayer[]
}

model PromptProfileLayer {
  id              String   @id @default(uuid())
  promptProfileId String
  promptLayerId   String
  priority        Int      @default(100)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())

  promptProfile PromptProfile @relation(fields: [promptProfileId], references: [id])
  promptLayer   PromptLayer   @relation(fields: [promptLayerId], references: [id])

  @@unique([promptProfileId, promptLayerId])
}

model PromptAssembly {
  id                   String   @id @default(uuid())
  executionId          String?
  agentTemplateId      String
  agentBindingId       String?
  capabilityId         String?
  workflowExecutionId  String?
  promptProfileId      String?
  modelProvider        String?
  modelName            String?
  finalPromptHash      String?
  finalPromptPreview   String?
  estimatedInputTokens Int?
  createdAt            DateTime @default(now())

  // M25 — typed RetrievedChunk[] used to assemble this prompt. Stored as
  // {source_kind, source_id, citation_key, excerpt, confidence, …} per
  // chunk so Run Insights can show citations + the LLM can ground its
  // output via the matching 〔cite: …〕 markers in the prompt itself.
  evidenceRefs         Json?
  // M25.5 — capsule id when this assembly was served from a precompiled
  // task context cache. NULL means we ran fresh retrieval.
  compiledContextId    String?

  layers PromptAssemblyLayer[]
}

// M25.5 — Context Compiler: precompiled task contexts (capsules) so that
// repeated AGENT_TASK shapes skip the three semantic queries + reranking
// and serve a stable paragraph directly. Cache key = SHA256 over
// (capability_id, agent_template_id, normalized intent, contentRevision).
// Any source-artifact change bumps the revision → cache key diverges →
// stale capsules become unreachable on the next lookup.
model CapabilityCompiledContext {
  id                String   @id @default(uuid())
  capabilityId      String
  agentTemplateId   String
  taskSignature     String   @unique
  intent            String
  // The compiled body the agent gets, with 〔cite: …〕 markers preserved.
  // Interpretation depends on compileMode:
  //   RAW — JSON-stringified AssembledLayer[] (M25.5 v1: latency win only)
  //   LLM — natural-language paragraph (M25.5.next: token + latency win)
  compiledContent   String
  compileMode       String   @default("RAW")
  // RetrievedChunk[] that backed the compile, kept for audit + Run Insights.
  citations         Json
  // Token estimate so callers can compare hot-path vs cold-path budgets.
  estimatedTokens   Int      @default(0)
  hitCount          Int      @default(0)
  // status: PENDING (compiling) | READY | FAILED. Hot path needs READY.
  status            String   @default("READY")
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([capabilityId, agentTemplateId])
  @@index([taskSignature])
  // M25.5 C9 — GC sweep predicate hits this. Without it, the periodic
  // delete-where-expired query is a seq scan at scale.
  @@index([expiresAt])
}

model PromptAssemblyLayer {
  id               String  @id @default(uuid())
  promptAssemblyId String
  promptLayerId    String?
  layerType        String?
  layerHash        String?
  priority         Int?
  included         Boolean @default(true)
  inclusionReason  String?
  contentSnapshot  String?

  promptAssembly PromptAssembly @relation(fields: [promptAssemblyId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// READ — Models owned by agent-runtime, queried during assembly
// (declarations must stay in lock-step with agent-runtime/prisma/schema.prisma)
// ─────────────────────────────────────────────────────────────

model AgentTemplate {
  id                  String       @id @default(uuid())
  name                String
  roleType            AgentRoleType
  description         String?
  basePromptProfileId String?
  defaultToolPolicyId String?
  version             Int          @default(1)
  status              EntityStatus @default(DRAFT)
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  // M23 — declared in agent-runtime's schema; mirrored here so composer's
  // `db push` doesn't drop these columns when both services share a DB.
  capabilityId        String?
  baseTemplateId      String?
  lockedReason        String?

  bindings AgentCapabilityBinding[]

  @@index([capabilityId])
  @@index([baseTemplateId])
}

model Capability {
  id                 String       @id @default(uuid())
  name               String
  parentCapabilityId String?
  capabilityType     String?
  businessUnitId     String?
  ownerTeamId        String?
  criticality        String?
  description        String?
  status             EntityStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  parent             Capability?  @relation("CapabilityHierarchy", fields: [parentCapabilityId], references: [id])
  children           Capability[] @relation("CapabilityHierarchy")
  bindings           AgentCapabilityBinding[]
  knowledgeArtifacts CapabilityKnowledgeArtifact[]
  codeSymbols        CapabilityCodeSymbol[]
  repositories       CapabilityRepository[]
}

// M14 — read-only mirrors of agent-runtime's repo + symbol tables so the
// composer can pull code context without round-tripping. Both services
// connect to the same Postgres; there's no migration here — agent-runtime's
// migration creates the tables. Composer just gets a Prisma client view.
model CapabilityRepository {
  id              String     @id @default(uuid())
  capabilityId    String
  repoName        String
  repoUrl         String
  defaultBranch   String     @default("main")
  repositoryType  String     @default("GITHUB")
  status          EntityStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  capability Capability             @relation(fields: [capabilityId], references: [id])
  symbols    CapabilityCodeSymbol[]
}

model CapabilityCodeSymbol {
  id             String   @id @default(uuid())
  capabilityId   String
  repositoryId   String
  filePath       String
  language       String?
  symbolName     String?
  symbolType     String?
  parentSymbolId String?
  startLine      Int?
  endLine        Int?
  summary        String?
  symbolHash     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  repository  CapabilityRepository      @relation(fields: [repositoryId], references: [id])
  capability  Capability                @relation(fields: [capabilityId], references: [id])
  embeddings  CapabilityCodeEmbedding[]
}

// M15 — composer needs visibility on the embedding column to query cosine.
model CapabilityCodeEmbedding {
  id             String   @id @default(uuid())
  symbolId       String
  embeddingModel String?
  vectorId       String?
  summary        String?
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime @default(now())

  symbol CapabilityCodeSymbol @relation(fields: [symbolId], references: [id])
}

model AgentCapabilityBinding {
  id                  String       @id @default(uuid())
  agentTemplateId     String
  capabilityId        String
  bindingName         String
  roleInCapability    String?
  promptProfileId     String?
  toolPolicyId        String?
  memoryScopePolicyId String?
  status              EntityStatus @default(ACTIVE)
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  agentTemplate AgentTemplate @relation(fields: [agentTemplateId], references: [id])
  capability    Capability    @relation(fields: [capabilityId], references: [id])
}

model CapabilityKnowledgeArtifact {
  id           String       @id @default(uuid())
  capabilityId String
  artifactType String
  title        String
  content      String
  sourceType   String?
  sourceRef    String?
  confidence   Decimal?     @db.Decimal(5, 2)
  version      Int          @default(1)
  status       EntityStatus @default(ACTIVE)
  contentHash  String?
  // M15 — pgvector mirror (read-only from composer; written by agent-runtime).
  embedding    Unsupported("vector(1536)")?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id])
}

model DistilledMemory {
  id                 String       @id @default(uuid())
  scopeType          String
  scopeId            String
  memoryType         String
  title              String
  content            String
  sourceExecutionIds Json?
  evidenceRefs       Json?
  approvedBy         String?
  confidence         Decimal?     @db.Decimal(5, 2)
  version            Int          @default(1)
  status             EntityStatus @default(ACTIVE)
  // M15 — pgvector mirror (read-only from composer; written by agent-service).
  embedding          Unsupported("vector(1536)")?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model ToolDefinition {
  id          String       @id @default(uuid())
  name        String
  namespace   String
  description String?
  toolType    String?
  version     Int          @default(1)
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contracts ToolContract[]
  grants    ToolGrant[]

  @@unique([namespace, name, version])
}

model ToolContract {
  id               String        @id @default(uuid())
  toolId           String
  inputSchema      Json
  outputSchema     Json?
  allowedUsage     String?
  deniedUsage      String?
  riskLevel        ToolRiskLevel @default(LOW)
  requiresApproval Boolean       @default(false)
  auditRequired    Boolean       @default(true)
  timeoutMs        Int           @default(30000)
  version          Int           @default(1)
  status           EntityStatus  @default(ACTIVE)
  createdAt        DateTime      @default(now())

  tool ToolDefinition @relation(fields: [toolId], references: [id])
}

model ToolPolicy {
  id          String       @id @default(uuid())
  name        String
  description String?
  scopeType   String?
  scopeId     String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  grants ToolGrant[]
}

model ToolGrant {
  id                       String             @id @default(uuid())
  toolPolicyId             String
  toolId                   String
  grantScopeType           ToolGrantScopeType
  grantScopeId             String
  allowedActions           Json?
  deniedActions            Json?
  environment              String?
  workflowPhase            String?
  requiresApprovalOverride Boolean?
  status                   EntityStatus       @default(ACTIVE)
  createdAt                DateTime           @default(now())

  toolPolicy ToolPolicy     @relation(fields: [toolPolicyId], references: [id])
  tool       ToolDefinition @relation(fields: [toolId], references: [id])
}
