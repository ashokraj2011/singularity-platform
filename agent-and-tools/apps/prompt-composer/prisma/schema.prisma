// Prompt Composer — owns prompt assembly tables on its OWN Postgres DB.
//
// M30 — physical DB split:
//   • This schema's models live on `singularity_composer` (composer-owned).
//   • Agent-runtime read-models live in prisma/runtime-read.prisma, served
//     by a second client (`runtimeReader`) against `singularity`.
//   • Composer never runs `prisma db push` against agent-runtime's DB.
//
// Per-service Prisma client output path ensures the workspace's shared
// node_modules can't cause "last-generate-wins" client clobber. Composer
// imports the client from "../generated/prisma-client" instead of
// "@prisma/client".
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

// M31 — auto-generated ERD for composer-OWNED tables (singularity_composer DB).
generator erd_md {
  provider = "prisma-erd-generator"
  output   = "../../../../docs/data-model/03-prompt-composer-owned.md"
  theme    = "default"
}

generator erd_png {
  provider = "prisma-erd-generator"
  output   = "../../../../docs/data-model/03-prompt-composer-owned.png"
  theme    = "default"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums used by composer-OWNED models
// (PromptScopeType + PromptLayerType are composer-only after M30)
// ─────────────────────────────────────────────────────────────

enum EntityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PromptScopeType {
  PLATFORM
  TENANT
  BUSINESS_UNIT
  CAPABILITY
  AGENT_TEMPLATE
  AGENT_BINDING
  WORKFLOW
  WORKFLOW_PHASE
  EXECUTION
}

enum PromptLayerType {
  PLATFORM_CONSTITUTION
  TENANT_CONTEXT
  BUSINESS_UNIT_CONTEXT
  AGENT_ROLE
  SKILL_CONTRACT
  TOOL_CONTRACT
  CAPABILITY_CONTEXT
  REPOSITORY_CONTEXT
  WORKFLOW_CONTEXT
  PHASE_CONTEXT
  TASK_CONTEXT
  RUNTIME_EVIDENCE
  MEMORY_CONTEXT
  CODE_CONTEXT
  OUTPUT_CONTRACT
  APPROVAL_POLICY
  DATA_ACCESS_POLICY
}

// ─────────────────────────────────────────────────────────────
// OWNED — Prompt assembly tables
// ─────────────────────────────────────────────────────────────

model PromptProfile {
  id             String           @id @default(uuid())
  name           String
  description    String?
  ownerScopeType PromptScopeType?
  ownerScopeId   String?
  version        Int              @default(1)
  status         EntityStatus     @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // M36.1 — optional Mustache-style task template (`{{varName}}` substitution).
  // When set, callers can resolve a stage prompt through StagePromptBinding and
  // receive a rendered task body without composing the string themselves.
  taskTemplate   String?
  // M36.1 — optional canonical stage key bound to this profile (informational;
  // the real binding lives in StagePromptBinding for the (stage, role) tuple).
  stageKey       String?
  // M36.1 — optional role narrowing for this profile when selected by stage.
  roleGate       String?

  layers   PromptProfileLayer[]
  bindings StagePromptBinding[]
}

model PromptLayer {
  id          String          @id @default(uuid())
  name        String
  layerType   PromptLayerType
  scopeType   PromptScopeType
  scopeId     String?
  content     String
  priority    Int             @default(100)
  isRequired  Boolean         @default(false)
  version     Int             @default(1)
  status      EntityStatus    @default(ACTIVE)
  contentHash String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  profiles PromptProfileLayer[]
}

model PromptProfileLayer {
  id              String   @id @default(uuid())
  promptProfileId String
  promptLayerId   String
  priority        Int      @default(100)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())

  promptProfile PromptProfile @relation(fields: [promptProfileId], references: [id])
  promptLayer   PromptLayer   @relation(fields: [promptLayerId], references: [id])

  @@unique([promptProfileId, promptLayerId])
}

model PromptAssembly {
  id                   String   @id @default(uuid())
  executionId          String?
  agentTemplateId      String
  agentBindingId       String?
  capabilityId         String?
  workflowExecutionId  String?
  promptProfileId      String?
  modelProvider        String?
  modelName            String?
  finalPromptHash      String?
  finalPromptPreview   String?
  estimatedInputTokens Int?
  createdAt            DateTime @default(now())

  // M28 spine-2 — TraceId is the run evidence spine.
  traceId              String?

  // M25 — typed RetrievedChunk[] used to assemble this prompt.
  evidenceRefs         Json?
  // M25.5 — capsule id when this assembly was served from a precompiled
  // task context cache.
  compiledContextId    String?

  layers PromptAssemblyLayer[]

  @@index([traceId])
}

// M25.5 — Context Compiler: precompiled task contexts (capsules).
model CapabilityCompiledContext {
  id                String   @id @default(uuid())
  capabilityId      String
  agentTemplateId   String
  taskSignature     String   @unique
  intent            String
  compiledContent   String
  compileMode       String   @default("RAW")
  citations         Json
  estimatedTokens   Int      @default(0)
  hitCount          Int      @default(0)
  status            String   @default("READY")
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([capabilityId, agentTemplateId])
  @@index([taskSignature])
  @@index([expiresAt])
}

// M36.1 — StagePromptBinding maps a `(stageKey, agentRole)` tuple to a
// PromptProfile + task template. Callers (workgraph-api blueprint runner,
// loop runner, etc.) resolve a stage to its prompt at call time instead of
// hardcoding role-branched strings in TS source.
//
// Lookup precedence (most specific wins):
//   1. Exact (stageKey, agentRole) match
//   2. (stageKey, NULL) — stage-only default
// Inactive bindings are skipped.
model StagePromptBinding {
  id              String   @id @default(uuid())
  // Canonical stage key. Convention: <surface>.<key> e.g.
  // "blueprint.architect", "blueprint.developer", "blueprint.qa",
  // "loop.develop", "loop.qa", "loop.review", etc.
  stageKey        String
  // Optional role narrowing (e.g. "DEVELOPER", "QA", "ARCHITECT").
  // NULL means "any role at this stage".
  agentRole       String?
  promptProfileId String
  isActive        Boolean  @default(true)
  // Notes for the prompt engineer.
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  promptProfile   PromptProfile @relation(fields: [promptProfileId], references: [id])

  @@unique([stageKey, agentRole])
  @@index([stageKey])
}

model PromptAssemblyLayer {
  id               String  @id @default(uuid())
  promptAssemblyId String
  promptLayerId    String?
  layerType        String?
  layerHash        String?
  priority         Int?
  included         Boolean @default(true)
  inclusionReason  String?
  contentSnapshot  String?

  promptAssembly PromptAssembly @relation(fields: [promptAssemblyId], references: [id])
}
