# Laptop-side config for bin/laptop.sh — copy to .env.laptop (gitignored) and
# fill in. Loaded automatically by every `bin/laptop.sh gateway|mcp` run, so you
# never re-export these per terminal.

# ── Copilot CLI (the SDLC copilot stages) — BYOK Anthropic ───────────────────
COPILOT_PROVIDER_TYPE=anthropic
COPILOT_PROVIDER_BASE_URL=https://api.anthropic.com
COPILOT_PROVIDER_API_KEY=sk-ant-REPLACE_ME
COPILOT_MODEL=claude-sonnet-4-6
# Pin the binary explicitly if `copilot` isn't on PATH for non-login shells:
# COPILOT_BIN=/usr/local/bin/copilot

# ── Git push from the work-item sandbox ──────────────────────────────────────
MCP_GIT_PUSH_ENABLED=true
MCP_GIT_AUTH_MODE=token
GITHUB_TOKEN=ghp_REPLACE_ME

# ── Gateway provider key (if not using .env.llm-secrets) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Optional overrides ───────────────────────────────────────────────────────
# MCP_BEARER_TOKEN=demo-bearer-token-must-be-min-16-chars   # must match the box
# MCP_SANDBOX_ROOT=$HOME/sg-laptop-workspace
