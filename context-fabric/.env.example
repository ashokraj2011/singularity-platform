# Service URLs used by context-api-service
LLM_GATEWAY_URL=http://llm-gateway-service:8001
CONTEXT_MEMORY_URL=http://context-memory-service:8002
METRICS_LEDGER_URL=http://metrics-ledger-service:8003

# LLM providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Context Fabric
OPENROUTER_SITE_URL=http://localhost:8000

# Generic OpenAI-compatible endpoint support
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

# Ollama from Docker usually needs host.docker.internal on Mac/Windows
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional local SQLite fallback paths. Normal platform runs use Postgres via
# CONTEXT_FABRIC_DATABASE_URL. Keep fallbacks relative/app-local so copied env
# files do not force containers to write under a read-only root-level /data.
LLM_GATEWAY_DB=./data/llm_gateway.db
CONTEXT_MEMORY_DB=./data/context_memory.db
METRICS_LEDGER_DB=./data/metrics_ledger.db
CALL_LOG_DB=./data/call_log.db
EVENTS_STORE_DB=./data/call_log_events.db

# Summarization defaults used by context-memory-service
SUMMARIZER_PROVIDER=mock
SUMMARIZER_MODEL=mock-summarizer
LLM_GATEWAY_INTERNAL_URL=http://llm-gateway-service:8001

# Optional per-node direct LLM route. Disabled unless a workflow node carries
# llmRoute=context_fabric_direct. Context Fabric reads only the named credential
# env var; never put a provider key in workflow JSON or an API request.
CONTEXT_FABRIC_DIRECT_LLM_PROVIDER=mock
CONTEXT_FABRIC_DIRECT_LLM_MODEL=mock-fast
CONTEXT_FABRIC_DIRECT_LLM_BASE_URL=
CONTEXT_FABRIC_DIRECT_LLM_ALLOWED_CREDENTIAL_ENVS=OPENAI_API_KEY,OPENROUTER_API_KEY,ANTHROPIC_API_KEY,COPILOT_PROVIDER_API_KEY,COPILOT_TOKEN
CONTEXT_FABRIC_DIRECT_LLM_ALLOW_CUSTOM_BASE_URLS=false
CONTEXT_FABRIC_DIRECT_LLM_TIMEOUT_SEC=300

# ─── ToolInvocationGrant minting (defence-in-depth) ────────────────────────
# When enabled, the governed loop signs a per-call grant that binds each tool
# dispatch to its (tool, args, stage/phase/policy) decision; mcp-server
# verifies it before running mutating / high-risk tools. OFF by default.
# Pair with mcp-server's MCP_TOOL_GRANT_MODE=grace|enforce and share the SAME
# TOOL_GRANT_SIGNING_SECRET on both sides.
CF_TOOL_GRANT_ENABLED=false
TOOL_GRANT_SIGNING_SECRET=
# Grant lifetime in seconds (clamped to 5..3600). Short enough that a captured
# grant is near-useless, long enough to survive a slow tool dispatch.
CF_TOOL_GRANT_TTL_SEC=120
