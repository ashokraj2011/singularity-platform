# ── secrets ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
/tmp/iam_jwt.txt

# ── node ──────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.npm/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── build outputs ─────────────────────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo
# Vite's tsc-compiled config artefacts (the .ts source is the truth)
**/vite.config.js
**/vite.config.d.ts
**/vite.config.js.map

# ── prisma generated client (re-generated by `prisma generate`) ───────────
**/node_modules/.prisma/

# ── python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# ── databases / persisted state (recreated by docker volumes) ─────────────
*.db
*.db-journal
*.db-shm
*.db-wal
**/data/
pgdata/

# ── docker / minio data dirs ──────────────────────────────────────────────
**/minio_data/

# ── IDE / OS ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*~

# ── logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── claude session detritus ───────────────────────────────────────────────
.claude/projects/
.claude/sessions/
# keep launch.json + plans
!.claude/launch.json
!.claude/plans/
