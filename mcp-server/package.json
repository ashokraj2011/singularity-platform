{
  "name": "@singularity/mcp-server",
  "version": "0.1.0",
  "description": "Reference MCP server for the Singularity platform — runs in the customer VPC, holds local tool secrets, drives the LLM↔tool agent loop through the central LLM gateway.",
  "private": true,
  "bin": {
    "singularity-mcp": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:cli": "ts-node --transpile-only src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test:contracts": "MCP_BEARER_TOKEN=test-bearer-token-12345 LLM_GATEWAY_URL=mock ts-node --transpile-only src/lib/governance-policy.contract.test.ts && MCP_BEARER_TOKEN=test-bearer-token-12345 LLM_GATEWAY_URL=mock ts-node --transpile-only src/lib/http-auth.contract.test.ts",
    "test": "MCP_BEARER_TOKEN=test-bearer-token-12345-min-16-chars LLM_GATEWAY_URL=mock vitest run",
    "test:watch": "MCP_BEARER_TOKEN=test-bearer-token-12345-min-16-chars LLM_GATEWAY_URL=mock vitest",
    "test:coverage": "MCP_BEARER_TOKEN=test-bearer-token-12345-min-16-chars LLM_GATEWAY_URL=mock vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "sql.js": "^1.14.1",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^11.0.3",
    "web-tree-sitter": "^0.25.10",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
