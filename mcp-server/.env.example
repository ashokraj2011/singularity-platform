NODE_ENV=development
PORT=7000
LOG_LEVEL=info

# Bearer token context-fabric uses to authenticate to this MCP server.
# Must match what the operator registered in IAM via
#   POST /api/v1/capabilities/{cap_id}/mcp-servers
# In dev, generate any 16+ char string.
MCP_BEARER_TOKEN=change-me-min-16-chars

# ─── M33: central LLM gateway ──────────────────────────────────────────────
# Every LLM call routes through llm-gateway-service. Provider keys live
# ONLY in the gateway's env, never here. There is NO provider fallback;
# gateway errors propagate. The only allowed fallback is the gateway's
# `mock` provider (or LLM_GATEWAY_URL=mock for in-process unit tests).
LLM_GATEWAY_URL=http://llm-gateway:8001
LLM_GATEWAY_BEARER=
LLM_GATEWAY_TIMEOUT_SEC=240

# Optional: external MCP-side provider config (display-only after M33; the
# gateway is the source of truth). When omitted, /llm/providers introspects
# the gateway live.
MCP_LLM_PROVIDER_CONFIG_PATH=/etc/singularity/llm-providers.json
MCP_LLM_MODEL_CATALOG_PATH=/etc/singularity/mcp-models.json
MCP_ALLOWED_LLM_PROVIDERS=

# Loop guard
MAX_AGENT_STEPS=12
TIMEOUT_SEC=240

# Sandbox + workspace
MCP_SANDBOX_ROOT=/workspace
MCP_AST_DB_PATH=
MCP_WORK_BRANCH_PREFIX=sg

# Context Fabric internal adapter used when the LLM selects a SERVER-target
# tool (governed tool execution path).
CONTEXT_FABRIC_URL=http://localhost:8000
CONTEXT_FABRIC_SERVICE_TOKEN=
