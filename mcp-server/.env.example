NODE_ENV=development
PORT=7000
LOG_LEVEL=info

# Bearer token context-fabric uses to authenticate to this MCP server.
# Must match what the operator registered in IAM via
#   POST /api/v1/capabilities/{cap_id}/mcp-servers
# In dev, generate any 16+ char string.
MCP_BEARER_TOKEN=change-me-min-16-chars

# LLM provider selection. v0 ships only the deterministic mock provider
# (no external calls). Real providers (openai, anthropic, openrouter) come
# in M7.x — keys would live in env vars on THIS server, never in our cloud.
LLM_PROVIDER=mock
LLM_MODEL=mock-fast

# Loop guard
MAX_AGENT_STEPS=12
TIMEOUT_SEC=240
