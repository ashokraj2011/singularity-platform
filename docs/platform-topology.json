{
  "version": 1,
  "defaultCore": {
    "description": "Default Docker topology for normal local operation.",
    "requiredRunning": {
      "platform-web": "single Next.js frontend for every UI surface; Blueprint Workbench cockpit runs in-process at the /workbench route",
      "platform-core": "agent-service (agents + merged tools), agent-runtime, prompt-composer",
      "iam-service": "identity, users, teams, roles, capabilities",
      "workgraph-api": "workflow templates, designer, runs, WorkItems, Workbench APIs, and code generation",
      "context-api": "Context Fabric orchestration/context API",
      "at-postgres": "shared app/IAM/agent/tools/prompt Postgres",
      "wg-postgres": "Workgraph Postgres",
      "wg-minio": "Workgraph artifact object storage"
    },
    "oneShotCompleted": {
      "at-postgres-bootstrap": "idempotent shared Postgres bootstrap",
      "wg-postgres-bootstrap": "idempotent Workgraph non-bypass app-role bootstrap"
    }
  },
  "agentTools": {
    "consolidatedService": "platform-core",
    "splitDebugServices": [
      "agent-service",
      "agent-runtime",
      "prompt-composer"
    ],
    "apiPorts": {
      "agent-service": 3001,
      "agent-runtime": 3003,
      "prompt-composer": 3004
    }
  },
  "legacyFrontends": [
    "edge-gateway",
    "agent-web"
  ],
  "optionalRuntime": {
    "llm-gateway": "optional local LLM gateway; may be remote",
    "mcp-server": "optional/per-tenant MCP runtime; may be remote",
    "mcp-sandbox-runner": "local sandbox runner used with local MCP",
    "formal-verifier": "optional verification sidecar",
    "prompt-compressor": "optional prompt compression sidecar",
    "context-memory": "deprecated/legacy context memory sidecar"
  },
  "profiles": {
    "core": {
      "mustInclude": [
        "platform-web",
        "platform-core",
        "wg-postgres-bootstrap"
      ],
      "mustExclude": [
        "agent-service",
        "agent-runtime",
        "prompt-composer",
        "edge-gateway",
        "agent-web"
      ]
    },
    "full": {
      "mustInclude": [
        "platform-web",
        "platform-core",
        "llm-gateway",
        "mcp-server",
        "wg-postgres-bootstrap"
      ],
      "mustExclude": [
        "agent-service",
        "agent-runtime",
        "prompt-composer",
        "edge-gateway",
        "agent-web"
      ]
    },
    "backend-split": {
      "mustInclude": [
        "platform-web",
        "agent-service",
        "agent-runtime",
        "prompt-composer",
        "wg-postgres-bootstrap"
      ],
      "mustExclude": [
        "platform-core",
        "edge-gateway",
        "agent-web"
      ]
    },
    "frontend-legacy": {
      "mustInclude": [
        "edge-gateway",
        "agent-web"
      ],
      "mustExclude": [
        "platform-web"
      ]
    }
  }
}
