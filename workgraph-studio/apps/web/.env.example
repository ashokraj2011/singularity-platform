# External agent registry. When set, NodeInspector's AGENT_TASK picker calls
# this base URL instead of the internal /api/agents fallback.
# Contract:
#   GET ${VITE_AGENT_REGISTRY_URL}/agents      → [{ id, name, description?, model? }]
#   GET ${VITE_AGENT_REGISTRY_URL}/agents/:id  → { id, name, description?, model?, capabilities?: string[] }
# Auth: same JWT used elsewhere (Authorization: Bearer …).
# VITE_AGENT_REGISTRY_URL=https://agents.example.com/api

# External tool registry. When set, NodeInspector's TOOL_REQUEST picker calls
# this base URL instead of the internal /api/tools fallback.
# Contract:
#   GET ${VITE_TOOL_REGISTRY_URL}/tools        → [{ id, name, description?, riskLevel?, requiresApproval? }]
#   GET ${VITE_TOOL_REGISTRY_URL}/tools/:id    → { id, name, description?, riskLevel?, actions: [{ id, name, inputSchema?, outputSchema? }] }
# VITE_TOOL_REGISTRY_URL=https://tools.example.com/api

# ── Identity (Singularity IAM federation) ────────────────────────────────────
# Which login flow the workgraph web shows by default:
#   local → email + password → POST /api/auth/login (HS256 JWT)
#   iam   → "Sign in with Singularity IAM" tab is the default; user pastes the
#           IAM-issued bearer token and workgraph-studio's middleware (also in
#           IAM mode) verifies it through IAM's introspection endpoint.
# VITE_AUTH_PROVIDER=iam

# Where to send users who click "Sign in with Singularity IAM".
# VITE_IAM_LOGIN_URL=http://localhost:5175/login

# Base URL of the IAM HTTP API (kept for future direct calls from web — e.g.
# the user/team/skill picker in the Node Inspector assignment UI).
# VITE_IAM_BASE_URL=http://localhost:8100/api/v1
