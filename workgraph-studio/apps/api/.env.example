# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://workgraph:workgraph@localhost:5432/workgraph
JWT_SECRET=replace-with-a-random-string-at-least-32-chars-long-please
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── MinIO / S3 (document attachments) ────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=workgraph
MINIO_SECRET_KEY=workgraph_secret
MINIO_BUCKET=workgraph-documents

# ── Identity provider (Singularity IAM federation) ───────────────────────────
# 'iam'   → all auth + authz delegated to Singularity IAM (production).
# 'local' → fall back to the built-in HS256 JWT + bcrypt login (offline dev).
AUTH_PROVIDER=local

# Human approval policy keys. These refer to permissions, not role names.
# Add the permissions to the roles that should approve in the Identity UI.
APPROVAL_WORKFLOW_PERMISSION=workflow:approve
APPROVAL_AGENT_PERMISSION=agent:approve
APPROVAL_TOOL_PERMISSION=tool:approve_execution
APPROVAL_GOVERNANCE_PERMISSION=governance:approve
APPROVAL_CONSUMABLE_PERMISSION=consumable:approve
PLATFORM_ADMIN_PERMISSION=platform:all

# Base URL for the IAM HTTP API (e.g. http://localhost:8100/api/v1).
# Required when AUTH_PROVIDER=iam.
# IAM_BASE_URL=http://localhost:8100/api/v1

# Long-lived bearer used by workgraph-studio when calling IAM as a service
# (e.g. `/teams/:id/members`, `/skills/:key/users`).  Not used for token
# verification, which is performed by introspecting the user's own bearer.
# IAM_SERVICE_TOKEN=

# TTL (seconds) for the in-memory token-verification cache.  Default 60.
# IAM_VERIFY_CACHE_TTL=60

# Fallback team name used when a workflow-template action has no team context. Default "Default".
# DEFAULT_WORKFLOW_TEAM_NAME=Default

# ── Seed identities (prisma db seed) ─────────────────────────────────────────
# Overridable seed users; defaults reproduce the historical local/dev seed. The
# default passwords are REFUSED when NODE_ENV=production — set strong values there.
# SEED_ADMIN_EMAIL=admin@workgraph.local
# SEED_ADMIN_PASSWORD=admin123
# SEED_ADMIN_NAME=Admin User
# SEED_DEMO_EMAIL=demo@workgraph.local
# SEED_DEMO_PASSWORD=demo123
# SEED_DEMO_NAME=Demo User

# ── Optional ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
