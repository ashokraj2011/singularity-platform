  @@index([traceId])
  @@index([cfCallId])
  @@index([promptAssemblyId])
  @@index([mcpInvocationId])
  @@index([contextPackageId])
  @@index([modelCallId])
  @@index([tenantId], map: "ix_agent_runs_tenant")
