// ─── IDENTITY ─────────────────────────────────────────────────────────────────

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  displayName  String
  // Local password hash — only used when AUTH_PROVIDER=local (offline dev).
  // Optional now that IAM is the source of truth.
  passwordHash String?
  // ID of the corresponding user in the external Singularity IAM platform.
  // Lazily upserted on first verified login when AUTH_PROVIDER=iam.
  iamUserId    String?     @unique
  isActive     Boolean     @default(true)
  teamId       String?
  team         Team?       @relation(fields: [teamId], references: [id])
  roles        UserRole[]
  skills       UserSkill[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("users")
}

model Team {
  id           String          @id @default(uuid())
  name         String
  description  String?
  externalIamTeamId String?    @unique
  externalTeamKey String?
  source       String          @default("LOCAL")
  departmentId String?
  department   Department?     @relation(fields: [departmentId], references: [id])
  members      TeamMember[]
  users        User[]
  queueItems   TeamQueueItem[]
  workflows    Workflow[]
  variables    TeamVariable[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([externalTeamKey])
  @@index([source])
  @@map("teams")
}

// Variables that flow into every workflow instance's context as
// `_globals.<key>`.  Three orthogonal axes:
//
//   visibility  — who can READ this variable at runtime.
//                   ORG_GLOBAL  → every workflow / team / capability sees it.
//                   CAPABILITY  → only workflows whose capabilityId matches
//                                 `visibilityScopeId` see it.
//                   WORKFLOW    → only the one workflow whose id matches
//                                 `visibilityScopeId` sees it.
//                 Visibility cascades: a workflow sees its own + its
//                 capability's + every ORG_GLOBAL.
//
//   instanceMode — runtime mutability:
//                   GLOBAL   → fixed value across every run (legacy default).
//                   INSTANCE → per-run value, defaulted from `value`; operators
//                              can override on a single run without touching
//                              the team-level default.
//
//   editableBy   — write-mode RBAC:
//                   USER   → any team member with the right role can edit.
//                   SYSTEM → only ADMIN users (or the system process) can edit
//                            this variable.  Use this for things like
//                            `runCount` or `lastDeployedHash` that downstream
//                            jobs maintain.
model TeamVariable {
  id                String   @id @default(cuid())
  teamId            String
  key               String
  label             String?
  type              String   @default("STRING") // STRING | NUMBER | BOOLEAN | JSON
  // legacy column — kept under the old name for back-compat. Holds
  // `instanceMode` semantics (GLOBAL | INSTANCE).
  scope             String   @default("GLOBAL")
  // New: read-visibility hierarchy.  Default is ORG_GLOBAL so existing rows
  // keep their current "every workflow sees it" behaviour.
  visibility        String   @default("ORG_GLOBAL") // ORG_GLOBAL | CAPABILITY | WORKFLOW
  // For CAPABILITY visibility: capability id.  For WORKFLOW visibility: the
  // owning workflow id.  Null when visibility = ORG_GLOBAL.
  visibilityScopeId String?
  // New: who can write this variable.
  editableBy        String   @default("USER") // USER | SYSTEM
  value             Json
  description       String?
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([teamId, key])
  @@index([teamId])
  @@index([visibility, visibilityScopeId])
  @@map("team_variables")
}

// Local cache of Singularity IAM capabilities — refreshed on demand whenever
// the IAM client looks one up.  Used so the workflow studio can render names
// and types for `capabilityId` references without hitting IAM on every page.
model Capability {
  id          String   @id // == IAM capability_id
  name        String
  type        String?
  status      String?
  // Capability Governance Model — synced from IAM. Governing capabilities are
  // excluded from work-item targeting by the routing guard (activateWorkItem).
  isGoverning Boolean  @default(false)
  syncedAt    DateTime @default(now())

  @@map("capabilities_cache")
}

/// Capability Governance Model — point-in-time snapshot of the resolved
/// governance overlay for a work item / run / stage. Runtime reads the snapshot,
/// never live governance state, so policy changes don't rewrite history.
model GovernanceOverlaySnapshot {
  id                   String   @id @default(uuid())
  workItemId           String?
  workflowInstanceId   String?
  workflowNodeId       String?
  governedCapabilityId String
  overlayHash          String
  resolvedOverlayJson  Json
  resolvedAt           DateTime @default(now())
  createdAt            DateTime @default(now())

  @@unique([workItemId, workflowNodeId, overlayHash])
  @@index([workItemId])
  @@index([workflowInstanceId])
  @@map("governance_overlay_snapshots")
}

/// Capability Governance Model — a waiver for a BLOCKING/REQUIRED governance
/// control. An APPROVED, unexpired waiver's controlKey unblocks that control in
/// the CF enforcement gate (passed as governance_waivers into the stage).
model GovernanceWaiver {
  id                 String    @id @default(uuid())
  workItemId         String?
  workflowInstanceId String?
  workflowNodeId     String?
  controlKey         String
  reason             String
  status             String    @default("REQUESTED") // REQUESTED | APPROVED | REJECTED
  requestedBy        String?
  approvedBy         String?
  expiresAt          DateTime?
  revokedBy          String?
  revokedAt          DateTime?
  revocationReason   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  @@index([workItemId])
  @@index([controlKey])
  @@map("governance_waivers")
}

model Department {
  id        String       @id @default(uuid())
  name      String
  parentId  String?
  parent    Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children  Department[] @relation("DeptTree")
  teams     Team[]
  createdAt DateTime     @default(now())

  @@map("departments")
}

model Role {
  id           String           @id @default(uuid())
  name         String           @unique
  description  String?
  isSystemRole Boolean          @default(false)
  userRoles    UserRole[]
  permissions  RolePermission[]
  createdAt    DateTime         @default(now())

  @@map("roles")
}

model Skill {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  category    String?
  userSkills  UserSkill[]
  agentSkills AgentSkill[]
  createdAt   DateTime     @default(now())

  @@map("skills")
