// ─────────────────────────────────────────────────────────────────────────────
// ADR 0006 — Unified Discovery & Elicitation. One first-class capability that
// consolidates the three legacy "handle the unknowns" mechanisms (workbench
// stage questions, work-item clarifications, LLM open-questions) behind a single
// model + service. A DiscoverySession attaches to a workflow stage, a work item,
// or a run; it can actively reduce unknowns by talking to the governed LLM
// gateway / Copilot (via Context Fabric) and read-only MCP research tools.
// ─────────────────────────────────────────────────────────────────────────────

enum DiscoveryScopeType {
  WORKFLOW_STAGE
  WORK_ITEM
  RUN
  INITIATIVE
}

enum DiscoverySessionStatus {
  OPEN
  RESOLVING
  BLOCKED
  RESOLVED
  ABANDONED
}

enum DiscoveryQuestionKind {
  single_select
  multi_select
  freeform
  clarification
}

enum DiscoveryQuestionSource {
  configured
  llm
  copilot
  human
  agent
}

enum DiscoveryQuestionStatus {
  OPEN
  ANSWERED
  DISMISSED
}

enum DiscoveryAssumptionStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  VALIDATED
  INVALIDATED
}

model DiscoverySession {
  id         String                 @id @default(uuid())
  tenantId   String?                @default("default")
  scopeType  DiscoveryScopeType
  // stageId | workItemId | runId, depending on scopeType.
  scopeId    String
  status     DiscoverySessionStatus @default(OPEN)
  // Optional LLM routing hints: which touch point + capability drove elicitation.
  touchPoint String?                @default("DISCOVERY")
  protocolStage  String?                @default("PROBLEM")
  stageExtracts  Json                   @default("{}")
  sessionCostUsd Float                  @default(0)
  tokensUsed     Int                    @default(0)
  // Running budget accounting for the elicitation loop (turns/tokens/tool calls).
  budget     Json?
  createdById String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  questions   DiscoveryQuestion[]
  assumptions DiscoveryAssumption[]

  @@index([tenantId, scopeType, scopeId])
  @@index([tenantId, status])
  @@map("discovery_sessions")
}

model DiscoveryQuestion {
  id             String                  @id @default(uuid())
  sessionId      String
  tenantId       String?                 @default("default")
  text           String
  kind           DiscoveryQuestionKind   @default(clarification)
  source         DiscoveryQuestionSource @default(human)
  // Unifies the legacy "required" gate semantics: a blocking, OPEN question
  // parks the session (and any workflow node bound to it).
  blocking       Boolean                 @default(false)
  status         DiscoveryQuestionStatus @default(OPEN)
  // Structured answer set: [{label, impact?, recommended?}].
  options        Json?
  answer         String?
  answeredById   String?
  answeredAt     DateTime?
  // Model/tool-proposed answer pending human confirmation, with confidence 0..1.
  proposedAnswer String?
  confidence     Float?
  ordinal        Int                     @default(0)
  // Compatibility bridge (ADR 0006 Slice 2): links a mirrored question back to
  // the legacy row it shadows — sourceType e.g. 'work_item_clarification' /
  // 'workbench_stage_question', sourceId the legacy PK. Null for native ones.
  sourceType     String?
  sourceId       String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  session DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([tenantId])
  @@index([sourceType, sourceId])
  @@map("discovery_questions")
}

model DiscoveryAssumption {
  id           String                    @id @default(uuid())
  sessionId    String
  tenantId     String?                   @default("default")
  text         String
  confidence   Float                     @default(0.5)
  status       DiscoveryAssumptionStatus @default(PROPOSED)
  validatedById String?
  validatedAt  DateTime?
  // Evidence supporting/refuting the assumption (tool receipts, links, etc.).
  evidenceRef  Json?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  session DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([tenantId])
  @@map("discovery_assumptions")
}

// ── Synthesis Studio — Agentic Working Sessions (R1A Foundations) ──────────────
// A SynthesisWorkspace is a persistent working session anchored on the existing
// SpecificationProject (and optionally a WorkItem). Threads are linear (non-forkable)
// conversations; messages use the board's fenced-append technique for a gap-free seq.
// Every table carries tenantId + the tenant_isolation_policy (installed in the
// creating migration, force-enabled by the tenant RLS cutover alongside the spine).

enum SynthesisWorkspaceStatus {
  OPEN
  ARCHIVED
}

enum WorkspaceThreadKind {
  WORKING_SESSION
  ASK_SIDECAR
}

enum WorkspaceThreadStatus {
  ACTIVE
  CLOSED
}

enum WorkspaceMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum WorkspaceAuthorType {
  HUMAN
  AGENT
  SYSTEM
}

enum ContextEntityType {
  SOURCE
  CLAIM
  DECISION
  REQUIREMENT
  SPECIFICATION
  METRIC
  WORKITEM
  OUTCOME
  PERSON
}

enum ContextReferenceMode {
  FOLLOW_LATEST
  PINNED
}

model SynthesisWorkspace {
  id                     String                   @id @default(uuid())
  tenantId               String?                  @default("default")
  specificationProjectId String
  workItemId             String?
  title                  String
  purpose                String?
  status                 SynthesisWorkspaceStatus @default(OPEN)
  openedById             String
  lastActivityAt         DateTime                 @default(now())
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  project     SpecificationProject @relation(fields: [specificationProjectId], references: [id], onDelete: Cascade)
  workItem    WorkItem?            @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  threads     WorkspaceThread[]
  contextRefs ContextReference[]
  manifests   ContextManifest[]

  @@index([tenantId], map: "ix_synthesis_workspaces_tenant")
  @@index([specificationProjectId, status])
  @@index([workItemId])
  @@map("synthesis_workspaces")
}

model WorkspaceThread {
  id           String                @id @default(uuid())
  tenantId     String?               @default("default")
  workspaceId  String
  kind         WorkspaceThreadKind   @default(WORKING_SESSION)
  agentRole    String?
  title        String?
  contextScope Json                  @default("{}")
  // The fenced counter (mirrors BoardBranch.headEventSeq): bumped under SELECT … FOR UPDATE.
  headSeq      BigInt                @default(0)
  status       WorkspaceThreadStatus @default(ACTIVE)
  createdById  String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  workspace SynthesisWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  WorkspaceMessage[]

  @@index([tenantId], map: "ix_workspace_threads_tenant")
  @@index([workspaceId, status])
  @@map("workspace_threads")
}

model WorkspaceMessage {
  id                String               @id @default(uuid())
  tenantId          String?              @default("default")
  workspaceId       String
  threadId          String
  seq               BigInt // fenced, gap-free per thread (@@unique([threadId, seq]) is the safety net)
  role              WorkspaceMessageRole
  authorType        WorkspaceAuthorType
  authorId          String?
  agentRole         String?
  content           Json                 @default("{}")
  contextManifestId String? // the frozen manifest this turn ran against
  proposalId        String? // the StudioProposal this message produced, if any
  correlation       Json                 @default("{}") // cfCallId / traceId / llmCallIds / toolInvocationIds
  tokens            Json                 @default("{}")
  receipts          Json                 @default("[]") // inline (Receipt has no tenantId yet)
  coalesceKey       String? // idempotent retries
  createdAt         DateTime             @default(now())

  thread WorkspaceThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, seq])
  @@index([tenantId], map: "ix_workspace_messages_tenant")
  @@index([workspaceId, createdAt])
  @@map("workspace_messages")
}

model ContextReference {
  id                     String               @id @default(uuid())
  tenantId               String?              @default("default")
  workspaceId            String
  threadId               String?
  specificationProjectId String? // denormalized scope carriers (no FK — kept loose)
  workItemId             String?
  entityType             ContextEntityType
  entityId               String
  versionId              String? // pinned reference target version
  contentHash            String? // pinned reference integrity hash
  span                   Json? // optional page/section/char span
  referenceMode          ContextReferenceMode @default(FOLLOW_LATEST)
  classification         String?
  authzDecision          Json                 @default("{}")
  label                  String?
  addedById              String
  resolvedAt             DateTime?
  createdAt              DateTime             @default(now())

  workspace SynthesisWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "ix_context_references_tenant")
  @@index([workspaceId, entityType])
  @@map("context_references")
}

model ContextManifest {
  id                    String   @id @default(uuid())
  tenantId              String?  @default("default")
  workspaceId           String
  threadId              String
  messageId             String?
  items                 Json     @default("[]") // FROZEN resolved snapshots — immutable once persisted
  tokenEstimate         Int      @default(0)
  costEstimate          Float?
  pinnedCount           Int      @default(0)
  followingCount        Int      @default(0)
  classificationSummary Json     @default("{}")
  manifestHash          String // canonical hash of items — the required immutable per-run hash
  createdAt             DateTime @default(now())

  workspace SynthesisWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "ix_context_manifests_tenant")
  @@index([workspaceId, threadId])
  @@map("context_manifests")
}

// ── Synthesis Studio — Documents (R1A Documents phase) ────────────────────────
// Versioned "Working Artifact" documents with structured, addressable blocks.
// Spec-typed docs (PRD/BRD) BIND to a SpecificationVersion and do NOT own content
// here (enforced in the service) — the spec stays the system-of-record. READOUT/
// DIGEST/NARRATIVE/GENERIC own their content via DocumentVersion + DocumentBlock.

enum SynthesisDocType {
  PRD
  BRD
  READOUT
  DIGEST
  NARRATIVE
  GENERIC
}

enum SynthesisDocumentStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
  SUPERSEDED
  ARCHIVED
}

enum DocumentBlockType {
  NARRATIVE
  CITATION
  CLAIM
  DECISION
  REQUIREMENT
  ACCEPTANCE
  OBJECTIVE
  METRIC
  RISK
  EXPERIMENT
  DIAGRAM
  WORKITEM
  AGENT_INFERENCE
}

enum DocumentBlockMode {
  LIVE
  PINNED
}

model SynthesisDocument {
  id                     String                  @id @default(uuid())
  tenantId               String?                 @default("default")
  specificationProjectId String
  workItemId             String? // denormalized scope carrier (no FK)
  workspaceId            String? // the workspace it was authored in
  docType                SynthesisDocType        @default(GENERIC)
  title                  String
  status                 SynthesisDocumentStatus @default(DRAFT)
  currentVersionId       String?
  specificationVersionId String? // set → spec-bound (content lives in the SpecificationVersion)
  contentHash            String?
  supersedesId           String?
  createdById            String
  approvedById           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  project  SpecificationProject @relation(fields: [specificationProjectId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([tenantId], map: "ix_synthesis_documents_tenant")
  @@index([specificationProjectId, status])
  @@index([workspaceId])
  @@map("synthesis_documents")
}

model DocumentVersion {
  id               String                  @id @default(uuid())
  tenantId         String?                 @default("default")
  documentId       String
  version          Int
  revision         Int                     @default(1)
  status           SynthesisDocumentStatus @default(DRAFT)
  renderedMarkdown String?
  contentHash      String?
  package          Json?
  createdById      String?
  approvedById     String?
  supersedesId     String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  document SynthesisDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  blocks   DocumentBlock[]

  @@unique([documentId, version])
  @@index([tenantId], map: "ix_document_versions_tenant")
  @@map("document_versions")
}

model DocumentBlock {
  id                String              @id @default(uuid())
  tenantId          String?             @default("default")
  documentVersionId String
  ordinal           Int
  blockType         DocumentBlockType
  mode              DocumentBlockMode   @default(LIVE)
  content           Json                @default("{}")
  sourceRef         Json? // { contextReferenceId?, entityType, entityId, versionId?, contentHash? }
  pinnedSnapshot    Json? // frozen content captured when mode flips to PINNED
  authorType        WorkspaceAuthorType @default(HUMAN)
  authorId          String?
  agentRole         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "ix_document_blocks_tenant")
  @@index([documentVersionId, ordinal])
  @@map("document_blocks")
}
