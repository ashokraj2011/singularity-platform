model Agent {
  id                 String       @id @default(uuid())
  name               String
  description        String?
  provider           String       @default("ANTHROPIC")
  model              String
  systemPrompt       String?
  isActive           Boolean      @default(true)
  // M10/M11.c — immutable snapshot of an agent-and-tools template captured
  // at AgentRun start. Rows are no longer authored locally.
  externalTemplateId String?      @unique
  externalSyncedAt   DateTime?    // = fetchedAt
  sourceHash         String?      // sha256(canonical JSON) of upstream payload at snapshot time
  sourceVersion      String?      // template's own .version (if present)
  fetchedBy          String?      // workgraph user id (null = system snapshot)
  skills             AgentSkill[]
  runs               AgentRun[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("agents")
}

model AgentSkill {
  agentId String
  skillId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
