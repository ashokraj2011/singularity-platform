  routingState            WorkItemRoutingState @default(UNROUTED)
  title                   String
  description             String?
  parentCapabilityId      String?
  sourceWorkflowInstanceId String?
  sourceWorkflowNodeId    String?
  status                  WorkItemStatus   @default(QUEUED)
  input                   Json             @default("{}")
  details                 Json             @default("{}")
  budget                  Json             @default("{}")
  urgency                 WorkItemUrgency   @default(NORMAL)
