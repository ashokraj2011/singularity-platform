// ─── IDENTITY ─────────────────────────────────────────────────────────────────

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  displayName  String
  // Local password hash — only used when AUTH_PROVIDER=local (offline dev).
  // Optional now that IAM is the source of truth.
  passwordHash String?
  // ID of the corresponding user in the external Singularity IAM platform.
  // Lazily upserted on first verified login when AUTH_PROVIDER=iam.
  iamUserId    String?     @unique
  isActive     Boolean     @default(true)
  teamId       String?
  team         Team?       @relation(fields: [teamId], references: [id])
  roles        UserRole[]
  skills       UserSkill[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("users")
}

model Team {
  id           String          @id @default(uuid())
  name         String
  description  String?
  externalIamTeamId String?    @unique
  externalTeamKey String?
  source       String          @default("LOCAL")
  departmentId String?
  department   Department?     @relation(fields: [departmentId], references: [id])
  members      TeamMember[]
  users        User[]
  queueItems   TeamQueueItem[]
  workflows    Workflow[]
  variables    TeamVariable[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([externalTeamKey])
  @@index([source])
  @@map("teams")
}

// Variables that flow into every workflow instance's context as
// `_globals.<key>`.  Three orthogonal axes:
//
//   visibility  — who can READ this variable at runtime.
//                   ORG_GLOBAL  → every workflow / team / capability sees it.
//                   CAPABILITY  → only workflows whose capabilityId matches
//                                 `visibilityScopeId` see it.
//                   WORKFLOW    → only the one workflow whose id matches
//                                 `visibilityScopeId` sees it.
//                 Visibility cascades: a workflow sees its own + its
//                 capability's + every ORG_GLOBAL.
//
//   instanceMode — runtime mutability:
//                   GLOBAL   → fixed value across every run (legacy default).
//                   INSTANCE → per-run value, defaulted from `value`; operators
//                              can override on a single run without touching
//                              the team-level default.
//
//   editableBy   — write-mode RBAC:
//                   USER   → any team member with the right role can edit.
//                   SYSTEM → only ADMIN users (or the system process) can edit
//                            this variable.  Use this for things like
//                            `runCount` or `lastDeployedHash` that downstream
//                            jobs maintain.
model TeamVariable {
  id                String   @id @default(cuid())
  teamId            String
  key               String
  label             String?
  type              String   @default("STRING") // STRING | NUMBER | BOOLEAN | JSON
  // legacy column — kept under the old name for back-compat. Holds
  // `instanceMode` semantics (GLOBAL | INSTANCE).
  scope             String   @default("GLOBAL")
  // New: read-visibility hierarchy.  Default is ORG_GLOBAL so existing rows
  // keep their current "every workflow sees it" behaviour.
  visibility        String   @default("ORG_GLOBAL") // ORG_GLOBAL | CAPABILITY | WORKFLOW
  // For CAPABILITY visibility: capability id.  For WORKFLOW visibility: the
  // owning workflow id.  Null when visibility = ORG_GLOBAL.
  visibilityScopeId String?
  // New: who can write this variable.
  editableBy        String   @default("USER") // USER | SYSTEM
  value             Json
  description       String?
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([teamId, key])
  @@index([teamId])
  @@index([visibility, visibilityScopeId])
  @@map("team_variables")
}

// Local cache of Singularity IAM capabilities — refreshed on demand whenever
// the IAM client looks one up.  Used so the workflow studio can render names
// and types for `capabilityId` references without hitting IAM on every page.
model Capability {
  id          String   @id // == IAM capability_id
  name        String
  type        String?
  status      String?
  // Capability Governance Model — synced from IAM. Governing capabilities are
  // excluded from work-item targeting by the routing guard (activateWorkItem).
  isGoverning Boolean  @default(false)
  syncedAt    DateTime @default(now())

  @@map("capabilities_cache")
}

/// Capability Governance Model — point-in-time snapshot of the resolved
/// governance overlay for a work item / run / stage. Runtime reads the snapshot,
/// never live governance state, so policy changes don't rewrite history.
model GovernanceOverlaySnapshot {
  id                   String   @id @default(uuid())
  workItemId           String?
  workflowInstanceId   String?
  workflowNodeId       String?
  governedCapabilityId String
  overlayHash          String
  resolvedOverlayJson  Json
  resolvedAt           DateTime @default(now())
  createdAt            DateTime @default(now())

  @@unique([workItemId, workflowNodeId, overlayHash])
  @@index([workItemId])
  @@index([workflowInstanceId])
  @@map("governance_overlay_snapshots")
}

/// Capability Governance Model — a waiver for a BLOCKING/REQUIRED governance
/// control. An APPROVED, unexpired waiver's controlKey unblocks that control in
/// the CF enforcement gate (passed as governance_waivers into the stage).
model GovernanceWaiver {
  id                 String    @id @default(uuid())
  workItemId         String?
  workflowInstanceId String?
  workflowNodeId     String?
  controlKey         String
  reason             String
  status             String    @default("REQUESTED") // REQUESTED | APPROVED | REJECTED
  requestedBy        String?
  approvedBy         String?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  @@index([workItemId])
  @@index([controlKey])
  @@map("governance_waivers")
}

model Department {
  id        String       @id @default(uuid())
  name      String
  parentId  String?
  parent    Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children  Department[] @relation("DeptTree")
  teams     Team[]
  createdAt DateTime     @default(now())

  @@map("departments")
}

model Role {
  id           String           @id @default(uuid())
  name         String           @unique
  description  String?
  isSystemRole Boolean          @default(false)
  userRoles    UserRole[]
  permissions  RolePermission[]
  createdAt    DateTime         @default(now())

  @@map("roles")
}

model Skill {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  category    String?
  userSkills  UserSkill[]
  agentSkills AgentSkill[]
  createdAt   DateTime     @default(now())

  @@map("skills")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  resource    String
  action      String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())
  // Finding #8 — provenance for IAM↔local reconciliation. "IAM" bindings are
  // mirrored from is_super_admin and are revoked when IAM demotes the user; any
  // other value ("LOCAL", the default for every pre-existing and hand-granted row)
  // is owned locally and is never auto-removed.
  source    String   @default("LOCAL")

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserSkill {
  userId           String
  skillId          String
  proficiencyLevel Int?
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill            Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@map("team_members")
}

model Delegation {
  id          String   @id @default(uuid())
  delegatorId String
  delegateId  String
  scope       String?
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())

  @@map("delegations")
}

model ApprovalAuthority {
  id           String    @id @default(uuid())
  userId       String
  resourceType String
  maxValue     Decimal?
  grantedAt    DateTime  @default(now())
  expiresAt    DateTime?

  @@map("approval_authorities")
}

// ─── INITIATIVES ──────────────────────────────────────────────────────────────

model Initiative {
  id          String               @id @default(uuid())
  title       String
  description String?
  status      String               @default("DRAFT")
  createdById String
  owners      InitiativeOwner[]
  documents   InitiativeDocument[]
  workflows   WorkflowInstance[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("initiatives")
}

model InitiativeOwner {
  initiativeId String
  userId       String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@id([initiativeId, userId])
  @@map("initiative_owners")
}

model InitiativeDocument {
  id           String     @id @default(uuid())
  initiativeId String
  documentId   String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@map("initiative_documents")
}

// ─── WORKFLOW ─────────────────────────────────────────────────────────────────

// ─── Workflow (the editable design — no longer a "template") ─────────────────
//
// A Workflow IS the canonical design.  Its graph lives in the dedicated
// `workflow_design_*` tables; runs are separate WorkflowInstance rows cloned
// from those tables when a run starts.  The `workflow_templates` table name
// is preserved for back-compat — only the model name and code surface change.
model Workflow {
  id             String                @id @default(uuid())
  name           String
  description    String?
  status         String                @default("DRAFT")
  currentVersion Int                   @default(1)
  createdById    String?
  teamId         String
  team           Team                  @relation(fields: [teamId], references: [id])
  // ID of the owning capability in Singularity IAM.  When set, this is the
  // authorization boundary — the permission helper calls iamClient.authzCheck
  // against this capability.  When null, falls back to the legacy team rule.
  capabilityId   String?
  archivedAt     DateTime?
  metadata       Json?
  workflowTypeKey String               @default("GENERAL")
  typeVersion    Int                   @default(1)
  typeSnapshot   Json?
  // M85.s1 — workflow profile. Distinguishes templates that the
  // operator designs as standalone workbench loops from the main
  // workflows that orchestrate them. Possible values:
  //   • 'main'           — top-level workflow (default)
  //   • 'workbench'      — a workbench loop template; nodes are stages
  //   • 'workbench-host' — legacy main workflow that contains an inline
  //                        WORKBENCH_TASK node (pre-M85; flagged so the
  //                        cutover can find them)
  // The blueprint-workbench UI filters to profile='workbench' only;
  // the main workflow designer hides workbench-only node types from
  // 'main' templates. String rather than enum so adding new profiles
  // (e.g. 'codepath', 'review') in future doesn't require a migration.
  profile        String                @default("main")
  eligibleWorkItemTypes Json           @default("[]")
  isDefaultForType Boolean             @default(false)
  defaultRoutingMode WorkItemRoutingMode @default(MANUAL)
  // Workflow-scoped variables: [{key, label, type, defaultValue, description, scope}]
  // scope: 'INPUT' (provided when starting a run) | 'CONSTANT' (workflow-baked default)
  variables      Json                  @default("[]")
  // Template-level token/cost budget policy cloned into each WorkflowInstance.
  budgetPolicy   Json?
  // Editable design graph — runs clone these into WorkflowInstance.nodes / edges / phases.
  designPhases   WorkflowDesignPhase[]
  designNodes    WorkflowDesignNode[]
  designEdges    WorkflowDesignEdge[]
  versions       WorkflowVersion[]
  triggers       WorkflowTrigger[]
  routingPolicies WorkItemRoutingPolicy[]
  permissions    WorkflowPermission[]
  instances      WorkflowInstance[]
  runSnapshots   RunSnapshot[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([teamId])
  @@index([capabilityId])
  @@index([capabilityId, workflowTypeKey, status])
  @@index([workflowTypeKey, isDefaultForType])
  @@index([status])
  @@map("workflow_templates")
}

// ─── Browser-runtime snapshot ────────────────────────────────────────────────
//
// Single row per browser-driven run.  The browser writes the full RunState as
// JSON; the server is just durable storage with optimistic-concurrency on
// `version`.  Run state machine + edge eval lives entirely client-side.
model RunSnapshot {
  id          String   @id @default(uuid())
  runId       String   @unique // browser-generated UUID
  workflowId  String
  name        String
  status      String // RunStatus enum mirror (string for forward-compat)
  payload     Json // entire RunState blob
  version     Int      @default(1) // monotonic; rejects POST with stale version
  createdById String?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([createdById])
  @@index([tenantId])
  @@index([status])
  @@map("run_snapshots")
}

enum WorkflowPermissionAction {
  VIEW
  EDIT
  START
  ADMIN
}

model WorkflowPermission {
  id         String                   @id @default(uuid())
  templateId String
  roleId     String
  action     WorkflowPermissionAction
  template   Workflow                 @relation(fields: [templateId], references: [id], onDelete: Cascade)
  grantedAt  DateTime                 @default(now())

  @@unique([templateId, roleId, action])
  @@map("workflow_permissions")
}

enum TriggerType {
  WEBHOOK
  SCHEDULE
  EVENT
}

model WorkflowTrigger {
  id          String      @id @default(uuid())
  templateId  String
  template    Workflow    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type        TriggerType
  isActive    Boolean     @default(true)
  // For WEBHOOK: { secret: string }
  // For SCHEDULE: { cron: string, timezone?: string }
  // For EVENT: { eventType: string, filter?: object }
  config      Json        @default("{}")
  lastFiredAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type, isActive])
  @@map("workflow_triggers")
}

model WorkflowVersion {
  id            String   @id @default(uuid())
  templateId    String
  version       Int
  graphSnapshot Json
  // SHA-256 of the canonical graph representation — used to dedupe snapshots
  // when starting a run.  If the design hasn't changed since the last
  // snapshot, the run reuses that version instead of creating a new one.
  contentHash   String?
  // Optional human/auto trigger context — "auto" (snapshot on run) or "manual" (Publish).
  source        String?
  template      Workflow @relation(fields: [templateId], references: [id])
  createdAt     DateTime @default(now())

  @@unique([templateId, version])
  @@index([templateId, contentHash])
  @@map("workflow_template_versions")
}

// ─── Workflow design tables — the editable graph owned by a Workflow ─────────

model WorkflowDesignPhase {
  id           String               @id @default(uuid())
  workflowId   String
  name         String
  displayOrder Int                  @default(0)
  color        String?
  workflow     Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodes        WorkflowDesignNode[]
  createdAt    DateTime             @default(now())

  @@index([workflowId])
  @@map("workflow_design_phases")
}

model WorkflowDesignNode {
  id                 String               @id @default(uuid())
  workflowId         String
  phaseId            String?
  nodeType           NodeType
  nodeTypeKey        String?
  nodeTypeVersion    Int?
  nodeTypeSnapshot   Json?
  label              String
  config             Json                 @default("{}")
  compensationConfig Json?
  executionLocation  ExecutionLocation    @default(SERVER)
  positionX          Float                @default(0)
  positionY          Float                @default(0)
  workflow           Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  phase              WorkflowDesignPhase? @relation(fields: [phaseId], references: [id])
  outgoing           WorkflowDesignEdge[] @relation("DesignSourceNode")
  incoming           WorkflowDesignEdge[] @relation("DesignTargetNode")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([workflowId])
  @@map("workflow_design_nodes")
}

model WorkflowDesignEdge {
  id           String             @id @default(uuid())
  workflowId   String
  sourceNodeId String
  targetNodeId String
  edgeType     EdgeType           @default(SEQUENTIAL)
  condition    Json?
  label        String?
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  source       WorkflowDesignNode @relation("DesignSourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  target       WorkflowDesignNode @relation("DesignTargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())

  @@index([workflowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("workflow_design_edges")
}

// A WorkflowInstance is now exclusively a run — a transactional clone of a
// Workflow's design graph at start time.  The previous `isDesign=true` row
// pattern is gone; the editable design lives in `workflow_design_*` tables
// owned by the Workflow.
model WorkflowInstance {
  id                String             @id @default(uuid())
  templateId        String?
  // Snapshot version this run was cloned from.
  templateVersion   Int?
  template          Workflow?          @relation(fields: [templateId], references: [id])
  initiativeId      String?
  tenantId          String?
  name              String
  status            InstanceStatus     @default(DRAFT)
  context           Json               @default("{}")
  initiative        Initiative?        @relation(fields: [initiativeId], references: [id])
  parentInstanceId  String?
  parentNodeId      String?
  parent            WorkflowInstance?  @relation("Subworkflows", fields: [parentInstanceId], references: [id])
  // M85.s1 — inherited from the template's profile at clone time. Cached
  // here so runtime / UI queries don't have to join the template every
  // time. blueprint-workbench filters on this directly.
  profile           String             @default("main")
  children          WorkflowInstance[] @relation("Subworkflows")
  phases            WorkflowPhase[]
  nodes             WorkflowNode[]
  edges             WorkflowEdge[]
  mutations         WorkflowMutation[]
  events            WorkflowEvent[]
  tasks             Task[]
  consumables       Consumable[]
  sourceWorkItems   WorkItem[]         @relation("WorkItemSourceInstance")
  childWorkItemTargets WorkItemTarget[] @relation("WorkItemChildInstance")
  agentRuns         AgentRun[]
  toolRuns          ToolRun[]
  pendingExecutions PendingExecution[]
  documents         Document[]
  budget            WorkflowRunBudget?
  startedAt         DateTime?
  completedAt       DateTime?
  archivedAt        DateTime?
  createdById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([templateId])
  @@index([tenantId])
  @@map("workflow_instances")
}

model WorkflowRunBudget {
  id                    String                         @id @default(uuid())
  instanceId            String                         @unique
  templateId            String?
  policy                Json                           @default("{}")
  maxInputTokens        Int?
  maxOutputTokens       Int?
  maxTotalTokens        Int?
  maxEstimatedCost      Float?
  warnAtPercent         Int                            @default(80)
  enforcementMode       WorkflowBudgetEnforcementMode  @default(PAUSE_FOR_APPROVAL)
  consumedInputTokens   Int                            @default(0)
  consumedOutputTokens  Int                            @default(0)
  consumedTotalTokens   Int                            @default(0)
  consumedEstimatedCost Float                          @default(0)
  pricingStatus         String                         @default("PRICED")
  status                WorkflowRunBudgetStatus        @default(ACTIVE)
  warningEmittedAt      DateTime?
  exceededAt            DateTime?
  pausedAt              DateTime?
  instance              WorkflowInstance               @relation(fields: [instanceId], references: [id], onDelete: Cascade)
