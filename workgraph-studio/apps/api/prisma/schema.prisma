  @@map("execution_runners")
}

model ToolRun {
  id             String            @id @default(uuid())
  toolId         String
  actionId       String?
  instanceId     String?
  tenantId       String?  // RLS standalone-row tenant (see Task.tenantId)
  runnerId       String?
  status         ToolRunStatus     @default(REQUESTED)
  inputPayload   Json              @default("{}")
  outputPayload  Json?
  requestedById  String?
  idempotencyKey String?
  tool           Tool              @relation(fields: [toolId], references: [id])
  instance       WorkflowInstance? @relation(fields: [instanceId], references: [id])
  approvals      ToolRunApproval[]
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([toolId, idempotencyKey])
  @@map("tool_runs")
}

model ToolRunApproval {
  id                String    @id @default(uuid())
  runId             String
  approvalRequestId String?
  approvedById      String?
  decision          String?
  run               ToolRun   @relation(fields: [runId], references: [id])
  decidedAt         DateTime?

  @@map("tool_run_approvals")
}

// ─── POLICIES ─────────────────────────────────────────────────────────────────

model Policy {
  id           String            @id @default(uuid())
  name         String
  description  String?
  resourceType String
  isActive     Boolean           @default(true)
