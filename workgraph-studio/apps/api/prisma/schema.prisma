  updatedAt               DateTime          @updatedAt

  @@index([workItemId])
  @@index([targetCapabilityId, status])
  @@index([childWorkflowTemplateId])
  @@index([childWorkflowInstanceId])
  @@index([claimedById])
  @@map("work_item_targets")
}

model WorkItemEvent {
  id         String          @id @default(uuid())
  workItemId String
  targetId   String?
  eventType  WorkItemEventType
  actorId    String?
  payload    Json?
  workItem   WorkItem        @relation(fields: [workItemId], references: [id], onDelete: Cascade)
