// ─── TASKS ────────────────────────────────────────────────────────────────────

model Task {
  id             String              @id @default(uuid())
  instanceId     String?
  // RLS: direct tenant column so standalone (null-instanceId) rows are representable
  // under the revised policy `tenantId = current_tenant OR instance-visible`.
  tenantId       String?
  nodeId         String?
  title          String
  description    String?
  status         TaskStatus          @default(OPEN)
  assignmentMode AssignmentMode      @default(DIRECT_USER)
  priority       Int                 @default(50)
  dueAt          DateTime?
  formSchema     Json?
  formData       Json?
  instance       WorkflowInstance?   @relation(fields: [instanceId], references: [id])
  assignments    TaskAssignment[]
  queueItems     TeamQueueItem[]
  comments       TaskComment[]
  statusHistory  TaskStatusHistory[]
  attachments    Document[]
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("tasks")
}

model TaskAssignment {
  id           String    @id @default(uuid())
  taskId       String
  assignedToId String?
  teamId       String?
  roleId       String?
  skillId      String?
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedAt   DateTime  @default(now())
  claimedAt    DateTime?
  completedAt  DateTime?

  @@map("task_assignments")
}

// Queue of tasks awaiting claim by an eligible user.  Eligibility is
// determined by the populated columns: a row may be tagged with `teamId`
// (TEAM_QUEUE), `roleKey` + `capabilityId` (ROLE_BASED), or `skillKey`
// (SKILL_BASED).  At most one of these is set per row; the runtime enqueues
// one row per assignment-mode at task activation time.
model TeamQueueItem {
  id             String    @id @default(uuid())
  taskId         String
  // Optional team membership filter (TEAM_QUEUE mode)
  teamId         String?
  // Optional role filter — combined with capabilityId via IAM authzCheck
  roleKey        String?
  // Optional skill filter — eligibility resolved against IAM /skills/:key/users
  skillKey       String?
  // Capability that scopes role-based eligibility (always set for ROLE_BASED)
  capabilityId   String?
  // Echoes which AssignmentMode produced this row, for auditing.
  assignmentMode String?
  claimedById    String?
  team           Team?     @relation(fields: [teamId], references: [id])
  task           Task      @relation(fields: [taskId], references: [id])
  enqueuedAt     DateTime  @default(now())
  claimedAt      DateTime?

  @@index([taskId])
  @@index([teamId])
  @@index([roleKey, capabilityId])
  @@index([skillKey])
  @@index([claimedById])
  @@map("team_queue_items")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("task_comments")
}

model TaskStatusHistory {
  id             String      @id @default(uuid())
  taskId         String
  previousStatus TaskStatus?
  newStatus      TaskStatus
  changedById    String?
  reason         String?
  task           Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedAt      DateTime    @default(now())

  @@map("task_status_history")
}

// ─── APPROVALS ────────────────────────────────────────────────────────────────

model ApprovalRequest {
  id             String             @id @default(uuid())
  instanceId     String?
  tenantId       String?  // RLS standalone-row tenant (see Task.tenantId)
  nodeId         String?
  subjectType    String
  subjectId      String
  requestedById  String
  // ── Assignment routing (mirrors Task) ─────────────────────────────────────
  // DIRECT_USER → assignedToId
  // TEAM_QUEUE  → teamId
  // ROLE_BASED  → roleKey + capabilityId
  // SKILL_BASED → skillKey
  assignedToId   String?
  assignmentMode String?
  teamId         String?
  roleKey        String?
  skillKey       String?
  capabilityId   String?
  status         ApprovalStatus     @default(PENDING)
  dueAt          DateTime?
  formData       Json?
  decisions      ApprovalDecision[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([assignedToId])
  @@index([teamId])
  @@index([roleKey, capabilityId])
  @@index([skillKey])
  @@map("approval_requests")
}

model ApprovalDecision {
  id          String          @id @default(uuid())
  requestId   String
  decidedById String
  decision    ApprovalStatus
  conditions  String?
  notes       String?
  request     ApprovalRequest @relation(fields: [requestId], references: [id])
  decidedAt   DateTime        @default(now())

  @@map("approval_decisions")
}

// ─── CONSUMABLES ──────────────────────────────────────────────────────────────

model ConsumableType {
  id               String       @id @default(uuid())
  name             String       @unique
  description      String?
  schemaDef        Json         @default("{}")
  ownerRoleId      String?
  requiresApproval Boolean      @default(true)
  allowVersioning  Boolean      @default(true)
  consumables      Consumable[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("consumable_types")
}

model Consumable {
  id             String              @id @default(uuid())
  typeId         String
  instanceId     String?
  tenantId       String?  // RLS standalone-row tenant (see Task.tenantId)
  nodeId         String?
  name           String
  status         ConsumableStatus    @default(DRAFT)
  currentVersion Int                 @default(1)
  formData       Json?
  // ── Assignment routing (the consumable's owner) ──────────────────────────
  assignedToId   String?
  assignmentMode String?
  teamId         String?
  roleKey        String?
  skillKey       String?
  capabilityId   String?
  type           ConsumableType      @relation(fields: [typeId], references: [id])
  instance       WorkflowInstance?   @relation(fields: [instanceId], references: [id])
  versions       ConsumableVersion[]
  events         ConsumableEvent[]
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([assignedToId])
  @@index([teamId])
  @@index([roleKey, capabilityId])
  @@index([skillKey])
  @@map("consumables")
}

model ConsumableVersion {
  id           String     @id @default(uuid())
  consumableId String
  version      Int
  payload      Json       @default("{}")
  createdById  String?
  consumable   Consumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([consumableId, version])
  @@map("consumable_versions")
}

model ConsumableEvent {
  id           String     @id @default(uuid())
  consumableId String
  eventType    String
  payload      Json?
  consumable   Consumable @relation(fields: [consumableId], references: [id])
  occurredAt   DateTime   @default(now())

  @@map("consumable_events")
}

// ─── AGENTS ───────────────────────────────────────────────────────────────────

model Agent {
  id                 String       @id @default(uuid())
  name               String
  description        String?
  provider           String       @default("ANTHROPIC")
  model              String
  systemPrompt       String?
  isActive           Boolean      @default(true)
  // M10/M11.c — immutable snapshot of an agent-and-tools template captured
  // at AgentRun start. Rows are no longer authored locally.
  externalTemplateId String?      @unique
  externalSyncedAt   DateTime?    // = fetchedAt
  sourceHash         String?      // sha256(canonical JSON) of upstream payload at snapshot time
  sourceVersion      String?      // template's own .version (if present)
  fetchedBy          String?      // workgraph user id (null = system snapshot)
  skills             AgentSkill[]
  runs               AgentRun[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("agents")
}

model AgentSkill {
  agentId String
  skillId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id])

  @@id([agentId, skillId])
  @@map("agent_skills")
}

model AgentRun {
  id            String            @id @default(uuid())
  agentId       String
  instanceId    String?
  tenantId      String?  // RLS standalone-row tenant (see Task.tenantId)
  nodeId        String?
  // Finding #7 — the node attempt this run was dispatched under (null for standalone runs).
  attempt       Int?
  status        AgentRunStatus    @default(REQUESTED)
  initiatedById String?
  origin        String            @default("workflow")
  client        String?
  traceId       String?
  cfCallId      String?
  promptAssemblyId String?
  mcpServerId   String?
  mcpInvocationId String?
  contextPackageId String?
  modelCallId   String?
  laptopInvocationId String?
  agent         Agent             @relation(fields: [agentId], references: [id])
  instance      WorkflowInstance? @relation(fields: [instanceId], references: [id])
  inputs        AgentRunInput[]
  outputs       AgentRunOutput[]
  reviews       AgentReview[]
  laptopInvocation LaptopInvocation?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([origin, client])
  @@index([traceId])
  @@index([cfCallId])
  @@index([promptAssemblyId])
  @@index([mcpInvocationId])
  @@index([contextPackageId])
  @@index([modelCallId])
  @@map("agent_runs")
}

model AgentRunInput {
  id        String   @id @default(uuid())
  runId     String
  inputType String
  payload   Json     @default("{}")
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("agent_run_inputs")
}

model AgentRunOutput {
  id                String   @id @default(uuid())
  runId             String
  outputType        String
  rawContent        String?
  structuredPayload Json?
  tokenCount        Int?
  run               AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@map("agent_run_outputs")
}

model AgentReview {
  id           String   @id @default(uuid())
  runId        String
  reviewedById String
  decision     String
  notes        String?
  run          AgentRun @relation(fields: [runId], references: [id])
  reviewedAt   DateTime @default(now())

  @@map("agent_reviews")
}

model LaptopInvocation {
  id                 String           @id @default(uuid())
  workItemId         String
  agentRunId         String           @unique
  capabilityId       String?
  client             String
  mode               String           @default("direct-copilot")
  status             String           @default("STARTED")
  userId             String?
  tenantId           String?
  mcpUrl             String?
  mcpTokenJti        String?
  repoUrl            String?
  branch             String?
  baseCommitSha      String?
  renderedPrompt     String?
  promptAssemblyId   String?
  envelopeAssemblyId String?
  agentSpec          Json             @default("{}")
  data               Json             @default("{}")
  lastHeartbeatAt    DateTime?
  startedAt          DateTime         @default(now())
  endedAt            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workItem           WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  agentRun           AgentRun         @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  questions          LaptopQuestion[]

  @@index([workItemId])
  @@index([agentRunId])
  @@index([capabilityId])
  @@index([status, lastHeartbeatAt])
  @@map("laptop_invocations")
}

model LaptopQuestion {
  id           String           @id @default(uuid())
  invocationId String
  workItemId   String
  question     String
  context      Json             @default("{}")
  status       String           @default("OPEN")
  answer       String?
  askedById    String?
  answeredById String?
  askedAt      DateTime         @default(now())
  answeredAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  invocation   LaptopInvocation @relation(fields: [invocationId], references: [id], onDelete: Cascade)

  @@index([invocationId, status])
  @@index([workItemId, status])
  @@index([status, createdAt])
  @@map("laptop_questions")
}

// ─── BLUEPRINT WORKBENCH ────────────────────────────────────────────────────

model BlueprintSession {
  id                       String                 @id @default(uuid())
  goal                     String
  sourceType               BlueprintSourceType
  sourceUri                String
  sourceRef                String?
  includeGlobs             Json                   @default("[]")
  excludeGlobs             Json                   @default("[]")
  capabilityId             String
  architectAgentTemplateId  String
  developerAgentTemplateId  String
  qaAgentTemplateId         String
  status                   BlueprintSessionStatus @default(DRAFT)
  workflowInstanceId        String?
  // Finding #12 — set to workflowInstanceId only for LIVE multinode sessions; a partial
  // UNIQUE index (see migration) enforces at most one live multinode session per instance.
  // Non-multinode sessions leave this null (nulls don't collide); the partial index drops the
  // row once the session reaches a terminal state (completed/approved/failed/abandoned), so a
  // re-run starts clean.
  multinodeInstanceKey     String?
  phaseId                  String?
  metadata                 Json                   @default("{}")
  createdById              String?
  approvedById             String?
  approvedAt               DateTime?
  snapshots                BlueprintSourceSnapshot[]
  stageRuns                BlueprintStageRun[]
  artifacts                BlueprintArtifact[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([capabilityId])
  @@index([createdById])
  @@index([status])
  @@map("blueprint_sessions")
}

model BlueprintSourceSnapshot {
  id          String           @id @default(uuid())
  sessionId   String
  status      String           @default("COMPLETED")
  manifest    Json             @default("[]")
  summary     Json             @default("{}")
  fileCount   Int              @default(0)
  totalBytes  Int              @default(0)
  rootHash    String?
  error       String?
  session     BlueprintSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([sessionId])
  @@map("blueprint_source_snapshots")
}

model BlueprintStageRun {
  id            String               @id @default(uuid())
  sessionId     String
  stage         BlueprintStage
  status        BlueprintStageStatus @default(PENDING)
  task          String
  response      String?
  error         String?
  correlation   Json?
  tokensUsed    Json?
  startedAt     DateTime?
  completedAt   DateTime?
  session       BlueprintSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now())

  @@index([sessionId, stage])
  @@map("blueprint_stage_runs")
}

model BlueprintArtifact {
  id          String           @id @default(uuid())
  sessionId   String
  stage       BlueprintStage?
  kind        String
  title       String
  content     String?
  payload     Json?
  session     BlueprintSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([sessionId])
  @@index([kind])
  @@map("blueprint_artifacts")
}

// ─── TOOLS ────────────────────────────────────────────────────────────────────

model Tool {
  id               String       @id @default(uuid())
  name             String       @unique
  description      String?
  riskLevel        RiskLevel    @default(MEDIUM)
  requiresApproval Boolean      @default(true)
  isActive         Boolean      @default(true)
  // M10/M11.c — immutable snapshot of a tool-service registration captured
  // at ToolRun start. Rows are no longer authored locally.
  externalToolName String?      @unique
  externalVersion  String?
  externalSyncedAt DateTime?    // = fetchedAt
  sourceHash       String?      // sha256(canonical JSON) of upstream payload at snapshot time
  sourceVersion    String?      // tool's published version (if present)
  fetchedBy        String?      // workgraph user id (null = system snapshot)
  actions          ToolAction[]
  runs             ToolRun[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("tools")
}

model ToolAction {
  id           String    @id @default(uuid())
  toolId       String
  name         String
  description  String?
  inputSchema  Json      @default("{}")
  outputSchema Json      @default("{}")
  riskLevel    RiskLevel @default(MEDIUM)
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@map("tool_actions")
}

model ToolPermission {
  id        String   @id @default(uuid())
  toolId    String
  roleId    String?
  actionId  String?
  grantedAt DateTime @default(now())

  @@map("tool_permissions")
}

model ExecutionRunner {
  id         String  @id @default(uuid())
  name       String
  runnerType String  @default("MOCK")
  config     Json    @default("{}")
