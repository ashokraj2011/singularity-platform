  initiatedById String?
  origin        String            @default("workflow")
  client        String?
  traceId       String?
  cfCallId      String?
  promptAssemblyId String?
  mcpServerId   String?
  mcpInvocationId String?
  contextPackageId String?
  modelCallId   String?
  laptopInvocationId String?
  agent         Agent             @relation(fields: [agentId], references: [id])
  instance      WorkflowInstance? @relation(fields: [instanceId], references: [id])
  inputs        AgentRunInput[]
  outputs       AgentRunOutput[]
