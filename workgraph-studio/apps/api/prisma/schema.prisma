  END
  HUMAN_TASK
  AGENT_TASK
  WORKBENCH_TASK
  APPROVAL
  DECISION_GATE
  CONSUMABLE_CREATION
  TOOL_REQUEST
  POLICY_CHECK
  TIMER
  SIGNAL_WAIT
  SIGNAL_EMIT
  CALL_WORKFLOW
  FOREACH
  PARALLEL_FORK
