// ─── WORKFLOW ─────────────────────────────────────────────────────────────────

// ─── Workflow (the editable design — no longer a "template") ─────────────────
//
// A Workflow IS the canonical design.  Its graph lives in the dedicated
// `workflow_design_*` tables; runs are separate WorkflowInstance rows cloned
// from those tables when a run starts.  The `workflow_templates` table name
// is preserved for back-compat — only the model name and code surface change.
model Workflow {
  id             String                @id @default(uuid())
  name           String
  description    String?
  status         String                @default("DRAFT")
  currentVersion Int                   @default(1)
  // Monotonic design revision used by Studio clients to detect stale edits.
  designRevision Int                   @default(0)
  createdById    String?
  teamId         String
  team           Team                  @relation(fields: [teamId], references: [id])
  tenantId       String?               @default("default")
  // ID of the owning capability in Singularity IAM.  When set, this is the
  // authorization boundary — the permission helper calls iamClient.authzCheck
  // against this capability.  When null, falls back to the legacy team rule.
  capabilityId   String?
  archivedAt     DateTime?
  metadata       Json?
  workflowTypeKey String               @default("GENERAL")
  typeVersion    Int                   @default(1)
  typeSnapshot   Json?
  // M85.s1 — workflow profile. Distinguishes templates that the
  // operator designs as standalone workbench loops from the main
  // workflows that orchestrate them. Possible values:
  //   • 'main'           — top-level workflow (default)
  //   • 'workbench'      — a workbench loop template; nodes are stages
  //   • 'workbench-host' — legacy main workflow that contains an inline
  //                        WORKBENCH_TASK node (pre-M85; flagged so the
  //                        cutover can find them)
  // The blueprint-workbench UI filters to profile='workbench' only;
  // the main workflow designer hides workbench-only node types from
  // 'main' templates. String rather than enum so adding new profiles
  // (e.g. 'codepath', 'review') in future doesn't require a migration.
  profile        String                @default("main")
  eligibleWorkItemTypes Json           @default("[]")
  isDefaultForType Boolean             @default(false)
  defaultRoutingMode WorkItemRoutingMode @default(MANUAL)
  // Workflow-scoped variables: [{key, label, type, defaultValue, description, scope}]
  // scope: 'INPUT' (provided when starting a run) | 'CONSTANT' (workflow-baked default)
  variables      Json                  @default("[]")
  // Template-level token/cost budget policy cloned into each WorkflowInstance.
  budgetPolicy   Json?
  // Editable design graph — runs clone these into WorkflowInstance.nodes / edges / phases.
  designPhases   WorkflowDesignPhase[]
  designNodes    WorkflowDesignNode[]
  designEdges    WorkflowDesignEdge[]
  versions       WorkflowVersion[]
  triggers       WorkflowTrigger[]
  routingPolicies WorkItemRoutingPolicy[]
  permissions    WorkflowPermission[]
  accessGrants   WorkflowAccessGrant[]
  instances      WorkflowInstance[]
  runSnapshots   RunSnapshot[]
  programSteps   WorkProgramStep[]
  simulations    WorkflowSimulation[]
  workItemTargetsAsTemplate WorkItemTarget[] @relation("WorkItemTargetTemplate")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([teamId])
  @@index([tenantId])
  @@index([capabilityId])
  @@index([capabilityId, workflowTypeKey, status])
  @@index([workflowTypeKey, isDefaultForType])
  @@index([status])
  @@map("workflow_templates")
}

// ─── Browser-runtime snapshot ────────────────────────────────────────────────
//
// Single row per browser-driven run.  The browser writes the full RunState as
// JSON; the server is just durable storage with optimistic-concurrency on
// `version`.  Run state machine + edge eval lives entirely client-side.
model RunSnapshot {
  id          String   @id @default(uuid())
  runId       String   @unique // browser-generated UUID
  workflowId  String
  name        String
  status      String // RunStatus enum mirror (string for forward-compat)
  payload     Json // entire RunState blob
  version     Int      @default(1) // monotonic; rejects POST with stale version
  createdById String?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([createdById])
  @@index([tenantId])
  @@index([status])
  @@map("run_snapshots")
}

enum WorkflowPermissionAction {
  VIEW
  EDIT
  START
  ADMIN
}

model WorkflowPermission {
  id         String                   @id @default(uuid())
  templateId String
  roleId     String
  action     WorkflowPermissionAction
  template   Workflow                 @relation(fields: [templateId], references: [id], onDelete: Cascade)
  grantedAt  DateTime                 @default(now())

  @@unique([templateId, roleId, action])
  @@map("workflow_permissions")
}

// Tenant-scoped resource grants. IAM capability permissions remain the coarse
// authorization boundary; these grants provide explicit workflow sharing and
// deny rules for users, teams, roles, and capabilities.
model WorkflowAccessGrant {
  id          String    @id @default(uuid())
  workflowId  String
  tenantId    String?   @default("default")
  subjectType String
  subjectId   String
  action      String
  effect      String    @default("ALLOW")
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String?
  metadata    Json      @default("{}")
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workflowId, subjectType, subjectId, action])
  @@index([tenantId, subjectType, subjectId])
  @@index([workflowId, action, effect])
  @@map("workflow_access_grants")
}

enum TriggerType {
  WEBHOOK
  SCHEDULE
  EVENT
}

model WorkflowTrigger {
  id          String      @id @default(uuid())
  templateId  String
  template    Workflow    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type        TriggerType
  isActive    Boolean     @default(true)
  // For WEBHOOK: { secret: string }
  // For SCHEDULE: { cron: string, timezone?: string }
  // For EVENT: { eventType: string, filter?: object }
  config      Json        @default("{}")
  lastFiredAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenantId    String?     @default("default")

  @@index([tenantId], map: "ix_workflow_triggers_tenant")
  @@index([type, isActive])
  @@map("workflow_triggers")
}

model WorkflowVersion {
  id            String   @id @default(uuid())
  templateId    String
  version       Int
  graphSnapshot Json
  // SHA-256 of the canonical graph representation — used to dedupe snapshots
  // when starting a run.  If the design hasn't changed since the last
  // snapshot, the run reuses that version instead of creating a new one.
  contentHash   String?
  // Optional human/auto trigger context — "auto" (snapshot on run) or "manual" (Publish).
  source        String?
  template      Workflow @relation(fields: [templateId], references: [id])
  createdAt     DateTime @default(now())

  @@unique([templateId, version])
  @@index([templateId, contentHash])
  @@map("workflow_template_versions")
}

// ─── Workflow design tables — the editable graph owned by a Workflow ─────────

model WorkflowDesignPhase {
  id           String               @id @default(uuid())
  workflowId   String
  name         String
  displayOrder Int                  @default(0)
  color        String?
  workflow     Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodes        WorkflowDesignNode[]
  createdAt    DateTime             @default(now())

  @@index([workflowId])
  @@map("workflow_design_phases")
}

model WorkflowDesignNode {
  id                 String               @id @default(uuid())
  workflowId         String
  phaseId            String?
  nodeType           NodeType
  nodeTypeKey        String?
  nodeTypeVersion    Int?
  nodeTypeSnapshot   Json?
  label              String
  config             Json                 @default("{}")
  compensationConfig Json?
  executionLocation  ExecutionLocation    @default(SERVER)
  positionX          Float                @default(0)
  positionY          Float                @default(0)
  workflow           Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  phase              WorkflowDesignPhase? @relation(fields: [phaseId], references: [id])
  outgoing           WorkflowDesignEdge[] @relation("DesignSourceNode")
  incoming           WorkflowDesignEdge[] @relation("DesignTargetNode")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([workflowId])
  @@map("workflow_design_nodes")
}

model WorkflowDesignEdge {
  id           String             @id @default(uuid())
  workflowId   String
  sourceNodeId String
  targetNodeId String
  edgeType     EdgeType           @default(SEQUENTIAL)
  condition    Json?
  label        String?
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  source       WorkflowDesignNode @relation("DesignSourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  target       WorkflowDesignNode @relation("DesignTargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())

  @@index([workflowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("workflow_design_edges")
}

// A WorkflowInstance is now exclusively a run — a transactional clone of a
// Workflow's design graph at start time.  The previous `isDesign=true` row
// pattern is gone; the editable design lives in `workflow_design_*` tables
// owned by the Workflow.
model WorkflowInstance {
  id                String             @id @default(uuid())
  templateId        String?
  // Snapshot version this run was cloned from.
  templateVersion   Int?
  template          Workflow?          @relation(fields: [templateId], references: [id])
  initiativeId      String?
  tenantId          String?
  name              String
  status            InstanceStatus     @default(DRAFT)
  context           Json               @default("{}")
  initiative        Initiative?        @relation(fields: [initiativeId], references: [id])
  parentInstanceId  String?
  parentNodeId      String?
  parent            WorkflowInstance?  @relation("Subworkflows", fields: [parentInstanceId], references: [id])
  // M85.s1 — inherited from the template's profile at clone time. Cached
  // here so runtime / UI queries don't have to join the template every
  // time. blueprint-workbench filters on this directly.
  profile           String             @default("main")
  graphGeneration   Int                @default(1)
  children          WorkflowInstance[] @relation("Subworkflows")
  phases            WorkflowPhase[]
  nodes             WorkflowNode[]
  edges             WorkflowEdge[]
  mutations         WorkflowMutation[]
  events            WorkflowEvent[]
  tasks             Task[]
  consumables       Consumable[]
  sourceWorkItems   WorkItem[]         @relation("WorkItemSourceInstance")
  childWorkItemTargets WorkItemTarget[] @relation("WorkItemChildInstance")
  workflowStartCommands WorkflowStartCommand[]
  agentRuns         AgentRun[]
  toolRuns          ToolRun[]
  pendingExecutions PendingExecution[]
  checkpoints       WorkflowCheckpoint[]
  replays           WorkflowReplay[]
  documents         Document[]
  budget            WorkflowRunBudget?
  startedAt         DateTime?
  completedAt       DateTime?
  archivedAt        DateTime?
  createdById       String?
  authorizationSnapshot WorkflowAuthorizationSnapshot?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([templateId])
  @@index([tenantId])
  @@index([status], map: "ix_workflow_instances_status")
  @@map("workflow_instances")
}

// Immutable start-time authorization evidence. Sensitive actions still perform
// live checks; this snapshot exists for reproducibility and audit.
model WorkflowAuthorizationSnapshot {
  id                 String           @id @default(uuid())
  instanceId         String           @unique
  tenantId           String?
  actorIamUserId     String?
  actorWorkGraphId   String?
  runOwnerId         String?
  workflowId         String?
  capabilityId       String?
  policyVersion      String           @default("v1")
  effectiveRoles     Json             @default("[]")
  effectivePermissions Json           @default("[]")
  resourceGrants     Json             @default("[]")
  snapshotDigest     String
  capturedAt         DateTime         @default(now())
  instance           WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([tenantId, actorIamUserId])
  @@index([workflowId])
  @@map("workflow_authorization_snapshots")
}

model WorkflowRunBudget {
  id                    String                         @id @default(uuid())
  instanceId            String                         @unique
  templateId            String?
  policy                Json                           @default("{}")
  maxInputTokens        Int?
  maxOutputTokens       Int?
  maxTotalTokens        Int?
  maxEstimatedCost      Float?
  warnAtPercent         Int                            @default(80)
  enforcementMode       WorkflowBudgetEnforcementMode  @default(PAUSE_FOR_APPROVAL)
  consumedInputTokens   Int                            @default(0)
  consumedOutputTokens  Int                            @default(0)
  consumedTotalTokens   Int                            @default(0)
  consumedEstimatedCost Float                          @default(0)
  pricingStatus         String                         @default("PRICED")
  status                WorkflowRunBudgetStatus        @default(ACTIVE)
  warningEmittedAt      DateTime?
  exceededAt            DateTime?
  pausedAt              DateTime?
  instance              WorkflowInstance               @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  events                WorkflowRunBudgetEvent[]
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt

  @@index([templateId])
  @@index([status])
  @@map("workflow_run_budgets")
}

model WorkflowRunBudgetEvent {
  id                 String                     @id @default(uuid())
  budgetId           String
  instanceId         String
  nodeId             String?
  agentRunId         String?
  cfCallId           String?
  promptAssemblyId   String?
  eventType          WorkflowRunBudgetEventType
  inputTokensDelta   Int                        @default(0)
  outputTokensDelta  Int                        @default(0)
  totalTokensDelta   Int                        @default(0)
  estimatedCostDelta Float?
  pricingStatus      String                     @default("PRICED")
  metadata           Json?
  budget             WorkflowRunBudget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  createdAt          DateTime                   @default(now())

  @@index([instanceId, createdAt])
  @@index([nodeId])
  @@index([agentRunId])
  @@index([cfCallId])
  @@map("workflow_run_budget_events")
}

model WorkflowPhase {
  id           String           @id @default(uuid())
  instanceId   String
  name         String
  displayOrder Int              @default(0)
  color        String?
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodes        WorkflowNode[]
  createdAt    DateTime         @default(now())

  @@index([instanceId], map: "ix_workflow_phases_instance")
  @@map("workflow_phases")
}

model WorkflowNode {
  id                 String             @id @default(uuid())
  instanceId         String
  phaseId            String?
  nodeType           NodeType
  nodeTypeKey        String?
  nodeTypeVersion    Int?
  nodeTypeSnapshot   Json?
  label              String
  status             NodeStatus         @default(PENDING)
  config             Json               @default("{}")
  compensationConfig Json?
  executionLocation  ExecutionLocation  @default(SERVER)
  positionX          Float              @default(0)
  positionY          Float              @default(0)
  instance           WorkflowInstance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  phase              WorkflowPhase?     @relation(fields: [phaseId], references: [id])
  outgoing           WorkflowEdge[]     @relation("SourceNode")
  incoming           WorkflowEdge[]     @relation("TargetNode")
  pendingExecutions  PendingExecution[]
  documents          Document[]
  workItems          WorkItem[]         @relation("WorkItemSourceNode")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  // M24.5 — authoritative per-step timing. Written by the runtime when a
  // node transitions PENDING → ACTIVE → COMPLETED/FAILED. Falls back to
  // createdAt/updatedAt in the insights view when these are null (older runs).
  startedAt          DateTime?
  completedAt        DateTime?
  // Finding #7 — monotonic attempt counter, bumped on restartNode so a result from a
  // SUPERSEDED attempt (stale client/subprocess result landing after a restart) can be
  // fenced out in advance() before it completes the new run.
  attempt            Int                @default(0)

  @@index([instanceId, status], map: "ix_workflow_nodes_instance_status")
  @@index([nodeType, status], map: "ix_workflow_nodes_type_status")
  @@map("workflow_nodes")
}

model WorkflowEdge {
  id           String           @id @default(uuid())
  instanceId   String
  sourceNodeId String
  targetNodeId String
  edgeType     EdgeType         @default(SEQUENTIAL)
  condition    Json?
  label        String?
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  source       WorkflowNode     @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  target       WorkflowNode     @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@index([sourceNodeId], map: "ix_workflow_edges_source")
  @@index([instanceId], map: "ix_workflow_edges_instance")
  @@map("workflow_edges")
}

model WorkflowMutation {
  id            String           @id @default(uuid())
  instanceId    String
  nodeId        String?
  mutationType  String
  beforeState   Json?
  afterState    Json?
  performedById String?
  instance      WorkflowInstance @relation(fields: [instanceId], references: [id])
  performedAt   DateTime         @default(now())

  @@index([instanceId], map: "ix_workflow_mutations_instance")
  @@map("workflow_mutations")
}

model WorkflowEvent {
  id         String           @id @default(uuid())
  instanceId String
  eventType  String
  payload    Json?
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id])
  occurredAt DateTime         @default(now())

  @@index([instanceId, occurredAt], map: "ix_workflow_events_instance_time")
  @@map("workflow_events")
}

// P1-12 — durable signals. An emitted signal is persisted here so a SIGNAL_WAIT
// that parks AFTER the emit can still consume it (fixes emit-before-wait loss).
// Instance-scoped; windowed via expiresAt; consumedAt is an atomic single-winner
// claim (updateMany consumedAt: null -> now). FK-less (instanceId is the scope
// key) to avoid a WorkflowInstance back-relation; stale rows expire via expiresAt.
model WorkflowSignal {
  id             String    @id @default(uuid())
  instanceId     String
  signalName     String
  correlationKey String?
  payload        Json?
  emittedAt      DateTime  @default(now())
  consumedAt     DateTime?
  expiresAt      DateTime

  @@index([instanceId, signalName, consumedAt])
  @@index([expiresAt])
  @@map("workflow_signals")
}

// ─── CROSS-CAPABILITY WORK ITEMS ──────────────────────────────────────────────

model WorkItem {
  id                      String           @id @default(uuid())
  workCode                String           @unique
  originType              WorkItemOriginType @default(CAPABILITY_LOCAL)
  workItemTypeKey         String           @default("GENERAL")
  typeVersion             Int              @default(1)
  typeSnapshot            Json?
  routingMode             WorkItemRoutingMode @default(MANUAL)
  scheduledAt             DateTime?
  notBefore               DateTime?
  sourceEventTypeKey      String?
  routingPolicyId         String?
  routingState            WorkItemRoutingState @default(UNROUTED)
  title                   String
  description             String?
  parentCapabilityId      String?
  sourceWorkflowInstanceId String?
  sourceWorkflowNodeId    String?
  status                  WorkItemStatus   @default(QUEUED)
  reconciliationState     ReconciliationState @default(UNVERIFIED)
  completionPolicy        String           @default("VERIFY_THEN_APPROVE")
  finalizationGeneration  Int              @default(0)
  input                   Json             @default("{}")
  details                 Json             @default("{}")
  specSourceRef           Json?
  budget                  Json             @default("{}")
  urgency                 WorkItemUrgency   @default(NORMAL)
  requiredBy              DateTime?
  detailsLocked           Boolean          @default(true)
  finalOutput             Json?
  priority                Int              @default(50)
  dueAt                   DateTime?
  createdById             String?
  approvedById            String?
  parentApprovalRequestId String?
  projectId               String?
  completionProgramId     String?
  sourceWorkflowInstance  WorkflowInstance? @relation("WorkItemSourceInstance", fields: [sourceWorkflowInstanceId], references: [id], onDelete: SetNull)
  sourceWorkflowNode      WorkflowNode?    @relation("WorkItemSourceNode", fields: [sourceWorkflowNodeId], references: [id], onDelete: SetNull)
  routingPolicy           WorkItemRoutingPolicy? @relation(fields: [routingPolicyId], references: [id], onDelete: SetNull)
  targets                 WorkItemTarget[]
  events                  WorkItemEvent[]
  clarifications          WorkItemClarification[]
  laptopInvocations       LaptopInvocation[]
  predecessorDependencies WorkItemDependency[] @relation("DependencyPredecessor")
  successorDependencies   WorkItemDependency[] @relation("DependencySuccessor")
  programRunSteps         WorkProgramRunStep[]
  specifications          SpecificationVersion[]
  specificationBindings   WorkItemSpecificationBinding[]
  developmentScopes       DevelopmentScope[]
  developmentTarget       DevelopmentTarget?
  implementationSubmissions ImplementationSubmission[]
  reconciliationRuns      ReconciliationRun[]
  finalizationRecords     WorkItemFinalizationRecord[]
  creationCommands        WorkItemCreationCommand[]
  generationPlanRows      GenerationPlanRow[]
  project                 SpecificationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  completionProgram       WorkProgram?     @relation("WorkItemCompletionProgram", fields: [completionProgramId], references: [id], onDelete: SetNull)
  specComments            SpecComment[]
  synthesisWorkspaces     SynthesisWorkspace[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  tenantId                String?          @default("default")

  @@index([tenantId], map: "ix_work_items_tenant")
  @@index([projectId], map: "ix_work_items_project")
  @@index([completionProgramId], map: "ix_work_items_completion_program")
  @@index([workCode])
  @@index([originType])
  @@index([workItemTypeKey])
  @@index([routingMode])
  @@index([routingState])
  @@index([scheduledAt])
  @@index([notBefore])
  @@index([sourceEventTypeKey])
  @@index([routingPolicyId])
  @@index([parentCapabilityId])
  @@index([sourceWorkflowInstanceId])
  @@index([sourceWorkflowNodeId])
  @@index([status])
  @@map("work_items")
}

// A Work Item's specification, versioned. The full structured SpecificationPackage
// is stored as versioned JSON (`package`); approval freezes it with a canonical
// `contentHash`. The active approved version is resolved by status=APPROVED + highest
// version (no denormalized pointer on WorkItem yet — added later for performance).
model SpecificationVersion {
  id               String              @id @default(uuid())
  workItemId       String?
  specificationProjectId String?
  version          Int
  revision         Int                 @default(1)
  status           SpecificationStatus @default(DRAFT)
  package          Json
  renderedMarkdown String?
  contentHash      String?
  createdById      String?
  approvedById     String?
  approvedAt       DateTime?
  approvalComment  String?
  supersedesId     String?
  tenantId         String?             @default("default")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  workItem         WorkItem?           @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  specificationProject SpecificationProject? @relation(fields: [specificationProjectId], references: [id], onDelete: Cascade)
  bindings         WorkItemSpecificationBinding[]
  submissions      ImplementationSubmission[]
  generationPlans  GenerationPlan[]
  changeRequests   SpecificationChangeRequest[]
  businessReadouts       BusinessReadout[]

  @@unique([workItemId, version])
  @@unique([specificationProjectId, version])
  @@index([workItemId, status])
  @@index([specificationProjectId, status])
  @@index([tenantId], map: "ix_specification_versions_tenant")
  @@map("specification_versions")
}

// A Specification Project is the persisted initiative root. It owns portfolio guardrails and the
// shared upstream (analysis -> requirements -> design) that many Work Items draw on. Work Items
// reference a project via WorkItem.projectId but remain standalone-capable for legacy/solo work.
model SpecificationProject {
  id          String                     @id @default(uuid())
  code        String                     @unique
  name        String
  mission     String?
  status      SpecificationProjectStatus @default(ACTIVE)
  createdById String?
  tenantId    String?                    @default("default")
  archivedAt  DateTime?
  completionProgramId String?
  primaryCapabilityId String
  primaryCapabilityName String
  tokenBudget          Int                        @default(250000)
  tokenUsed            Int                        @default(0)
  costBudgetUsd        Float?
  costUsedUsd          Float                      @default(0)
  businessValue        Int?
  customerImpact       Int?
  strategicAlignment  Int?
  urgency              Int?
  deliveryRisk         Int?
  technicalRisk        Int?
  regulatoryRisk       Int?
  confidence           Int?
  effort               Int?
  targetDate           DateTime?
  reviewCadenceDays    Int                        @default(30)
  lastReviewedAt       DateTime?
  sponsorId            String?
  productOwnerId       String?
  successMetrics       Json                       @default("[]")
  tags                 String[]                   @default([])
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  workItems     WorkItem[]
  specificationVersions SpecificationVersion[]
  specification ProjectSpecification?
  rooms         Room[]
  claims        Claim[]
  boards        Board[]
  generationPlans GenerationPlan[]
  decisionDossiers DecisionDossier[]
  budgetEnvelope ProjectBudgetEnvelope?
  tokenLedgerEntries ProjectTokenLedgerEntry[]
  budgetEvents ProjectBudgetEvent[]
  claimDriftSignals ClaimDriftSignal[]
  changeRequests SpecificationChangeRequest[]
  capabilityLinks SpecificationProjectCapability[]
  impactAssessments CapabilityImpactAssessment[]
  primaryBusinessObjectives BusinessObjective[]              @relation("BusinessObjectivePrimaryProject")
  businessObjectiveLinks    BusinessObjectiveProject[]
  businessMilestones        BusinessMilestone[]
  businessReadouts          BusinessReadout[]
  businessRisks             BusinessRisk[]
  taxonomyMappings          ExternalTaxonomyMapping[]
  attentionItems            AttentionItem[]
  validationReports         ArtifactValidationReport[]
  studio        Studio?
  synthesisWorkspaces SynthesisWorkspace[]
  synthesisDocuments  SynthesisDocument[]
  completionProgram WorkProgram?         @relation("ProjectCompletionProgram", fields: [completionProgramId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([completionProgramId], map: "ix_specification_projects_completion_program")
  @@index([tenantId], map: "ix_specification_projects_tenant")
  @@index([tenantId, primaryCapabilityId], map: "ix_specification_projects_tenant_primary_capability")
  @@map("specification_projects")
}

// Tenant-level funded intent. Objectives may span initiatives through
// BusinessObjectiveProject while studioProjectId retains a convenient primary link.
model BusinessObjective {
  id              String                  @id @default(uuid())
  tenantId        String                  @default("default")
  studioProjectId String?
  title           String
  description     String
  ownerId         String
  targetMetric    Json                    @default("{}")
  valueScore      Int                     @default(1)
  valueRationale  String?
  budgetLineRef   String?
  period          Json                    @default("{}")
  status          BusinessObjectiveStatus @default(ACTIVE)
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  primaryProject SpecificationProject?      @relation("BusinessObjectivePrimaryProject", fields: [studioProjectId], references: [id], onDelete: SetNull)
  projectLinks   BusinessObjectiveProject[]
  readouts       BusinessReadout[]

  @@index([tenantId, status])
  @@index([studioProjectId])
  @@map("business_objectives")
}

model BusinessObjectiveProject {
  id          String   @id @default(uuid())
  objectiveId String
  projectId   String
  tenantId    String   @default("default")
  createdById String?
  createdAt   DateTime @default(now())

  objective BusinessObjective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  project   SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([objectiveId, projectId])
  @@index([tenantId, projectId])
  @@map("business_objective_projects")
}

// Milestone status is stored as a last-derived snapshot for queryability; the
// business-alignment service recomputes it from delivery data on every read.
model BusinessMilestone {
  id                   String                  @id @default(uuid())
  tenantId             String                  @default("default")
  studioProjectId      String
  name                 String
  valueStatement       String
  targetDate           DateTime
  completionDefinition Json                    @default("{}")
  status               BusinessMilestoneStatus @default(PLANNED)
  createdById          String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  project  SpecificationProject @relation(fields: [studioProjectId], references: [id], onDelete: Cascade)
  planRows GenerationPlanRow[]

  @@index([tenantId, studioProjectId])
  @@index([targetDate, status])
  @@map("business_milestones")
}

// Generated, immutable sponsor/weekly communication. renderedMarkdown and
// contentHash are persisted together so the exact signed document is retrievable.
model BusinessReadout {
  id                     String                @id @default(uuid())
  tenantId               String                @default("default")
  studioProjectId        String
  objectiveId            String?
  specificationVersionId String?
  kind                   BusinessReadoutKind
  periodStart            DateTime?
  periodEnd              DateTime?
  content                Json                  @default("{}")
  citations              Json                  @default("[]")
  renderedMarkdown       String
  contentHash            String
  status                 BusinessReadoutStatus @default(DRAFT)
  sponsorApprovalId      String?
  generatedById          String?
  signedAt               DateTime?
  supersedesId           String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  project              SpecificationProject  @relation(fields: [studioProjectId], references: [id], onDelete: Cascade)
  objective            BusinessObjective?    @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  specificationVersion SpecificationVersion? @relation(fields: [specificationVersionId], references: [id], onDelete: SetNull)

  @@unique([studioProjectId, contentHash, kind])
  @@index([tenantId, studioProjectId, kind, status])
  @@index([objectiveId, createdAt])
  @@map("business_readouts")
}

model BusinessRisk {
  id              String             @id @default(uuid())
  tenantId        String             @default("default")
  studioProjectId String
  sourceType      String
  sourceId        String
  category        String
  title           String
  description     String
  ownerId         String?
  mitigation      String?
  severity        Int                @default(3)
  status          BusinessRiskStatus @default(OPEN)
  sourceHref      String?
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  project SpecificationProject @relation(fields: [studioProjectId], references: [id], onDelete: Cascade)

  @@unique([studioProjectId, sourceType, sourceId])
  @@index([tenantId, studioProjectId, status, severity])
  @@map("business_risks")
}

model ExternalTaxonomyMapping {
  id              String   @id @default(uuid())
  tenantId        String   @default("default")
  studioProjectId String
  entityType      String
  entityId        String
  externalSystem  String
  externalType    String
  externalLabel   String?
  costCenterRef   String?
  metadata        Json     @default("{}")
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project SpecificationProject @relation(fields: [studioProjectId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalSystem, entityType, entityId])
  @@index([studioProjectId, externalSystem])
  @@map("external_taxonomy_mappings")
}

model SpecificationProjectCapability {
  id             String                @id @default(uuid())
  projectId      String
  capabilityId   String
  capabilityName String?
  role           ProjectCapabilityRole @default(PRIMARY)
  impactArea     String?
  tenantId       String?               @default("default")
  createdAt      DateTime              @default(now())
