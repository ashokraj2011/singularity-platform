  session     BlueprintSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([sessionId])
  @@map("blueprint_source_snapshots")
}

model BlueprintStageRun {
  id            String               @id @default(uuid())
  sessionId     String
  stage         BlueprintStage
  status        BlueprintStageStatus @default(PENDING)
  task          String
  response      String?
  error         String?
  correlation   Json?
  tokensUsed    Json?
  startedAt     DateTime?
  completedAt   DateTime?
  session       BlueprintSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now())

  @@index([sessionId, stage])
  @@map("blueprint_stage_runs")
}

model BlueprintArtifact {
  id          String           @id @default(uuid())
  sessionId   String
  stage       BlueprintStage?
  kind        String
  title       String
  content     String?
  payload     Json?
  session     BlueprintSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([sessionId])
  @@index([kind])
  @@map("blueprint_artifacts")
}

// ─── TOOLS ────────────────────────────────────────────────────────────────────

model Tool {
  id               String       @id @default(uuid())
  name             String       @unique
  description      String?
  riskLevel        RiskLevel    @default(MEDIUM)
  requiresApproval Boolean      @default(true)
  isActive         Boolean      @default(true)
  // M10/M11.c — immutable snapshot of a tool-service registration captured
  // at ToolRun start. Rows are no longer authored locally.
  externalToolName String?      @unique
  externalVersion  String?
  externalSyncedAt DateTime?    // = fetchedAt
  sourceHash       String?      // sha256(canonical JSON) of upstream payload at snapshot time
  sourceVersion    String?      // tool's published version (if present)
  fetchedBy        String?      // workgraph user id (null = system snapshot)
  actions          ToolAction[]
  runs             ToolRun[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("tools")
}

model ToolAction {
  id           String    @id @default(uuid())
  toolId       String
  name         String
  description  String?
  inputSchema  Json      @default("{}")
  outputSchema Json      @default("{}")
  riskLevel    RiskLevel @default(MEDIUM)
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@map("tool_actions")
}

model ToolPermission {
  id        String   @id @default(uuid())
  toolId    String
  roleId    String?
  actionId  String?
  grantedAt DateTime @default(now())

  @@map("tool_permissions")
}

model ExecutionRunner {
  id         String  @id @default(uuid())
  name       String
  runnerType String  @default("MOCK")
  config     Json    @default("{}")
  isActive   Boolean @default(true)

  @@map("execution_runners")
}

model ToolRun {
  id             String            @id @default(uuid())
  toolId         String
  actionId       String?
  instanceId     String?
  tenantId       String?  // RLS standalone-row tenant (see Task.tenantId)
  runnerId       String?
  status         ToolRunStatus     @default(REQUESTED)
  inputPayload   Json              @default("{}")
  outputPayload  Json?
  requestedById  String?
  idempotencyKey String?
  tool           Tool              @relation(fields: [toolId], references: [id])
  instance       WorkflowInstance? @relation(fields: [instanceId], references: [id])
  approvals      ToolRunApproval[]
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([toolId, idempotencyKey])
  @@index([tenantId], map: "ix_tool_runs_tenant")
  @@map("tool_runs")
}

model ToolRunApproval {
  id                String    @id @default(uuid())
  runId             String
  approvalRequestId String?
  approvedById      String?
  decision          String?
  run               ToolRun   @relation(fields: [runId], references: [id])
  decidedAt         DateTime?

  @@map("tool_run_approvals")
}

// ─── POLICIES ─────────────────────────────────────────────────────────────────

model Policy {
  id           String            @id @default(uuid())
  name         String
  description  String?
  resourceType String
  isActive     Boolean           @default(true)
  priority     Int               @default(100)
  conditions   PolicyCondition[]
  actions      PolicyAction[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("policies")
}

model PolicyCondition {
  id              String @id @default(uuid())
  policyId        String
  fieldPath       String
  operator        String
  value           Json
  logicalOperator String @default("AND")
  policy          Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@map("policy_conditions")
}

model PolicyAction {
  id           String @id @default(uuid())
  policyId     String
  actionType   String
  actionConfig Json   @default("{}")
  policy       Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@map("policy_actions")
}

// ─── AUDIT ────────────────────────────────────────────────────────────────────

model EventLog {
  id         String   @id @default(uuid())
  eventType  String
  entityType String
  entityId   String
  actorId    String?
  traceId    String?
  tenantId   String?
  payload    Json?
  occurredAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([traceId])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([occurredAt(sort: Desc)])
  @@map("event_log")
}

model Receipt {
  id          String   @id @default(uuid())
  receiptType String
  entityType  String
  entityId    String
  eventLogId  String?
  content     Json     @default("{}")
  generatedAt DateTime @default(now())

  @@map("receipts")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

// An attachment associated with a task / node / instance.
//
// Two kinds (`kind`):
//   UPLOAD — file stored in MinIO/S3.  `storageKey`, `mimeType`, `sizeBytes`
//            and `bucket` are populated; `url` is null.
//   LINK   — external URL (OneDrive, SharePoint, Google Drive, Dropbox,
//            arbitrary HTTPS).  `url` and `provider` are populated; storage
//            fields are null.
//
// Either kind may be attached at runtime to any node — there is no size
// limit on links and uploads only enforce the configured server-side cap.
model Document {
  id           String   @id @default(uuid())
  name         String
  // Common
  kind         String   @default("UPLOAD") // UPLOAD | LINK
  // UPLOAD-only
  mimeType     String?
  sizeBytes    BigInt?
  storageKey   String?
  bucket       String?
  // LINK-only
  url          String?
  provider     String? // ONEDRIVE | SHAREPOINT | GDRIVE | DROPBOX | BOX | GENERIC
  // Common metadata
  uploadedById String?
  uploadedAt   DateTime @default(now())

  // Optional links to runtime form-fill artifacts
  taskId     String?
  nodeId     String?
  instanceId String?
  tenantId   String?  // RLS standalone-row tenant (see Task.tenantId)

  task     Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  node     WorkflowNode?     @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  instance WorkflowInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([nodeId])
  @@index([instanceId])
  @@index([kind])
  @@index([tenantId], map: "ix_documents_tenant")
  @@map("documents")
}

// ─── CUSTOM NODE TYPES ────────────────────────────────────────────────────────

model CustomNodeType {
  id            String   @id @default(uuid())
  // Internal key used in config.customTypeId — uppercase, snake_case e.g. MARKETING_REVIEW
  name          String   @unique
  label         String
  description   String?
  color         String   @default("#64748b")
  // Lucide icon name, e.g. "Star", "Briefcase"
  icon          String   @default("Box")
  // Which built-in executor handles this node at runtime
  baseType      String   @default("HUMAN_TASK")
  // JSON array: [{key, label, placeholder, multiline?}]
  fields        Json     @default("[]")
  // If true, the node config gets a section-based form builder (and runtime fill panel)
  supportsForms Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("custom_node_types")
}

// ─── OUTBOX ───────────────────────────────────────────────────────────────────

model OutboxEvent {
  id            String       @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  processedAt   DateTime?
  errorMessage  String?

  @@index([status, createdAt])
  @@map("outbox_events")
}

// ─── CONNECTORS ───────────────────────────────────────────────────────────────

model Connector {
  id          String        @id @default(uuid())
  type        ConnectorType
  name        String
  description String?
  // Non-sensitive configuration (baseUrl, project keys, defaults)
  config      Json          @default("{}")
  // Encrypted at rest — API NEVER returns this field in list/get responses
  credentials Json          @default("{}")
  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("connectors")
}

// ─── PENDING EXECUTIONS (client/edge/external location gating) ───────────────

model PendingExecution {
  id          String            @id @default(uuid())
  instanceId  String
  nodeId      String
  // Finding #7 — the node attempt this pending execution was dispatched under.
  attempt     Int               @default(0)
  location    ExecutionLocation
  claimToken  String            @unique @default(uuid())
  payload     Json?
  claimedAt   DateTime?
  claimedBy   String?
  completedAt DateTime?
  result      Json?
  error       String?
  expiresAt   DateTime
  instance    WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  node        WorkflowNode      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@index([instanceId, completedAt])
  @@index([location, completedAt, expiresAt])
  @@map("pending_executions")
}

// ─── Artifact Designer ────────────────────────────────────────────────────────
//
// ArtifactTemplate defines the structure of a typed document: sections, parties,
// fill rules. Used to generate contracts (agent↔agent, agent↔human, human↔human),
// deliverables, specs, handoffs, and reports.
//
// Sections are stored as JSON:
//   [{ id, title, type, required, filledBy, placeholder, description,
//      fields?, columns?, language?, items? }]
//
// Parties are stored as JSON:
//   [{ id, name, role, required, description }]

model ArtifactTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// CONTRACT | DELIVERABLE | SPECIFICATION | APPROVAL_BRIEF | HANDOFF | REPORT
  type        String   @default("DELIVERABLE")
  /// DRAFT | PUBLISHED | ARCHIVED
  status      String   @default("DRAFT")
  version     Int      @default(1)
  sections    Json     @default("[]")
  parties     Json     @default("[]")
  metadata    Json?
  createdById String
  teamName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@map("artifact_templates")
}

// ─── M11.e — Event bus (Postgres LISTEN/NOTIFY + outbox + webhooks) ──────────
//
// Each service owns its own outbox + subscriptions. Publishers INSERT into
// `event_outbox` and pg_notify('event_outbox_workgraph', id). A dispatcher
// LISTENs on that channel, fans out to matching subscribers, and tracks
// per-delivery state for at-least-once retry semantics.

model EventOutbox {
  id            String   @id @default(uuid())
  eventName     String   // canonical: "workflow.published", "agent.run.completed", ...
  sourceService String   // "workgraph-api"
  traceId       String?  // correlation chain (M9.z)
  subjectKind   String   // "workflow" | "agent_run" | "approval" | ...
  subjectId     String
  envelope      Json     // full canonical envelope (kind, status, started_at, correlation, ...)
  tenantId      String?  // tenant owning the event; null is legacy/global
  status        String   @default("pending")  // pending | dispatched | failed
  attempts      Int      @default(0)
  emittedAt     DateTime @default(now())
  lastAttemptAt DateTime?
  lastError     String?
  deliveries    EventDelivery[]

  @@index([status, emittedAt])
  @@index([eventName])
  @@index([traceId])
  @@index([tenantId, emittedAt])
  @@map("event_outbox")
}

model EventSubscription {
  id            String   @id @default(uuid())
  subscriberId  String   // free-form; e.g. "audit-warehouse", "slack-bridge"
  eventPattern  String   // glob: "agent.run.*", "workflow.published", "*"
  targetUrl     String
  secret        String?  // optional HMAC-SHA256 signing key
  isActive      Boolean  @default(true)
  metadata      Json?
  createdById   String?
  tenantId      String?  // tenant owning the subscription; null is legacy/global
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deliveries    EventDelivery[]

  @@index([isActive, eventPattern])
  @@index([tenantId, isActive])
  @@map("event_subscriptions")
}

model EventDelivery {
  id              String              @id @default(uuid())
  outboxId        String
  subscriptionId  String
  status          String              @default("queued")  // queued | sent | failed | dropped
  attempts        Int                 @default(0)
  lastAttemptAt   DateTime?
  lastError       String?
  deliveredAt     DateTime?
  responseStatus  Int?
  outbox          EventOutbox         @relation(fields: [outboxId],       references: [id], onDelete: Cascade)
  subscription    EventSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())

  @@unique([outboxId, subscriptionId])
  @@index([status, createdAt])
  @@map("event_deliveries")
}

// ─── M11.c — Execution Snapshot tables ────────────────────────────────────────
//
// Immutable copies of upstream reference data captured at run start so that
// audit replay still resolves names/configs even if the upstream entity was
// later modified or deleted. Distinct from Agent/Tool which are themselves
// snapshot rows but also act as workgraph-local FK targets for AgentRun/
// ToolRun. The snapshots below are "read-only audit rows" — nothing FKs to
// them; consumers JOIN by externalId at read time.

model PromptProfileSnapshot {
  id             String    @id @default(uuid())
  externalId     String    // prompt-composer profile uuid
  name           String?
  capabilityId   String?
  scope          String?
  payload        Json      // canonical-JSON snapshot of the upstream record
  sourceHash     String    // sha256 of `payload`
  sourceVersion  String?   // profile.version (if present)
  fetchedAt      DateTime  @default(now())
  fetchedBy      String?   // workgraph user id (null = system)
  createdAt      DateTime  @default(now())

  @@unique([externalId, sourceHash])
  @@index([externalId, fetchedAt])
  @@map("prompt_profile_snapshots")
}

model CapabilitySnapshot {
  id             String    @id @default(uuid())
  externalId     String    // IAM capability row uuid
  capabilityKey  String?   // IAM .capability_id slug (e.g. "tag-test")
  name           String?
  capabilityType String?
  payload        Json      // canonical-JSON snapshot of the upstream record
  sourceHash     String    // sha256 of `payload`
  sourceVersion  String?   // optional — reserved (IAM doesn't currently version capabilities)
  fetchedAt      DateTime  @default(now())
  fetchedBy      String?   // workgraph user id (null = system)
  createdAt      DateTime  @default(now())

  @@unique([externalId, sourceHash])
  @@index([externalId, fetchedAt])
  @@map("capability_snapshots")
}

// ─── FEATURE FLAGS ──────────────────────────────────────────────────────────
// M42.0 — Admin-controlled kill switches for major platform capabilities.
// Each row is a boolean toggle keyed by a dotted-namespace string. The
// Foundry's CLI / REST / web UI all check the relevant key before doing
// work; flipping `enabled=false` returns a clean FEATURE_DISABLED response
// at every entry point. Toggles are gated to ADMIN role on PUT and emit
// a FeatureFlagToggled audit event on every change.

model FeatureFlag {
  key         String   @id                          // e.g. 'code_foundry.enabled'
  enabled     Boolean  @default(false)
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

// ─── M84 — FIRST-CLASS WORKBENCH STAGES ─────────────────────────────────────
// Operators couldn't make sense of the old workbench: the whole loop was a
// JSON blob on WorkflowNode.config with no canvas representation, no
// drag-reorder, and no visible artifact flow between stages. M84 promotes
// stages, edges, expected artifacts, and artifact handoffs to first-class
// rows so the canvas can render a subgraph ("block inside a block") and the
// inspector can edit individual stages without rewriting the entire JSON.
//
// Cutover is staged across M84.s1 → s6:
//   • s1 — these models + backfill from existing JSON (this slice)
//   • s2 — REST API + service layer
//   • s3 — runtime executor reads from tables
//   • s4 — inspector UI writes via API
//   • s5 — canvas mini-graph rendering
//   • s6 — drop the legacy JSON path
//
// Until s6 lands, WorkflowNode.config still carries the legacy loopDefinition
// JSON blob and the runtime reads from it. The new tables are a SECONDARY
// source that the backfill keeps in sync — a write-through pattern.

model WorkbenchDefinition {
  id                       String   @id @default(uuid())
  workflowNodeId           String   @unique   // 1:1 with the WORKBENCH_TASK WorkflowNode
  name                     String                // e.g. "Capability implementation workbench loop"
  version                  Int      @default(1)
  goal                     String?               // operator-stated goal for the loop
  // Source repository the loop operates on. Mirrors the legacy
  // workbench config so the runtime can keep the same materializer
  // path during cutover.
  sourceType               String?               // 'github' | 'localdir'
  sourceUri                String?
  sourceRef                String?
  capabilityId             String?               // IAM capability this loop implements
  // Agent template fallbacks — used when a stage doesn't pin its own
  // agentTemplateId. The architect/developer/qa split mirrors the
  // historical role taxonomy; new roles default to no fallback.
  architectAgentTemplateId String?
  developerAgentTemplateId String?
  qaAgentTemplateId        String?
  // Loop budget knobs.
  maxLoopsPerStage         Int      @default(3)
  maxTotalSendBacks        Int      @default(6)
  gateMode                 String   @default("manual")  // 'manual' | 'auto'
  finalPackKey             String?               // context key the approval pack writes to
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  stages WorkbenchStage[]

  @@index([workflowNodeId])
  @@map("workbench_definitions")
}

model WorkbenchStage {
  id               String   @id @default(uuid())
  definitionId     String
  definition       WorkbenchDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  // Operator-defined key, unique within a definition. e.g. "STORY_INTAKE",
  // "DESIGN", "DEVELOP", "QA". The legacy loopDefinition used these keys to
  // chain stages via `next`; M84 uses ordinal + edges instead, but we keep
  // the key as a stable identifier for receipts/audit-gov correlation.
  stageKey         String
  label            String                // human label e.g. "Story Intake"
  agentRole        String                // PRODUCT_OWNER / ARCHITECT / DEVELOPER / QA / ...
  agentTemplateId  String?               // overrides definition-level fallback when set
  promptProfileKey String?
  // Ordering — drives the default forward chain when no explicit edges
  // exist. Drag-reorder updates this. ordinal 0 = first stage.
  ordinal          Int      @default(0)
  // Canvas position when the operator pinned one (subgraph rendering).
  // Auto-laid out from ordinal when both are null.
  positionX        Float?
  positionY        Float?
  // Stage flags.
  required         Boolean  @default(true)
  terminal         Boolean  @default(false)
  approvalRequired Boolean  @default(true)
  repoAccess       Boolean  @default(false)
  // Policy strings — kept as strings rather than enums so prompt-composer's
  // StagePolicy rows (which use the same vocabulary) stay the source of
  // truth. Adding a new policy value doesn't require a migration here.
  toolPolicy       String   @default("NONE")    // NONE | READ_ONLY | MUTATION | VERIFICATION
  contextPolicy    String   @default("NONE")    // STORY_ONLY | REPO_READ_ONLY | CODE_EDIT | VERIFY_ONLY | EVIDENCE_REVIEW
  // G8 — per-stage governance INTENT. Reconciled into scope=STAGE IAM
  // governance_attachments (target_kind=STAGE_KEY, target_key=stageKey) on
  // explicit definition save. Named governanceEnforcement (NOT governanceMode)
  // to avoid colliding with the node-level fail-open `governanceMode` field.
  governancePolicyId      String?              // governing capability (IAM business capability_id)
  governanceEnforcement   String?              // ADVISORY | REQUIRED | BLOCKING
  governancePriority      Int?
  governanceContributions Json?                // optional per-stage contributions override
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  expectedArtifacts WorkbenchExpectedArtifact[]
  questions         WorkbenchStageQuestion[]
  outgoingEdges     WorkbenchStageEdge[] @relation("WorkbenchEdgeFrom")
  incomingEdges     WorkbenchStageEdge[] @relation("WorkbenchEdgeTo")
  consumes          WorkbenchArtifactConsumes[]

  @@unique([definitionId, stageKey])
  @@index([definitionId, ordinal])
  @@map("workbench_stages")
}

model WorkbenchExpectedArtifact {
  id          String   @id @default(uuid())
  stageId     String
  stage       WorkbenchStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  // Machine key — e.g. "story_brief", "solution_architecture",
  // "code_change". The artifact-handoff edge (WorkbenchArtifactConsumes)
  // resolves by this kind, so changing it after consumers are wired is a
  // breaking change. UI surfaces a rename warning.
  kind        String
  title       String
  description String?
  format      String   @default("MARKDOWN")    // MARKDOWN | TEXT | JSON | CODE
  required    Boolean  @default(true)
  // Display order within the stage's "produces" list. Doesn't affect
  // runtime — purely cosmetic for the inspector.
  ordinal     Int      @default(0)
  // M82 — editable artifacts (operator can override after the agent
  // emits one). Mirrors the legacy LoopExpectedArtifact.editable flag.
  editable    Boolean  @default(false)
  // M102 — optional link to a catalog ArtifactTemplate (id, e.g.
  // "tmpl-design-document"). Flows into the JSON loopDefinition so the
  // runtime injects the template's section skeleton into the agent prompt;
  // the designer's catalog picker sets it.
  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consumedBy WorkbenchArtifactConsumes[]

  @@unique([stageId, kind])
  @@index([stageId, ordinal])
  @@map("workbench_expected_artifacts")
}

model WorkbenchStageEdge {
  id          String   @id @default(uuid())
  // Forward edge: from.next = to. Send-back edge: when in `to` the
  // operator/agent decides to regress, `from` is an upstream stage
  // eligible to receive the send-back. The legacy
  // `allowedSendBackTo: stageKey[]` is fully expressed as one
  // SEND_BACK edge per allowed target.
  fromStageId String
  fromStage   WorkbenchStage @relation("WorkbenchEdgeFrom", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStageId   String
  toStage     WorkbenchStage @relation("WorkbenchEdgeTo", fields: [toStageId], references: [id], onDelete: Cascade)
  kind        String   // 'FORWARD' | 'SEND_BACK'
  // Optional label for the canvas — typically auto-generated from
  // artifact-handoff resolution, but operators can override.
  label       String?
  createdAt   DateTime @default(now())

  @@unique([fromStageId, toStageId, kind])
  @@index([fromStageId])
  @@index([toStageId])
  @@map("workbench_stage_edges")
}

model WorkbenchArtifactConsumes {
  id                 String   @id @default(uuid())
  // The stage that REQUIRES this artifact as input.
  consumerStageId    String
  consumerStage      WorkbenchStage @relation(fields: [consumerStageId], references: [id], onDelete: Cascade)
  // The specific artifact (produced by some upstream stage) that
  // satisfies the requirement. Resolved by (producerStage, kind).
  producerArtifactId String
  producerArtifact   WorkbenchExpectedArtifact @relation(fields: [producerArtifactId], references: [id], onDelete: Cascade)
  required           Boolean  @default(true)
  // When true, this binding was filled in automatically by name-matching
  // (the legacy inference path). false = operator pinned it explicitly.
  // The UI shows inferred bindings with a "✦ inferred" badge in lighter
  // color until they're confirmed.
  inferred           Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@unique([consumerStageId, producerArtifactId])
  @@index([consumerStageId])
  @@map("workbench_artifact_consumes")
}

model WorkbenchStageQuestion {
  id         String   @id @default(uuid())
  stageId    String
  stage      WorkbenchStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  // Operator-defined id used in audit trails and answer payloads.
  questionId String
  text       String
  required   Boolean  @default(false)
  freeform   Boolean  @default(true)
  // Display order within the stage.
  ordinal    Int      @default(0)
  // Optional structured answer set. Shape: [{label, impact?, recommended?}].
  options    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([stageId, questionId])
  @@index([stageId, ordinal])
  @@map("workbench_stage_questions")
}

/// LLM gateway routing — maps a "touch point" (Copilot SDLC, Workbench, Chat,
/// Governed agents, Audit judge) to a connection (a model alias from the gateway
/// catalog), optionally scoped to a specific user or capability. The drag-drop
/// admin canvas writes these rows; surfaces resolve them at request time.
/// Resolution precedence: USER > CAPABILITY > DEFAULT. scopeId is '' for DEFAULT.
model LlmRouting {
  id          String   @id @default(uuid())
  touchPoint  String
  scopeType   String   @default("DEFAULT")
  scopeId     String   @default("")
  modelAlias  String
  enabled     Boolean  @default(true)
  positionX   Float?
  positionY   Float?
  createdById String?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, touchPoint, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([tenantId, enabled])
  @@map("llm_routing")
}

/// LLM connections the admin adds in the routing UI — a named gateway + model the
/// routing canvas wires to touch points. credentialEnv is the NAME of the env var
/// holding the key (the secret itself never lives in the DB). alias is the
/// model_alias used at runtime + referenced by LlmRouting.modelAlias.
model LlmConnection {
  id            String   @id @default(uuid())
  name          String
  provider      String
  baseUrl       String?
  model         String
  alias         String
  credentialEnv String?
  enabled       Boolean  @default(true)
  createdById   String?
  tenantId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, alias])
  @@map("llm_connection")
}

// Reusable Direct LLM execution strategies. Definitions are versioned so a
// published workflow can pin the exact loop behavior it was designed against.
// tenantId = null is reserved for platform-provided read-only templates.
model LoopStrategy {
  id            String               @id @default(uuid())
  tenantId      String?
  name          String
  description   String?
  kind          String               @default("PHASE") // SINGLE | PHASE | TOOL
  status        String               @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  currentVersion Int                 @default(1)
  createdById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  versions      LoopStrategyVersion[]

  @@index([tenantId, status])
  @@index([tenantId, kind])
  @@map("loop_strategies")
}

model LoopStrategyVersion {
  id            String       @id @default(uuid())
  strategyId    String
  tenantId      String?
  version       Int
  definition    Json
  contentHash   String
  createdById   String?
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  strategy      LoopStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([strategyId, version])
  @@index([tenantId, strategyId, version])
  @@map("loop_strategy_versions")
}

