// ─── EPISTEMIC LAYER (Rooms & Claims) ─────────────────────────────────────────
// Governing the *ambiguity regime* of the SDLC with inverted primitives: the unit is a hypothesis,
// not a task. Rooms are ephemeral, state-machined explorations; Claims carry Beta(alpha,beta)
// posteriors + provenance + a human steward. The belief math lives in modules/rooms/belief.ts.

enum RoomState {
  FRAMING
  DIVERGENCE
  REVEAL
  ESTIMATION
  PROBING
  REVIEW
  GATE
  CONVERGED
  ABANDONED
}

enum ClaimType {
  MARKET
  USER
  OPERATIONAL
  TECHNICAL
}

enum ClaimStatus {
  OPEN
  ACCEPTED
  PROMOTED
  RETIRED
  ABANDONED
}

// Source tier of a piece of evidence — caps how far it can move a posterior (production reality moves
// it far, an agent simulation barely). OPINION is uncapped-at-zero: opinions stay local, only evidence travels.
enum EvidenceTier {
  PRODUCTION
  EXPERIMENT
  SOURCE_DOCUMENT
  SIMULATION
  AGENT
  OPINION
}

enum ProbeStatus {
  OPEN
  RESOLVED
  ABANDONED
}

enum EstimatorKind {
  HUMAN
  AGENT
}

// A Room — an ephemeral, state-machined exploration over a project. Disposable by design; what
// endures is the claims it produces (and, in later phases, the evidence it promotes to the registry).
// ── Studio Board — event-sourced freeform board (system of record) ──────────
// The board's durable truth is an append-only, per-branch event log with a
// gap-free monotonic eventSeq (BoardBranch.headEventSeq is the fence); state is
// a pure fold over events from the nearest snapshot. See board-events.ts.
model Board {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  createdById String?
  tenantId    String?  @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branches  BoardBranch[]
  events    BoardEvent[]
  snapshots BoardSnapshot[]
  moments   BoardMoment[]
  ingestedArtifacts IngestedArtifact[]
  validationReports ArtifactValidationReport[]

  @@index([projectId])
  @@index([tenantId], map: "ix_boards_tenant")
  @@map("boards")
}

model BoardBranch {
  id                String    @id @default(uuid())
  tenantId          String?   @default("default")
  boardId           String
  name              String
  parentBranchId    String?
  forkEventSeq      BigInt?
  headEventSeq      BigInt    @default(0)
  mode              String    @default("HUMAN")
  purpose           String?
  status            String    @default("ACTIVE")
  explorationBudget Json      @default("{}")
  createdById       String?
  createdAt         DateTime  @default(now())
  mergedAt          DateTime?

  board     Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  events    BoardEvent[]
  snapshots BoardSnapshot[]
  moments   BoardMoment[]

  @@unique([boardId, name])
  @@index([tenantId, boardId, status])
  @@map("board_branches")
}

model BoardEvent {
  id          String   @id @default(uuid())
  tenantId    String?  @default("default")
  boardId     String
  branchId    String
  eventSeq    BigInt
  eventType   String
  objectIds   Json     @default("[]")
  actorType   String
  actorId     String?
  agentRole   String?
  payload     Json     @default("{}")
  causedBy    Json     @default("[]")
  coalesceKey String?
  createdAt   DateTime @default(now())

  board  Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  branch BoardBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, eventSeq])
  @@index([boardId, branchId, eventSeq])
  @@index([boardId, eventType, createdAt])
  @@map("board_events")
}

model BoardSnapshot {
  id        String   @id @default(uuid())
  tenantId  String?  @default("default")
  boardId   String
  branchId  String
  eventSeq  BigInt
  state     Json
  stateHash String
  createdAt DateTime @default(now())

  board  Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  branch BoardBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, eventSeq])
  @@map("board_snapshots")
}

// A Moment — an AI-authored, causally-narrated marker on the timeline. Detected
// deterministically, narrated by the Chronicler under the citation rule. A
// low-stakes proposal: VISIBLE immediately, auto-confirms after 72h.
model BoardMoment {
  id            String   @id @default(uuid())
  tenantId      String?  @default("default")
  boardId       String
  branchId      String
  kind          String
  detectorKey   String
  eventSeqStart BigInt
  eventSeqEnd   BigInt
  title         String
  narrative     String
  causalChain   Json     @default("[]")
  confidence    Float    @default(0)
  status        String   @default("VISIBLE")
  editedById    String?
  createdAt     DateTime @default(now())

  board  Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  branch BoardBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([boardId, branchId, eventSeqStart])
  @@index([tenantId], map: "ix_board_moments_tenant")
  @@map("board_moments")
}

// An artifact dragged onto the board (deck, doc, sheet, image, link). Ingested as
// DATA, never instructions: parsed → placed as board objects → cross-examined into
// staged claims at evidence tier SOURCE_DOCUMENT. See board-ingestion.ts.
model IngestedArtifact {
  id              String   @id @default(uuid())
  tenantId        String?  @default("default")
  boardId         String
  branchId        String
  kind            String
  filename        String
  storageRef      String?
  contentHash     String
  status          String   @default("QUEUED")
  parseSummary    Json     @default("{}")
  sourceSpans     Json     @default("[]")
  extractedClaims Json     @default("[]")
  droppedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  validationSources ArtifactValidationSource[]

  @@index([boardId, contentHash])
  @@index([tenantId], map: "ix_ingested_artifacts_tenant")
  @@map("ingested_artifacts")
}

// Human attention is a projection, not a second source of truth. The source
// record remains authoritative; this row only preserves ranking, assignment,
// auto-confirm policy, and the human decision for calibration.
model AttentionItem {
  id              String    @id @default(uuid())
  tenantId        String    @default("default")
  projectId       String
  sourceType      String
  sourceId        String
  band            String
  title           String
  summary         String
  actionHref      String?
  stakes          Float
  uncertainty     Float
  urgency         Float
  priority        Float
  rankingReason   String
  status          String    @default("OPEN")
  assignedToId    String?
  autoConfirmAt   DateTime?
  expiresAt       DateTime?
  resolution      String?
  resolutionNote  String?
  metadata        Json      @default("{}")
  lastProjectedAt DateTime  @default(now())
  resolvedById    String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sourceType, sourceId])
  @@index([tenantId, projectId, status, priority])
  @@index([assignedToId, status])
  @@map("attention_items")
}

// A cited, immutable validation result over one artifact pile. Findings and
// tensions carry source span references; humans adjudicate rather than agents
// silently resolving contradictions.
model ArtifactValidationReport {
  id            String   @id @default(uuid())
  tenantId      String   @default("default")
  projectId     String
  boardId       String
  taxonomy      Json     @default("[]")
  findings      Json     @default("[]")
  tensions      Json     @default("[]")
  citations     Json     @default("[]")
  status        String   @default("READY")
  contentHash   String
  generatedById String?
  createdAt     DateTime @default(now())

  project SpecificationProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  board   Board                      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  sources ArtifactValidationSource[]

  @@unique([boardId, contentHash])
  @@index([tenantId, projectId, createdAt])
  @@map("artifact_validation_reports")
}

model ArtifactValidationSource {
  id         String @id @default(uuid())
  reportId   String
  artifactId String
  tenantId   String @default("default")

  report   ArtifactValidationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  artifact IngestedArtifact         @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([reportId, artifactId])
  @@index([tenantId])
  @@index([artifactId])
  @@map("artifact_validation_sources")
}

// An agent's verdict on a human artifact — CHALLENGE / ENDORSE / FLAG. Voice, never
// a vote: it never changes the target's status. boardId is nullable (verdicts also
// apply to graph artifacts). Anti-nag "one OPEN per (target, agent, stance)" is a
// partial unique index (see the m100 migration). See board-verdicts.ts.
model AgentVerdict {
  id           String    @id @default(uuid())
  tenantId     String?   @default("default")
  boardId      String?
  targetType   String
  targetRef    String
  actorType    String    @default("AGENT")
  agentRole    String
  stance       String
  rationale    String
  evidenceRefs Json      @default("[]")
  resolvesWith String?
  confidence   Float     @default(0.6)
  status       String    @default("OPEN")
  createdById  String?
  answeredById String?
  answerNote   String?
  traceId      String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  @@index([tenantId, boardId, status])
  @@index([targetType, targetRef, status])
  @@map("agent_verdicts")
}

model Room {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  state       RoomState @default(FRAMING)
  createdById String?
  tenantId    String?   @default("default")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  claims  Claim[]
  probes  Probe[]

  @@index([projectId])
  @@index([state])
  @@index([tenantId], map: "ix_rooms_tenant")
  @@map("rooms")
}

// A Claim — a hypothesis carrying a Beta(alpha,beta) posterior over P(true), a riskiest assumption, a
// provenance chain, a context scope, and a HUMAN steward (accountability never transfers to agents).
// The statement is immutable per version; alpha/beta is the live belief state.
model Claim {
  id                 String      @id @default(uuid())
  projectId          String
  roomId             String?
  statement          String
  riskiestAssumption String?
  claimType          ClaimType   @default(TECHNICAL)
  contextScope       String      @default("default")
  entityKind         String?
  entityId           String?
  capabilityId       String?
  alpha              Float       @default(1)
  beta               Float       @default(1)
  version            Int         @default(1)
  supersedesId       String?
  status             ClaimStatus @default(OPEN)
  stewardId          String
  provenance         Json        @default("{}")
  createdById        String?
  tenantId           String?     @default("default")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  project   SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room      Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  estimates Estimate[]
  probes    Probe[]
  evidence  Evidence[]
  driftSignals ClaimDriftSignal[]

  @@index([projectId])
  @@index([roomId])
  @@index([contextScope])
  @@index([capabilityId])
  @@index([status])
  @@index([tenantId], map: "ix_claims_tenant")
  @@map("claims")
}

model ClaimDriftSignal {
  id                  String   @id @default(uuid())
  projectId           String
  claimId             String
  reconciliationRunId String?
  beforeMean          Float
  afterMean           Float
  delta               Float
  direction           String
  threshold           Float
  status              String   @default("OPEN")
  traceId             String?
  tenantId            String?  @default("default")
  createdAt           DateTime @default(now())

  project           SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  claim             Claim                @relation(fields: [claimId], references: [id], onDelete: Cascade)
  reconciliationRun ReconciliationRun?   @relation(fields: [reconciliationRunId], references: [id], onDelete: SetNull)
  changeRequests    SpecificationChangeRequest[]

  @@unique([reconciliationRunId, claimId])
  @@index([projectId, createdAt])
  @@index([tenantId, status])
  @@map("claim_drift_signals")
}

model SpecificationChangeRequest {
  id                     String              @id @default(uuid())
  projectId              String
  driftSignalId          String?
  specificationVersionId String?
  title                  String
  reason                 String
  requirementDeltas      Json                @default("{}")
  costDelta              Json                @default("{}")
  scheduleDelta          Json                @default("{}")
  milestoneImpacts       Json                @default("[]")
  status                 ChangeControlStatus @default(RECOMMENDED)
  sponsorApprovalId      String?
  readoutId              String?
  resultingVersionId     String?
  requestedById          String?
  decidedById            String?
  decidedAt              DateTime?
  appliedAt              DateTime?
  traceId                String?
  metadata               Json                @default("{}")
  tenantId               String?             @default("default")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  project              SpecificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  driftSignal          ClaimDriftSignal?    @relation(fields: [driftSignalId], references: [id], onDelete: SetNull)
  specificationVersion SpecificationVersion? @relation(fields: [specificationVersionId], references: [id], onDelete: SetNull)

  @@index([projectId, status, createdAt])
  @@index([tenantId, status])
  @@map("specification_change_requests")
}

// An Estimate — one participant's probability that a claim is true (a human or an agent peer). Latest
// per estimator; estimates pool (calibration-weighted) into the claim's prior, and their variance
// locates ignorance (where mental models diverge).
model Estimate {
  id            String        @id @default(uuid())
  claimId       String
  estimatorId   String
  estimatorKind EstimatorKind @default(HUMAN)
  probability   Float
  weight        Float         @default(1)
  rationale     String?
  tenantId      String?       @default("default")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@unique([claimId, estimatorId])
  @@index([claimId])
  @@index([tenantId], map: "ix_claim_estimates_tenant")
  @@map("claim_estimates")
}

// A Probe — the cheapest experiment that could falsify a claim's riskiest assumption. Pre-registers its
// falsification condition, has exactly one owner + a deadline, and carries an expected-information-gain
// (computed at creation) that feeds the room's arithmetic stopping rule. Resolving a probe emits Evidence.
model Probe {
  id                 String       @id @default(uuid())
  claimId            String
  roomId             String?
  riskiestAssumption String
  falsification      String
  tier               EvidenceTier @default(SIMULATION)
  ownerId            String
  deadline           DateTime?
  status             ProbeStatus  @default(OPEN)
  eig                Float?
  outcome            String?
  createdById        String?
  tenantId           String?      @default("default")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  claim    Claim      @relation(fields: [claimId], references: [id], onDelete: Cascade)
  room     Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  evidence Evidence[]

  @@index([claimId])
  @@index([roomId])
  @@index([status])
  @@index([tenantId], map: "ix_claim_probes_tenant")
  @@map("claim_probes")
}

// A piece of Evidence bound to a claim — the durable output of a probe (artifacts are disposable). Its
// tier caps how far it moves the posterior; `evidenceKey` is the identity that makes promotion idempotent
// (the same observation arriving twice counts once). supports=true adds to alpha, false to beta.
model Evidence {
  id          String       @id @default(uuid())
  claimId     String
  probeId     String?
  tier        EvidenceTier
  supports    Boolean
  weight      Float        @default(1)
  evidenceKey String       @unique
  sourceUri   String?
  note        String?
  createdById String?
  tenantId    String?      @default("default")
  createdAt   DateTime     @default(now())

  claim Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  probe Probe? @relation(fields: [probeId], references: [id], onDelete: SetNull)

  @@index([claimId])
  @@index([tenantId], map: "ix_claim_evidence_tenant")
  @@map("claim_evidence")
}

// The approved specification, made developer-ready: which repo/base to build against, which
// requirements are in scope, and what evidence reconciliation will require. One per Work Item
// for a single repo (a multi-repo Work Item would later introduce child DevelopmentScopes).
model DevelopmentTarget {
  id                     String    @id @default(uuid())
  workItemId             String    @unique
  specificationVersionId String
  repository             String
  component              String?
  baseBranch             String
  baseCommitSha          String
  requirementIds         Json      @default("[]")
  requiredEvidence       Json      @default("[]")
  forbiddenPaths         Json      @default("[]")
  reconciliationPolicy   Json      @default("{}")
  dueAt                  DateTime?
  status                 String    @default("DRAFT")
  publishedAt            DateTime?
  tenantId               String?   @default("default")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "ix_development_targets_tenant")
  @@map("development_targets")
}

// One exact external implementation attempt. Immutable per head commit SHA — a new PR commit
// creates a new record rather than overwriting, so the reconciliation history is preserved.
model ImplementationSubmission {
  id                     String   @id @default(uuid())
  workItemId             String
  specificationVersionId String
  specificationBindingId String?
  developmentScopeId     String?
  handoffGenerationId    String?
  specificationHash      String
  repository             String
  baseCommitSha          String
  headCommitSha          String
  pullRequestNumber      Int?
  manifest               Json?
  claims                 Json     @default("[]")
  deviations             Json     @default("[]")
  source                 String
  status                 String   @default("DISCOVERED")
  tenantId               String?  @default("default")
  createdAt              DateTime @default(now())

  specificationVersion SpecificationVersion @relation(fields: [specificationVersionId], references: [id], onDelete: Cascade)
  specificationBinding WorkItemSpecificationBinding? @relation(fields: [specificationBindingId], references: [id], onDelete: SetNull)
  developmentScope     DevelopmentScope? @relation(fields: [developmentScopeId], references: [id], onDelete: SetNull)
  handoffGeneration    HandoffGeneration? @relation(fields: [handoffGenerationId], references: [id], onDelete: SetNull)
  workItem             WorkItem             @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  reconciliationRuns   ReconciliationRun[]

  @@unique([workItemId, repository, headCommitSha])
  @@index([workItemId, createdAt])
  @@index([tenantId], map: "ix_implementation_submissions_tenant")
  @@map("implementation_submissions")
}

enum ReconciliationStatus {
  PENDING
  RUNNING
  DECLARED_CONSISTENT
  SEMANTICALLY_REVIEWED
  VERIFIED_PASS
  PASSED
  FAILED
  PARTIAL
  ERROR
  CANCELLED
}

enum RequirementVerdictValue {
  PASS
  PARTIAL
  FAIL
  NOT_APPLICABLE
  NOT_VERIFIED
}

enum ReconciliationFindingSeverity {
  ERROR
  WARNING
  INFO
}

// One reconciliation of a single ImplementationSubmission against the approved specification it
// claims. The DETERMINISTIC layer (declared-evidence + path/test policy) runs in-request and is
// pure; the dynamic (test-execution) layer will attach later via the runner queue. The run is the
// evidence spine (traceId) tying a per-requirement verdict matrix to the immutable submission.
model ReconciliationRun {
  id                     String               @id @default(uuid())
  workItemId             String
  submissionId           String
  specificationVersionId String
  specificationBindingId String?
  developmentScopeId    String?
  handoffGenerationId   String?
  generation             Int                  @default(1)
  specificationHash      String?
  mode                   String               @default("DETERMINISTIC")
  status                 ReconciliationStatus  @default(PENDING)
  reconciliationState    ReconciliationState   @default(UNVERIFIED)
  summary                Json                  @default("{}")
  traceId                String?
  startedById            String?
  startedAt              DateTime              @default(now())
  completedAt            DateTime?
  tenantId               String?               @default("default")
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  submission ImplementationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  workItem   WorkItem                 @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  specificationBinding WorkItemSpecificationBinding? @relation(fields: [specificationBindingId], references: [id], onDelete: SetNull)
  developmentScope    DevelopmentScope? @relation(fields: [developmentScopeId], references: [id], onDelete: SetNull)
  handoffGeneration   HandoffGeneration? @relation(fields: [handoffGenerationId], references: [id], onDelete: SetNull)
  verdicts   RequirementVerdict[]
  findings   ReconciliationFinding[]
  job        ReconciliationJob?
  driftSignals ClaimDriftSignal[]

  @@index([workItemId, createdAt])
  @@index([submissionId])
  @@index([developmentScopeId, generation])
  @@index([tenantId], map: "ix_reconciliation_runs_tenant")
  @@map("reconciliation_runs")
}

// Per-requirement outcome of a reconciliation run — the row-level cells of the verdict matrix.
model RequirementVerdict {
  id                  String                  @id @default(uuid())
  reconciliationRunId String
  requirementId       String
  priority            String?
  verdict             RequirementVerdictValue
  claimStatus         String?
  rationale           String?
  evidence            Json                    @default("[]")
  // true once the verdict is backed by actual test execution (dynamic layer), not just declared evidence.
  verified            Boolean                 @default(false)
  createdAt           DateTime                @default(now())

  reconciliationRun ReconciliationRun @relation(fields: [reconciliationRunId], references: [id], onDelete: Cascade)

  @@unique([reconciliationRunId, requirementId])
  @@index([reconciliationRunId])
  @@map("requirement_verdicts")
}

// A single issue surfaced by a reconciliation run — run-level (policy/path) or per-requirement.
model ReconciliationFinding {
  id                  String                        @id @default(uuid())
  reconciliationRunId String
  requirementId       String?
  kind                String
  severity            ReconciliationFindingSeverity @default(WARNING)
  message             String
  detail              Json?
  createdAt           DateTime                      @default(now())

  reconciliationRun ReconciliationRun @relation(fields: [reconciliationRunId], references: [id], onDelete: Cascade)

  @@index([reconciliationRunId])
  @@map("reconciliation_findings")
}

enum ReconciliationJobStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

// The dynamic (test-execution) layer of reconciliation (spec §15, "Layer 2"). Because running an
// implementer's declared tests means executing customer code, it MUST NOT run in-request — the
// deterministic run enqueues one job here, and an out-of-process runner claims it (atomic claim +
// claimToken fencing, mirroring PendingExecution), checks out the head commit, runs the test plan
// in isolation, and POSTs results back to refine the run's verdicts from declared to verified.
model ReconciliationJob {
  id                  String                  @id @default(uuid())
  reconciliationRunId String                  @unique
  workItemId          String
  submissionId        String
  generation          Int                     @default(1)
  status              ReconciliationJobStatus @default(PENDING)
  repository          String
  baseCommitSha       String
  headCommitSha       String
  testPlan            Json                    @default("[]")
  claimToken          String?
  claimedBy           String?
  claimedAt           DateTime?
  leaseUntil          DateTime?
  heartbeatAt         DateTime?
  attempts            Int                     @default(0)
  maxAttempts         Int                     @default(3)
  result              Json?
  error               String?
  deadLetterReason    String?
  tenantId            String?                 @default("default")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  reconciliationRun ReconciliationRun @relation(fields: [reconciliationRunId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([workItemId])
  @@index([tenantId], map: "ix_reconciliation_jobs_tenant")
  @@map("reconciliation_jobs")
}

// Collaboration — a comment/thread on the studio, optionally anchored to a spec artifact
// (a requirement, diagram, decision, …). @mentions are stored resolved; threads via parentId;
// resolvable. The shared "work together" layer over the versioned spec.
model SpecComment {
  id           String    @id @default(uuid())
  workItemId   String
  anchorKind   String?
  anchorId     String?
  body         String
  authorId     String
  mentions     Json      @default("[]")
  parentId     String?
  resolvedAt   DateTime?
  resolvedById String?
  tenantId     String?   @default("default")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId, createdAt])
  @@index([workItemId, anchorKind, anchorId])
  @@index([tenantId], map: "ix_spec_comments_tenant")
  @@map("spec_comments")
}

model WorkItemDependency {
  id             String   @id @default(uuid())
  predecessorId  String
  successorId    String
  dependencyType String   @default("BLOCKS")
  condition      Json?
  createdById    String?
  tenantId       String?  @default("default")
  predecessor    WorkItem @relation("DependencyPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor      WorkItem @relation("DependencySuccessor", fields: [successorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([predecessorId, successorId])
  @@index([tenantId])
  @@index([predecessorId])
  @@index([successorId])
  @@map("work_item_dependencies")
}

model WorkProgram {
  id           String              @id @default(uuid())
  name         String
  description  String?
  capabilityId String?
  version      Int                 @default(1)
  status       String              @default("DRAFT")
  metadata     Json                @default("{}")
  createdById  String?
  tenantId     String?             @default("default")
  steps        WorkProgramStep[]
  runs         WorkProgramRun[]
  completionWorkItems WorkItem[]            @relation("WorkItemCompletionProgram")
  completionProjects  SpecificationProject[] @relation("ProjectCompletionProgram")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId])
  @@index([capabilityId, status])
  @@map("work_programs")
}

model WorkProgramStep {
  id                 String              @id @default(uuid())
  programId          String
  stepKey            String
  ordinal            Int                 @default(0)
  titleTemplate      String
  descriptionTemplate String?
  workItemTypeKey    String              @default("GENERAL")
  targetCapabilityId String
  workflowTemplateId String?
  routingMode        WorkItemRoutingMode @default(MANUAL)
  inputMapping       Json                @default("{}")
  dependsOnKeys      Json                @default("[]")
  program            WorkProgram         @relation(fields: [programId], references: [id], onDelete: Cascade)
  workflowTemplate   Workflow?           @relation(fields: [workflowTemplateId], references: [id], onDelete: SetNull)
  runSteps           WorkProgramRunStep[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([programId, stepKey])
  @@index([workflowTemplateId])
  @@index([programId, ordinal])
  @@map("work_program_steps")
}

model WorkProgramRun {
  id          String               @id @default(uuid())
  programId   String
  status      String               @default("RUNNING")
  input       Json                 @default("{}")
  output      Json?
  startedById String?
  tenantId    String?              @default("default")
  program     WorkProgram          @relation(fields: [programId], references: [id], onDelete: Cascade)
  steps       WorkProgramRunStep[]
  startedAt   DateTime             @default(now())
  completedAt DateTime?

  @@index([tenantId, status])
  @@index([programId, startedAt])
  @@map("work_program_runs")
}

model WorkProgramRunStep {
  id          String           @id @default(uuid())
  runId       String
  stepId      String
  workItemId  String
  status      String           @default("QUEUED")
  output      Json?
  run         WorkProgramRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  step        WorkProgramStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  workItem    WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  startedAt   DateTime?
  completedAt DateTime?

  @@unique([runId, stepId])
  @@index([workItemId])
  @@map("work_program_run_steps")
}

model WorkItemTarget {
  id                      String            @id @default(uuid())
  workItemId              String
  targetCapabilityId      String
  childWorkflowTemplateId String?
  childWorkflowInstanceId String?
  roleKey                 String?
  status                  WorkItemTargetStatus @default(QUEUED)
  claimedById             String?
  output                  Json?
  claimedAt               DateTime?
  startedAt               DateTime?
  submittedAt             DateTime?
  completedAt             DateTime?
  workItem                WorkItem          @relation(fields: [workItemId], references: [id], onDelete: Cascade)
