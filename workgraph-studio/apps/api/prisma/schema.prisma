  @@index([dedupeKey])
  @@map("work_item_triggers")
}

// P1-7 — inbound-event idempotency. One claim row per (triggerId, dedupeValue)
// makes event -> WorkItem creation race-safe: concurrent or retried deliveries
// resolving to the same dedupe/correlation value collide on the unique
// constraint, so only ONE WorkItem is created for the event. Windowed via
// claimedAt (not a permanent block) so a genuine later recurrence of the same
// key is not wrongly suppressed; old rows are swept by claimedAt.
model WorkItemEventDedup {
  id          String   @id @default(uuid())
  triggerId   String
  dedupeValue String
  workItemId  String?
  claimedAt   DateTime @default(now())

  @@unique([triggerId, dedupeValue])
  @@index([claimedAt])
  @@map("work_item_event_dedup")
}

// ─── TASKS ────────────────────────────────────────────────────────────────────

model Task {
  id             String              @id @default(uuid())
  instanceId     String?
  // RLS: direct tenant column so standalone (null-instanceId) rows are representable
  // under the revised policy `tenantId = current_tenant OR instance-visible`.
  tenantId       String?
  nodeId         String?
  title          String
  description    String?
  status         TaskStatus          @default(OPEN)
  assignmentMode AssignmentMode      @default(DIRECT_USER)
  priority       Int                 @default(50)
  dueAt          DateTime?
  formSchema     Json?
  formData       Json?
  instance       WorkflowInstance?   @relation(fields: [instanceId], references: [id])
  assignments    TaskAssignment[]
  queueItems     TeamQueueItem[]
  comments       TaskComment[]
  statusHistory  TaskStatusHistory[]
  attachments    Document[]
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tenantId], map: "ix_tasks_tenant")
  @@index([instanceId], map: "ix_tasks_instance")
  @@index([status, dueAt], map: "ix_tasks_status_due")
  @@map("tasks")
}

model TaskAssignment {
  id           String    @id @default(uuid())
  taskId       String
  assignedToId String?
  teamId       String?
  roleId       String?
  skillId      String?
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedAt   DateTime  @default(now())
  claimedAt    DateTime?
  completedAt  DateTime?

  @@map("task_assignments")
}

// Queue of tasks awaiting claim by an eligible user.  Eligibility is
// determined by the populated columns: a row may be tagged with `teamId`
// (TEAM_QUEUE), `roleKey` + `capabilityId` (ROLE_BASED), or `skillKey`
// (SKILL_BASED).  At most one of these is set per row; the runtime enqueues
// one row per assignment-mode at task activation time.
model TeamQueueItem {
  id             String    @id @default(uuid())
  taskId         String
  // Optional team membership filter (TEAM_QUEUE mode)
  teamId         String?
  // Optional role filter — combined with capabilityId via IAM authzCheck
  roleKey        String?
  // Optional skill filter — eligibility resolved against IAM /skills/:key/users
  skillKey       String?
  // Capability that scopes role-based eligibility (always set for ROLE_BASED)
  capabilityId   String?
  // Echoes which AssignmentMode produced this row, for auditing.
  assignmentMode String?
  claimedById    String?
  team           Team?     @relation(fields: [teamId], references: [id])
  task           Task      @relation(fields: [taskId], references: [id])
  enqueuedAt     DateTime  @default(now())
  claimedAt      DateTime?

  @@index([taskId])
  @@index([teamId])
  @@index([roleKey, capabilityId])
  @@index([skillKey])
  @@index([claimedById])
  @@map("team_queue_items")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("task_comments")
}

model TaskStatusHistory {
  id             String      @id @default(uuid())
  taskId         String
  previousStatus TaskStatus?
  newStatus      TaskStatus
  changedById    String?
  reason         String?
  task           Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedAt      DateTime    @default(now())

  @@map("task_status_history")
}

