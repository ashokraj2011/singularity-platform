{
  "name": "@singularity/platform-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev":   "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "express": "4.21.2",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-http": "10.4.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "@vitest/coverage-v8": "2.1.8",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "vitest": "2.1.8"
  }
}
