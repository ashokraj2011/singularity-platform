// M42.1 — Singularity Code Foundry data model.
//
// Lives in a dedicated singularity_codegen DB on at-postgres (the same
// physical container that hosts singularity_composer + singularity). The
// schema is intentionally narrow at M42.1 — only the spec spine and a
// receipt skeleton. Generation artifacts, gaps, and patch tasks follow
// in M42.2/M42.3/M42.4 by EXTENDING this schema (idempotent prisma db
// push), not by replacing it.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CODEGEN SPECS ─────────────────────────────────────────────────────────
// A spec is a structured YAML service description. We persist the
// canonicalized JSON form alongside the raw YAML so re-reading is
// deterministic and the hash is stable across cosmetic edits.

enum SpecLifecycleState {
  DRAFT
  VALIDATED
  POLICY_APPROVED
  FROZEN
  GENERATED
  SUPERSEDED
}

model CodegenSpec {
  id              String              @id @default(uuid())
  // The spec's own metadata.id from the YAML (e.g. 'eligibility-service-spec').
  // (id_within_tenant, version) is globally unique within a tenant per §8.15.
  specName        String
  version         String              @default("1.0.0")
  kind            String              // 'service' | 'code_enhancement' (M42.5)
  state           SpecLifecycleState  @default(DRAFT)
  yaml            String              // raw YAML for human review
  canonicalJson   Json                // sorted-key JSON form (the hash anchor)
  specHash        String              // sha256:<hex> of canonicalJson
  irJson          Json?               // populated when state advances past POLICY_APPROVED
  irHash          String?
  workItemId      String?
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lifecycleEvents SpecLifecycleEvent[]
  runs            CodegenRun[]

  @@unique([specName, version])
  @@index([state, createdAt])
  @@index([specHash])
  @@map("codegen_specs")
}

// Lifecycle audit trail per spec. Every state transition writes a row
// here; receipts and audit-gov events reference these for replay.
model SpecLifecycleEvent {
  id          String              @id @default(uuid())
  specId      String
  fromState   SpecLifecycleState?
  toState     SpecLifecycleState
  actorId     String?
  reason      String?
  payload     Json?
  occurredAt  DateTime            @default(now())

  spec        CodegenSpec         @relation(fields: [specId], references: [id], onDelete: Cascade)

  @@index([specId, occurredAt])
  @@map("codegen_spec_lifecycle_events")
}

// ─── CODEGEN RUNS ──────────────────────────────────────────────────────────
// A run is one (spec, IR, template-version, generator-version) tuple
// resolved at a point in time. M42.1 only records the run row; M42.2
// fills in generated_artifacts and M42.3+ adds gaps + patches.

enum RunStatus {
  STARTED
  GENERATED
  VERIFIED
  GAPS_DETECTED
  PATCHED
  CERTIFIED
  COMPLETED
  FAILED
}

enum RunMode {
  GREENFIELD
  BROWNFIELD
}

model CodegenRun {
  id                String      @id @default(uuid())
  specId            String
  irHash            String
  templateVersion   String      // e.g. 'springboot-template-1.0.0'
  generatorVersion  String      // e.g. 'code-foundry-0.1.0'
  status            RunStatus   @default(STARTED)
  // M42.5 — distinguishes a from-scratch generation (greenfield) from
  // a recipe-driven modification of an existing repo (brownfield).
  // For brownfield runs, outputPath is the scanned repo's root and
  // the run references a CodegenChangePlan via brownfieldPlanId.
  mode              RunMode     @default(GREENFIELD)
  brownfieldPlanId  String?
  outputPath        String?     // host path or workspace ref (M42.2)
  startedAt         DateTime    @default(now())
  completedAt       DateTime?

  spec              CodegenSpec    @relation(fields: [specId], references: [id], onDelete: Cascade)
  receipt           CodegenReceipt?
  artifacts         CodegenArtifact[]
  gaps              CodegenGap[]
  verifications     CodegenVerification[]
  llmTasks          CodegenLlmPatchTask[]
  changePlan        CodegenChangePlan? @relation(fields: [brownfieldPlanId], references: [id])

  @@index([specId, startedAt])
  @@index([status])
  @@index([mode])
  @@map("codegen_runs")
}

// ─── BROWNFIELD MODELS (M42.5) ─────────────────────────────────────────────
// Patent Chain B primitive. The Repo Model is the structured snapshot
// of an existing repository the scanner produces; the Change Plan is
// the typed list of operations the dispatcher emits after the impact
// analysis classifies an enhancement against known patterns.

model CodegenRepoModel {
  id            String        @id @default(uuid())
  repoPath      String
  language      String        // 'java' | 'python' | 'typescript'
  framework     String        // 'spring-boot' | 'fastapi' | 'express'
  modelJson     Json
  modelHash     String
  scannedById   String?
  scannedAt     DateTime      @default(now())
  changePlans   CodegenChangePlan[]

  @@index([repoPath, scannedAt])
  @@index([modelHash])
  @@map("codegen_repo_models")
}

enum ChangePlanStatus {
  PROPOSED         // built; awaiting apply
  PARTIALLY_APPLIED
  APPLIED
  FAILED
  REJECTED
}

model CodegenChangePlan {
  id                  String           @id @default(uuid())
  repoModelId         String
  enhancementSpecJson Json
  enhancementSpecHash String
  planJson            Json             // ChangeOperation[]
  planHash            String
  status              ChangePlanStatus @default(PROPOSED)
  createdAt           DateTime         @default(now())
  appliedAt           DateTime?

  repoModel           CodegenRepoModel @relation(fields: [repoModelId], references: [id])
  runs                CodegenRun[]

  @@index([repoModelId])
  @@index([status])
  @@map("codegen_change_plans")
}

// M42.2 — One row per emitted file. Storing them denormalised here
// makes it cheap for the M42.4 Patch Guard to look up "was this file
// declared protected by the generator?" and for the UI to render the
// file tree without re-parsing the receipt JSON.
model CodegenArtifact {
  id            String     @id @default(uuid())
  runId         String
  path          String
  contentHash   String
  fileType      String     // 'source' | 'test' | 'config' | 'doc' | 'contract' | 'manifest'
  generatedBy   String     // template id
  protected     Boolean    @default(false)
  createdAt     DateTime   @default(now())

  run           CodegenRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, path])
  @@index([runId])
  @@map("codegen_artifacts")
}

// ─── CODEGEN GAPS (M42.3) ──────────────────────────────────────────────────
// One row per finding produced by the Gap Detector. Patches in M42.4
// reference rows here via gapId; the M42.6 UI surfaces them in the
// approval flow. `resolved` flips to true once a patch lands and
// verification re-runs green.

enum GapType {
  MISSING_BUSINESS_LOGIC
  MISSING_DATASOURCE_CLIENT
  MISSING_IMPORT
  COMPILE_ERROR
  TEST_FAILURE
  POLICY_VIOLATION
  MISSING_TEST_CASE
  UNRESOLVED_TODO
  UNRESOLVED_TEMPLATE_VAR
  UNSUPPORTED_SPEC_FEATURE
}

enum GapSeverity {
  low
  medium
  high
  critical
}

model CodegenGap {
  id            String       @id @default(uuid())
  runId         String
  gapType       GapType
  severity      GapSeverity  @default(medium)
  filePath      String?
  className     String?
  methodName    String?
  // Region marker id (e.g. 'business-logic') when the gap is anchored
  // to an llm-editable region.
  regionId      String?
  description   String
  // Free-form recommendation surfaced to the operator or LLM.
  recommendedResolution String?
  llmEligible   Boolean      @default(false)
  resolved      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  resolvedAt    DateTime?

  run           CodegenRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, resolved])
  @@index([gapType])
  @@map("codegen_gaps")
}

// ─── LLM PATCH TASKS (M42.4) ───────────────────────────────────────────────
// Patent Chain D primitive: a typed task object that bounds an LLM to
// exactly one editable region of one file, with an enumerated allowed-
// and forbidden-changes ontology the Patch Guard enforces mechanically.

enum LlmTaskType {
  COMPLETE_METHOD_BODY
  GENERATE_ADDITIONAL_TESTS
  FIX_COMPILE_ERROR
  COMPLETE_MAPPING_LOGIC
  UPDATE_TEST_ASSERTIONS
}

enum LlmTaskStatus {
  PENDING        // task built; awaiting dispatch
  DISPATCHED     // sent to LLM (or operator); awaiting diff
  GUARD_PASSED   // diff returned + accepted by Patch Guard; applied to disk
  GUARD_REJECTED // diff returned but rejected; reason captured in metadata
  CANCELLED
  FAILED
}

model CodegenLlmPatchTask {
  id              String       @id @default(uuid())
  runId           String
  gapId           String?      // null when synthesised manually
  taskType        LlmTaskType
  status          LlmTaskStatus @default(PENDING)
  targetFile      String
  targetClass     String?
  targetMethod    String?
  regionId        String       // anchors the patch to a typed region
  allowedChanges  Json         // string[] — change-class ontology
  forbiddenChanges Json        // string[] — change-class ontology
  promptHash      String?      // sha256 of the assembled prompt body
  responseHash    String?      // sha256 of the unified diff returned
  cfCallId        String?      // context-fabric call id, when composer was used
  bundleHash      String?      // ImmutableContract bundleHash (M40), when composer was used
  metadata        Json?        // free-form (guard reason, prompt snippet, etc.)
  createdAt       DateTime     @default(now())
  dispatchedAt    DateTime?
  completedAt     DateTime?

  run             CodegenRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, status])
  @@index([gapId])
  @@map("codegen_llm_patch_tasks")
}

// ─── VERIFICATION RESULT (M42.3) ───────────────────────────────────────────
// Captures the output of running the per-stack toolchain against a
// generated tree. Multiple results per run are allowed (initial run +
// post-patch re-verify in M42.4); the latest by createdAt is the
// effective state. JSON body matches src/verify/types.ts so the M42.6
// UI can render it without a model translation.

model CodegenVerification {
  id            String     @id @default(uuid())
  runId         String
  status        String     // PASSED | FAILED | SKIPPED | PARTIAL
  result        Json       // VerificationResult shape
  createdAt     DateTime   @default(now())

  run           CodegenRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@map("codegen_verifications")
}

// ─── CODEGEN RECEIPT ───────────────────────────────────────────────────────
// Hash-chained receipt per run, per spec §8.14 + Patent Chain E.
// Includes specHash, irHash, templateVersion, generatorVersion + (post
// M42.4) patch hashes. The receiptHash is sha256 of the canonical JSON
// of the entire receipt body — auditors can verify by recomputing.

model CodegenReceipt {
  id            String     @id @default(uuid())
  runId         String     @unique
  receiptJson   Json
  receiptHash   String
  createdAt     DateTime   @default(now())

  run           CodegenRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([receiptHash])
  @@map("codegen_receipts")
}
