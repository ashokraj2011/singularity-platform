{
  "name": "@singularity-code-foundry/code-foundry-api",
  "version": "0.1.0",
  "private": true,
  "description": "Singularity Code Foundry — deterministic code-generation orchestrator. M42.1 ships the spec spine: validator + IR builder + lifecycle + receipt + CLI.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --experimental-strip-types src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "cli": "tsx src/cli/index.ts"
  },
  "bin": {
    "singularity-codegen": "src/cli/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@singularity-code-foundry/feature-flags": "*",
    "axios": "^1.7.7",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "yaml": "^2.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
