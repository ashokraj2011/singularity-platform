openapi: 3.1.0
info:
  title: {{application.name}}
  version: 1.0.0
  description: |
    Generated by Singularity Code Foundry.
    spec hash: {{meta.specHash}}
    ir hash:   {{meta.irHash}}
paths:
{{#each endpoints}}
  {{this.fullPath}}:
    {{this.method}}:
      operationId: {{this.operationId}}
      parameters:
{{#each this.pathParams}}        - in: path
          name: {{this.name}}
          required: {{this.required}}
          schema:
            type: string
{{/each}}      responses:
        '200':
          description: Success
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{this.responseType}}'
{{#each this.errors}}        '{{this.statusCode}}':
          description: Error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{this.responseType}}'
{{/each}}{{/each}}
components:
  schemas:
{{#each models}}    {{this.name}}:
      type: object
      properties:
{{#each this.fields}}        {{this.name}}:
          type: {{this.jsonType}}
{{#if this.format}}          format: {{this.format}}
{{/if}}{{/each}}      required:
{{#each this.fields}}{{#if this.required}}        - {{this.name}}
{{/if}}{{/each}}{{/each}}
