{
  "name": "@singularity-code-foundry/code-foundry-web",
  "version": "0.1.0",
  "private": true,
  "description": "Singularity Code Foundry — minimal approval UI (M42.6). Single operator, single run, no presence/lock.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5181",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5181",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-diff-viewer-continued": "^3.4.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  },
  "engines": {
    "node": ">=20"
  }
}
