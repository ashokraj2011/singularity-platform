# Backend URLs are proxied via Vite in dev (see vite.config.ts).
# These VITE_* values are used in production where the SPA is served directly
# and needs to know absolute backend URLs.
VITE_IAM_BASE_URL=http://localhost:8100/api/v1
VITE_WORKGRAPH_BASE_URL=http://localhost:8080/api
VITE_COMPOSER_BASE_URL=http://localhost:3004/api/v1
VITE_CONTEXT_FABRIC_BASE_URL=http://localhost:8000

# Deep-link targets for the nav bar
VITE_LINK_OPERATIONS_PORTAL=http://localhost:5180
VITE_LINK_AGENT_ADMIN=http://localhost:3000
VITE_LINK_IAM_ADMIN=http://localhost:5175
VITE_LINK_WORKGRAPH_DESIGNER=http://localhost:5174
VITE_LINK_BLUEPRINT_WORKBENCH=http://localhost:5176

# Override mode: 'proxy' (Vite dev) | 'direct' (production)
VITE_API_MODE=proxy
